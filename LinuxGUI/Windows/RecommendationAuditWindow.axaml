<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:CKAN.LinuxGUI"
        x:Class="CKAN.LinuxGUI.RecommendationAuditWindow"
        x:CompileBindings="False"
        Width="980"
        Height="620"
        MinWidth="860"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Title="Audit Recommendations"
        Background="#171C22">
  <Window.Styles>
    <Style Selector="Button.dialog-action">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Background" Value="#24303B" />
      <Setter Property="BorderBrush" Value="#405061" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Foreground" Value="#F3F7FC" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Button.dialog-action:pointerover">
      <Setter Property="Background" Value="#2E3C49" />
      <Setter Property="BorderBrush" Value="#5B7084" />
    </Style>
    <Style Selector="Button.dialog-action:pressed">
      <Setter Property="Background" Value="#1D2730" />
      <Setter Property="BorderBrush" Value="#6A7F94" />
    </Style>
    <Style Selector="Button.dialog-action:disabled">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#303A44" />
      <Setter Property="Foreground" Value="#7B8794" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="TextBlock.detail-label">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="#98A5B3" />
      <Setter Property="Margin" Value="0,1,0,1" />
    </Style>
    <Style Selector="TextBlock.detail-value">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="#EEF3F8" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="Margin" Value="0,1,0,1" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto"
        Margin="20">
    <Grid
          ColumnDefinitions="*,Auto"
          Margin="0,0,0,12">
      <TextBlock VerticalAlignment="Center"
                 FontSize="13"
                 Opacity="0.82"
                 Text="{Binding SelectionSummary}" />
      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="10">
        <Button Classes="dialog-action"
                Click="UncheckAllButton_OnClick"
                Content="Uncheck All" />
        <Button Classes="dialog-action"
                Click="CheckAllButton_OnClick"
                Content="Check All" />
        <Button Classes="dialog-action"
                Click="CheckRecommendationsButton_OnClick"
                Content="Check Recommendations" />
        <Button Classes="dialog-action"
                Click="CheckSuggestionsButton_OnClick"
                Content="Check Suggestions" />
      </StackPanel>
    </Grid>

    <Border Grid.Row="1"
            Background="#161B21"
            BorderBrush="#2B323C"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12">
      <Grid RowDefinitions="Auto,*,Auto">
        <Grid ColumnDefinitions="34,2*,1.25*,0.8*,2.2*"
              Margin="10,0,10,6">
          <TextBlock Grid.Column="1"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="#AEB9C5"
                     Text="Mod" />
          <Border Grid.Column="2"
                  BorderBrush="#26323D"
                  BorderThickness="1,0,0,0"
                  Padding="12,0,0,0">
            <TextBlock FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#AEB9C5"
                       Text="Related mod" />
          </Border>
          <Border Grid.Column="3"
                  BorderBrush="#26323D"
                  BorderThickness="1,0,0,0"
                  Padding="12,0,0,0">
            <TextBlock FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#AEB9C5"
                       Text="Downloads" />
          </Border>
          <Border Grid.Column="4"
                  BorderBrush="#26323D"
                  BorderThickness="1,0,0,0"
                  Padding="12,0,0,0">
            <TextBlock FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#AEB9C5"
                       Text="Mod description" />
          </Border>
        </Grid>

        <Border Grid.Row="1"
                Background="#111820"
                BorderBrush="#252F3A"
                BorderThickness="1">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Rows}">
              <ItemsControl.DataTemplates>
                <DataTemplate DataType="local:RecommendationAuditGroupHeader">
                  <Border Background="#151D26"
                          BorderBrush="#26313C"
                          BorderThickness="0,0,0,1"
                          Padding="10,7">
                    <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#8EB8F4"
                               Text="{Binding Title}" />
                  </Border>
                </DataTemplate>
                <DataTemplate DataType="local:RecommendationAuditItem">
                  <Border Background="{Binding DetailRowBackground}"
                          BorderBrush="{Binding DetailRowBorderBrush}"
                          BorderThickness="0,0,0,1"
                          Padding="10,8"
                          PointerPressed="RecommendationRow_OnPointerPressed">
                    <Grid ColumnDefinitions="34,2*,1.25*,0.8*,2.2*">
                      <CheckBox VerticalAlignment="Top"
                                IsEnabled="{Binding CanQueue}"
                                IsChecked="{Binding IsSelected, Mode=TwoWay}" />

                      <StackPanel Grid.Column="1"
                                  Margin="0,0,14,0"
                                  Spacing="3">
                        <Grid ColumnDefinitions="Auto,*">
                          <Border Background="{Binding KindBadgeBackground}"
                                  BorderBrush="{Binding KindBadgeBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="999"
                                  Margin="0,0,8,0"
                                  Padding="7,2">
                            <TextBlock FontSize="10"
                                       FontWeight="SemiBold"
                                       Text="{Binding Kind}" />
                          </Border>
                          <TextBlock Grid.Column="1"
                                     FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis"
                                     Text="{Binding NameAndVersion}" />
                        </Grid>
                        <TextBlock FontSize="12"
                                   Opacity="0.62"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding Identifier}" />
                      </StackPanel>

                      <Border Grid.Column="2"
                              BorderBrush="#26323D"
                              BorderThickness="1,0,0,0"
                              Padding="12,0,14,0">
                        <TextBlock FontSize="12"
                                   Opacity="0.78"
                                   TextWrapping="Wrap"
                                   Text="{Binding RelatedMods}" />
                      </Border>

                      <Border Grid.Column="3"
                              BorderBrush="#26323D"
                              BorderThickness="1,0,0,0"
                              Padding="12,0,14,0">
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Opacity="0.86"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding DownloadCountText}" />
                      </Border>

                      <Border Grid.Column="4"
                              BorderBrush="#26323D"
                              BorderThickness="1,0,0,0"
                              Padding="12,0,0,0">
                        <TextBlock FontSize="12"
                                   Opacity="0.84"
                                   TextWrapping="Wrap"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding Summary}" />
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.DataTemplates>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                IsVisible="{Binding ShowDetailPane}"
                Margin="0,12,0,0"
                Background="#111820"
                BorderBrush="#2B3846"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
          <Grid ColumnDefinitions="280,*">
            <StackPanel Margin="0,0,18,0"
                        Spacing="8">
              <StackPanel Spacing="2">
                <TextBlock FontSize="15"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding SelectedDetailItem.Name}" />
                <TextBlock FontSize="12"
                           Foreground="#AEB9C5"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding SelectedDetailItem.Identifier}" />
              </StackPanel>

              <Grid ColumnDefinitions="80,*"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <TextBlock Classes="detail-label"
                           Text="Type" />
                <TextBlock Grid.Column="1"
                           Classes="detail-value"
                           Text="{Binding SelectedDetailItem.Kind}" />

                <TextBlock Grid.Row="1"
                           Classes="detail-label"
                           Text="Version" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Classes="detail-value"
                           Text="{Binding SelectedDetailItem.Version}" />

                <TextBlock Grid.Row="2"
                           Classes="detail-label"
                           Text="Related" />
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Classes="detail-value"
                           Text="{Binding SelectedDetailItem.RelatedMods}" />

                <TextBlock Grid.Row="3"
                           Classes="detail-label"
                           Text="Authors" />
                <TextBlock Grid.Row="3"
                           Grid.Column="1"
                           Classes="detail-value"
                           Text="{Binding SelectedDetailItem.AuthorsText}" />

                <TextBlock Grid.Row="4"
                           Classes="detail-label"
                           Text="License" />
                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           Classes="detail-value"
                           Text="{Binding SelectedDetailItem.LicenseText}" />

                <TextBlock Grid.Row="5"
                           Classes="detail-label"
                           Text="Size" />
                <TextBlock Grid.Row="5"
                           Grid.Column="1"
                           Classes="detail-value"
                           Text="{Binding SelectedDetailItem.DownloadSizeText}" />

                <TextBlock Grid.Row="6"
                           Classes="detail-label"
                           Text="Downloads" />
                <TextBlock Grid.Row="6"
                           Grid.Column="1"
                           Classes="detail-value"
                           Text="{Binding SelectedDetailItem.DownloadCountText}" />
              </Grid>
            </StackPanel>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*,Auto">
              <TextBlock FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="#AEB9C5"
                         Text="Description" />
              <ScrollViewer Grid.Row="1"
                            Margin="0,6,0,8"
                            MaxHeight="126"
                            VerticalScrollBarVisibility="Auto">
                <TextBlock FontSize="12"
                           Foreground="#E1E7EE"
                           TextWrapping="Wrap"
                           Text="{Binding SelectedDetailItem.DetailDescription}" />
              </ScrollViewer>
              <Grid Grid.Row="2"
                    ColumnDefinitions="70,*"
                    RowDefinitions="Auto,Auto">
                <TextBlock Classes="detail-label"
                           Text="Released" />
                <TextBlock Grid.Column="1"
                           Classes="detail-value"
                           Text="{Binding SelectedDetailItem.ReleaseDateText}" />

                <TextBlock Grid.Row="1"
                           Classes="detail-label"
                           Text="Resource" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Classes="detail-value"
                           Foreground="#AEB9C5"
                           Text="{Binding SelectedDetailItem.ResourceText}" />
              </Grid>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <StackPanel Grid.Row="2"
                Margin="0,18,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="12">
      <Button Classes="dialog-action"
              Background="#20262D"
              BorderBrush="#39424E"
              Foreground="#F4F6F8"
              Click="CancelButton_OnClick"
              Content="Cancel" />
      <Button Classes="dialog-action"
              x:Name="PrimaryActionButton"
              Background="#355779"
              BorderBrush="#5A86B4"
              Foreground="#F4F6F8"
              Click="QueueSelectedButton_OnClick"
              Content="{Binding PrimaryActionLabel}" />
    </StackPanel>
  </Grid>
</Window>
