<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CKAN.LinuxGUI.TextInputWindow"
        x:CompileBindings="False"
        Width="420"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="{Binding Title}">
  <Window.Styles>
    <Style Selector="Button.dialog-action">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Background" Value="#24303B" />
      <Setter Property="BorderBrush" Value="#405061" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Foreground" Value="#F3F7FC" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Button.dialog-action:pointerover">
      <Setter Property="Background" Value="#2E3C49" />
      <Setter Property="BorderBrush" Value="#5B7084" />
    </Style>
    <Style Selector="Button.dialog-action:pressed">
      <Setter Property="Background" Value="#1D2730" />
      <Setter Property="BorderBrush" Value="#6A7F94" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto"
        Margin="20">
    <StackPanel Spacing="10">
      <TextBlock FontWeight="SemiBold"
                 Text="{Binding Prompt}" />
      <TextBox x:Name="InputTextBox"
               MinHeight="36"
               Text="{Binding Value, Mode=TwoWay}" />
    </StackPanel>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="12"
                Margin="0,20,0,0">
      <Button Classes="dialog-action"
              Click="CancelButton_OnClick"
              Content="Cancel" />
      <Button Classes="dialog-action"
              Background="#355779"
              BorderBrush="#5A86B4"
              Click="ConfirmButton_OnClick"
              Content="{Binding ConfirmLabel}" />
    </StackPanel>
  </Grid>
</Window>
