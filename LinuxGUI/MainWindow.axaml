      <Setter Property="Foreground" Value="#AFB8C6" />
    </Style>
    <Style Selector="TextBlock.row-status">
      <Setter Property="FontSize" Value="10" />
      <Setter Property="Foreground" Value="#AAB5C3" />
    </Style>
    <Style Selector="TextBlock.row-number">
