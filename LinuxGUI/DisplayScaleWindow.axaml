<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CKAN.LinuxGUI.DisplayScaleWindow"
        x:CompileBindings="False"
        Width="500"
        Height="380"
        MinWidth="440"
        MinHeight="340"
        WindowStartupLocation="CenterOwner"
        Title="Display Scale"
        Background="#171C22">
  <Window.Styles>
    <Style Selector="Button.dialog-action">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Background" Value="#24303B" />
      <Setter Property="BorderBrush" Value="#405061" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Foreground" Value="#F3F7FC" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Button.dialog-action:pointerover">
      <Setter Property="Background" Value="#2E3C49" />
      <Setter Property="BorderBrush" Value="#5B7084" />
    </Style>
    <Style Selector="Button.dialog-action:pressed">
      <Setter Property="Background" Value="#1D2730" />
      <Setter Property="BorderBrush" Value="#6A7F94" />
    </Style>
    <Style Selector="Button.dialog-action:disabled">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#303A44" />
      <Setter Property="Foreground" Value="#7B8794" />
      <Setter Property="Opacity" Value="1" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,*,Auto"
        Margin="20">
    <StackPanel Spacing="6">
      <TextBlock FontSize="22"
                 FontWeight="SemiBold"
                 Text="Display Scale" />
      <TextBlock FontSize="13"
                 Opacity="0.74"
                 TextWrapping="Wrap"
                 Text="{Binding DisplayScaleSummary}" />
    </StackPanel>

    <Grid Grid.Row="1"
          ColumnDefinitions="*,*"
          Margin="0,18,0,0">
      <Border Background="#161B21"
              BorderBrush="#2B323C"
              BorderThickness="1"
              CornerRadius="8"
              Padding="12">
        <StackPanel Spacing="5">
          <TextBlock FontSize="12"
                     Opacity="0.68"
                     Text="Current" />
          <TextBlock FontSize="20"
                     FontWeight="SemiBold"
                     Text="{Binding AppliedUiScalePercent, StringFormat={}{0}%}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="1"
              Margin="12,0,0,0"
              Background="#1B2530"
              BorderBrush="#3D5064"
              BorderThickness="1"
              CornerRadius="8"
              Padding="12">
        <StackPanel Spacing="5">
          <TextBlock FontSize="12"
                     Opacity="0.68"
                     Text="Next launch" />
          <TextBlock FontSize="20"
                     FontWeight="SemiBold"
                     Text="{Binding PendingUiScaleLabel}" />
        </StackPanel>
      </Border>
    </Grid>

    <StackPanel Grid.Row="2"
                Margin="0,18,0,0"
                Spacing="12">
      <Border Background="#161B21"
              BorderBrush="#2B323C"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16,14">
        <Grid RowDefinitions="Auto,Auto,Auto">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock FontSize="12"
                       Opacity="0.72"
                       Text="Smaller" />
            <TextBlock Grid.Column="1"
                       HorizontalAlignment="Center"
                       FontWeight="SemiBold"
                       Text="{Binding PendingUiScaleLabel}" />
            <TextBlock Grid.Column="2"
                       FontSize="12"
                       Opacity="0.72"
                       Text="Larger" />
          </Grid>

          <Slider Grid.Row="1"
                  Margin="0,12,0,0"
                  Minimum="{Binding UiScaleMinimum}"
                  Maximum="{Binding UiScaleMaximum}"
                  TickFrequency="5"
                  TickPlacement="None"
                  IsSnapToTickEnabled="True"
                  SmallChange="5"
                  LargeChange="5"
                  Value="{Binding PendingUiScalePercent}" />

          <Grid Grid.Row="2"
                Margin="0,12,0,0"
                ColumnDefinitions="Auto,*,Auto">
            <TextBlock FontSize="12"
                       Opacity="0.62"
                       Text="{Binding UiScaleMinimum, StringFormat={}{0}%}" />
            <TextBlock Grid.Column="1"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       Opacity="0.62"
                       Text="100%" />
            <TextBlock Grid.Column="2"
                       FontSize="12"
                       Opacity="0.62"
                       Text="{Binding UiScaleMaximum, StringFormat={}{0}%}" />
          </Grid>
        </Grid>
      </Border>

      <Border Background="#20262D"
              BorderBrush="#39424E"
              BorderThickness="1"
              CornerRadius="8"
              Padding="12">
        <TextBlock FontSize="12"
                   Opacity="0.78"
                   TextWrapping="Wrap"
                   Text="{Binding DisplayScaleHint}" />
      </Border>
    </StackPanel>

    <Grid Grid.Row="3"
          Margin="0,18,0,0"
          ColumnDefinitions="*,Auto">
      <Button Classes="dialog-action"
              HorizontalAlignment="Left"
              IsVisible="{Binding ShowResetUiScaleAction}"
              Background="#1F3D58"
              BorderBrush="#31597B"
              Foreground="#F4F6F8"
              Command="{Binding ResetUiScaleCommand}"
              Content="Reset to 100%" />
      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="12">
        <Button Classes="dialog-action"
                IsVisible="{Binding UiScaleNeedsRestart}"
                Background="#355779"
                BorderBrush="#5A86B4"
                Foreground="#F4F6F8"
                Command="{Binding RestartToApplyUiScaleCommand}"
                Content="Restart Now" />
        <Button Classes="dialog-action"
                Background="#20262D"
                BorderBrush="#39424E"
                Foreground="#F4F6F8"
                Click="CloseButton_OnClick"
                Content="Close" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
