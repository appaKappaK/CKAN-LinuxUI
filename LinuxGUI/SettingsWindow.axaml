<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="CKAN.LinuxGUI.SettingsWindow"
        x:CompileBindings="False"
        mc:Ignorable="d"
        Width="900"
        Height="700"
        MinWidth="860"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Title="Settings"
        Background="#20262D">
  <Window.Styles>
    <Style Selector="Border.settings-group">
      <Setter Property="BorderBrush" Value="#55606B" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10" />
    </Style>
    <Style Selector="TextBlock.settings-group-title">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="#F2F4F7" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>
    <Style Selector="TextBlock.settings-label">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="#F2F4F7" />
    </Style>
    <Style Selector="TextBlock.settings-muted">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="#D8DEE5" />
      <Setter Property="Opacity" Value="0.86" />
    </Style>
    <Style Selector="Button.settings-button">
      <Setter Property="Background" Value="#202B35" />
      <Setter Property="BorderBrush" Value="#3B4B5B" />
      <Setter Property="Foreground" Value="#F2F4F7" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="MinWidth" Value="84" />
      <Setter Property="Padding" Value="12,5" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Button.settings-button:pointerover">
      <Setter Property="Background" Value="#2A3744" />
      <Setter Property="BorderBrush" Value="#55697E" />
    </Style>
    <Style Selector="Button.settings-button:pressed">
      <Setter Property="Background" Value="#18212A" />
      <Setter Property="BorderBrush" Value="#667A90" />
    </Style>
    <Style Selector="Button.settings-button:disabled">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#303A44" />
      <Setter Property="Foreground" Value="#7B8794" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.settings-button.compact">
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBox.settings-textbox">
      <Setter Property="Background" Value="#16202A" />
      <Setter Property="BorderBrush" Value="#3D4E60" />
      <Setter Property="Foreground" Value="#E8EDF2" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="SelectionBrush" Value="#355779" />
      <Setter Property="CaretBrush" Value="#F4F6F8" />
    </Style>
    <Style Selector="TextBox.settings-textbox:pointerover">
      <Setter Property="Background" Value="#1B2631" />
      <Setter Property="BorderBrush" Value="#4B5D70" />
    </Style>
    <Style Selector="TextBox.settings-textbox:focus">
      <Setter Property="Background" Value="#1B2631" />
      <Setter Property="BorderBrush" Value="#61758B" />
    </Style>
    <Style Selector="ComboBox.settings-combo">
      <Setter Property="Background" Value="#16202A" />
      <Setter Property="Foreground" Value="#E8EDF2" />
      <Setter Property="BorderBrush" Value="#3D4E60" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="4,2" />
      <Setter Property="MinHeight" Value="28" />
    </Style>
    <Style Selector="ComboBox.settings-combo:pointerover">
      <Setter Property="Background" Value="#1B2631" />
      <Setter Property="BorderBrush" Value="#4B5D70" />
    </Style>
    <Style Selector="ComboBox.settings-combo:focus">
      <Setter Property="Background" Value="#1B2631" />
      <Setter Property="BorderBrush" Value="#61758B" />
    </Style>
    <Style Selector="ComboBox.settings-combo:dropdownopen">
      <Setter Property="Background" Value="#1B2631" />
      <Setter Property="BorderBrush" Value="#61758B" />
    </Style>
    <Style Selector="ComboBox.settings-combo ComboBoxItem">
      <Setter Property="Background" Value="#16202A" />
      <Setter Property="Foreground" Value="#E8EDF2" />
      <Setter Property="Padding" Value="8,5" />
    </Style>
    <Style Selector="ComboBox.settings-combo ComboBoxItem:pointerover">
      <Setter Property="Background" Value="#243140" />
    </Style>
    <Style Selector="ComboBox.settings-combo ComboBoxItem:selected">
      <Setter Property="Background" Value="#2C3A4A" />
      <Setter Property="Foreground" Value="#F4F7FA" />
    </Style>
    <Style Selector="ListBox.settings-list">
      <Setter Property="Background" Value="#16202A" />
      <Setter Property="BorderBrush" Value="#3D4E60" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinHeight" Value="0" />
    </Style>
    <Style Selector="ListBox.settings-list ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="ListBox.settings-list ListBoxItem:pointerover">
      <Setter Property="Background" Value="#1D2A36" />
    </Style>
    <Style Selector="ListBox.settings-list ListBoxItem:selected">
      <Setter Property="Background" Value="#1D2A36" />
      <Setter Property="Foreground" Value="#E8EDF2" />
    </Style>
    <Style Selector="ListBox.settings-list ListBoxItem:selected:pointerover">
      <Setter Property="Background" Value="#223241" />
      <Setter Property="Foreground" Value="#E8EDF2" />
    </Style>
    <Style Selector="CheckBox.settings-check">
      <Setter Property="Foreground" Value="#F2F4F7" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Margin" Value="0,0,0,7" />
    </Style>
    <Style Selector="TextBlock.card-error">
      <Setter Property="Foreground" Value="#FF6B6B" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </Window.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
  <Grid Margin="14">
    <Grid ColumnDefinitions="27*,25*,25*"
          RowDefinitions="164,230,Auto">
      <Border Classes="settings-group"
              Grid.ColumnSpan="2"
              Margin="0,0,14,14">
        <Grid RowDefinitions="Auto,*,Auto,Auto">
          <TextBlock Classes="settings-group-title"
                     Text="Metadata Repositories" />
          <Grid Grid.Row="1"
                RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="130,*"
                  Margin="0,0,0,4">
              <TextBlock Classes="settings-label"
                         Text="Name" />
              <TextBlock Grid.Column="1"
                         Classes="settings-label"
                         Text="URL" />
            </Grid>
            <ListBox Grid.Row="1"
                     Classes="settings-list"
                     ItemsSource="{Binding RepositoryRows}"
                     SelectedItem="{Binding SelectedRepositoryRow, Mode=TwoWay}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="130,*"
                        Margin="8,4">
                    <TextBlock Foreground="#E8EDF2"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding Name}" />
                    <TextBlock Grid.Column="1"
                               Foreground="#E8EDF2"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding Url}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
          <DockPanel Grid.Row="2"
                     Margin="0,8,0,0">
            <Button Classes="settings-button"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right"
                    IsEnabled="{Binding CanRemoveRepository}"
                    Click="RemoveRepositoryButton_OnClick"
                    Content="Remove" />
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <Button Classes="settings-button"
                      IsEnabled="{Binding CanAddRepository}"
                      Click="AddRepositoryButton_OnClick"
                      Content="Add" />
              <Button Classes="settings-button"
                      IsEnabled="{Binding CanMoveRepositoryUp}"
                      Click="MoveRepositoryUpButton_OnClick"
                      ToolTip.Tip="Move selected repository earlier in priority order"
                      Content="Move Up" />
              <Button Classes="settings-button"
                      IsEnabled="{Binding CanMoveRepositoryDown}"
                      Click="MoveRepositoryDownButton_OnClick"
                      ToolTip.Tip="Move selected repository later in priority order"
                      Content="Move Down" />
            </StackPanel>
          </DockPanel>
          <TextBlock Grid.Row="3"
                     Classes="card-error"
                     Margin="0,6,0,0"
                     IsVisible="{Binding ShowRepositoryStatus}"
                     Text="{Binding RepositoryStatusMessage}" />
        </Grid>
      </Border>

      <Border Grid.Column="2"
              Classes="settings-group"
              Margin="0,0,0,14">
        <Grid RowDefinitions="Auto,*,Auto,Auto">
          <TextBlock Classes="settings-group-title"
                     Text="Authentication Tokens" />
          <Grid Grid.Row="1"
                RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="110,*"
                  Margin="0,0,0,4">
              <TextBlock Classes="settings-label"
                         Text="Host" />
              <TextBlock Grid.Column="1"
                         Classes="settings-label"
                         Text="Token" />
            </Grid>
            <ListBox Grid.Row="1"
                     Classes="settings-list"
                     ItemsSource="{Binding AuthTokenRows}"
                     SelectedItem="{Binding SelectedAuthTokenRow, Mode=TwoWay}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="110,*"
                        Margin="8,4">
                    <TextBlock Foreground="#E8EDF2"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding Host}" />
                    <TextBlock Grid.Column="1"
                               Foreground="#E8EDF2"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding Token}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
          <DockPanel Grid.Row="2"
                     Margin="0,8,0,0">
            <Button Classes="settings-button"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right"
                    IsEnabled="{Binding CanRemoveAuthToken}"
                    Click="RemoveAuthTokenButton_OnClick"
                    Content="Delete" />
            <Button Classes="settings-button"
                    IsEnabled="{Binding CanAddAuthToken}"
                    Click="AddAuthTokenButton_OnClick"
                    Content="New" />
          </DockPanel>
          <TextBlock Grid.Row="3"
                     Classes="card-error"
                     Margin="0,6,0,0"
                     IsVisible="{Binding ShowAuthTokenStatus}"
                     Text="{Binding AuthTokenStatusMessage}" />
        </Grid>
      </Border>

      <Border Grid.Row="1"
              Classes="settings-group"
              Margin="0,0,14,14">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <TextBlock Classes="settings-group-title"
                     Text="Auto-Updates" />
          <Grid Grid.Row="1"
                ColumnDefinitions="105,*"
                RowDefinitions="Auto,Auto"
                Margin="0,2,0,10">
            <TextBlock Classes="settings-label"
                       Text="Local version:" />
            <TextBlock Grid.Column="1"
                       Classes="settings-muted"
                       Text="{Binding LocalVersion}" />
            <TextBlock Grid.Row="1"
                       Classes="settings-label"
                       Text="Latest version:" />
            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Classes="settings-muted"
                       Text="{Binding LatestVersion}" />
          </Grid>
          <CheckBox Grid.Row="2"
                    Classes="settings-check"
                    IsChecked="{Binding CheckForUpdatesOnLaunch}"
                    Content="Check for CKAN updates on launch" />
          <CheckBox Grid.Row="3"
                    Classes="settings-check"
                    IsChecked="{Binding UseDevBuilds}"
                    Content="Use dev builds" />
          <Grid Grid.Row="4"
                ColumnDefinitions="*,8,*"
                Margin="0,8,0,0">
            <Button Classes="settings-button compact"
                    HorizontalAlignment="Stretch"
                    Click="CheckForUpdatesButton_OnClick"
                    Content="Check for updates" />
            <Button Grid.Column="2"
                    Classes="settings-button compact"
                    HorizontalAlignment="Stretch"
                    IsEnabled="False"
                    Content="Install update" />
          </Grid>
        </Grid>
      </Border>

      <Border Grid.Row="1"
              Grid.Column="1"
              Grid.ColumnSpan="2"
              Classes="settings-group"
              Margin="0,0,0,14">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Classes="settings-group-title"
                     Text="Download Cache" />
          <Grid Grid.Row="1"
                ColumnDefinitions="*,Auto"
                Margin="0,2,0,8">
            <TextBox Classes="settings-textbox"
                     IsReadOnly="True"
                     Text="{Binding DownloadCachePath}" />
            <Button Grid.Column="1"
                    Classes="settings-button"
                    Margin="8,0,0,0"
                    Click="ChangeCachePathButton_OnClick"
                    Content="Browse" />
          </Grid>
          <TextBlock Grid.Row="2"
                     Classes="settings-muted"
                     Margin="0,0,0,8"
                     Text="{Binding DownloadCacheSummary}" />
          <Grid Grid.Row="3"
                ColumnDefinitions="140,64,*"
                Margin="0,0,0,10">
            <TextBlock Classes="settings-label"
                       VerticalAlignment="Center"
                       Text="Maximum cache size:" />
            <TextBox Grid.Column="1"
                     Classes="settings-textbox"
                     HorizontalAlignment="Stretch"
                     Text="{Binding CacheSizeLimitMiBText}" />
            <TextBlock Grid.Column="2"
                       Classes="settings-muted"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Text="MiB (empty for unlimited)" />
          </Grid>
          <StackPanel Grid.Row="4"
                      Orientation="Horizontal"
                      Spacing="10">
            <Button Classes="settings-button"
                    Click="ChangeCachePathButton_OnClick"
                    Content="Change..." />
            <Button Classes="settings-button"
                    Click="PurgeCacheButton_OnClick"
                    Content="Purge" />
            <Button Classes="settings-button"
                    IsEnabled="{Binding CanResetCachePath}"
                    Click="ResetCachePathButton_OnClick"
                    Content="Reset" />
            <Button Classes="settings-button"
                    Click="OpenCacheButton_OnClick"
                    Content="Open" />
          </StackPanel>
          <TextBlock Grid.Row="5"
                     Classes="card-error"
                     Margin="0,10,0,0"
                     IsVisible="{Binding ShowCacheError}"
                     Text="{Binding CacheErrorMessage}" />
        </Grid>
      </Border>

      <Border Grid.Row="2"
              Classes="settings-group"
              Margin="0,0,14,0">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <TextBlock Classes="settings-group-title"
                     Text="Behavior" />
          <CheckBox Grid.Row="1"
                    Classes="settings-check"
                    IsChecked="{Binding EnableTrayIcon}"
                    Content="Enable tray icon" />
          <CheckBox Grid.Row="2"
                    Classes="settings-check"
                    IsEnabled="{Binding EnableTrayIcon}"
                    IsChecked="{Binding MinimizeToTray}"
                    Content="Minimize to tray" />
          <Grid Grid.Row="3"
                ColumnDefinitions="140,52,*"
                Margin="0,8,0,8">
            <TextBlock Classes="settings-label"
                       VerticalAlignment="Center"
                       Text="Refresh modlist every" />
            <TextBox Grid.Column="1"
                     Classes="settings-textbox"
                     Text="{Binding RefreshRateText}" />
            <TextBlock Grid.Column="2"
                       Classes="settings-muted"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Text="minute(s)" />
          </Grid>
          <CheckBox Grid.Row="4"
                    Classes="settings-check"
                    IsEnabled="{Binding CanPauseRefresh}"
                    IsChecked="{Binding RefreshPaused}"
                    Content="Pause refreshing" />
        </Grid>
      </Border>

      <Border Grid.Row="2"
              Grid.Column="1"
              Grid.ColumnSpan="2"
              Classes="settings-group">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Classes="settings-group-title"
                     Text="More Settings" />
          <Grid Grid.Row="1"
                Margin="0,4,0,10"
                ColumnDefinitions="270,*">
            <TextBlock Classes="settings-label"
                       VerticalAlignment="Center"
                       Text="Language (requires restart):" />
            <ComboBox Grid.Column="1"
                      Classes="settings-combo"
                      ItemsSource="{Binding LanguageOptions}"
                      SelectedItem="{Binding SelectedLanguage}" />
          </Grid>
          <CheckBox Grid.Row="2"
                    Classes="settings-check"
                    IsChecked="{Binding RefreshOnStartup}"
                    Content="Update repositories on launch" />
          <CheckBox Grid.Row="3"
                    Classes="settings-check"
                    IsChecked="{Binding HideEpochs}"
                    Content="Hide epoch numbers in mod list (requires restart)" />
          <CheckBox Grid.Row="4"
                    Classes="settings-check"
                    IsChecked="{Binding HideV}"
                    Content="Hide &quot;v&quot; in mod list (requires restart)" />
          <CheckBox Grid.Row="5"
                    Classes="settings-check"
                    IsChecked="{Binding AutoSortByUpdate}"
                    Content="Automatically sort by &quot;Update&quot; column when clicking &quot;Add available updates&quot;" />
          <CheckBox Grid.Row="6"
                    Classes="settings-check"
                    IsChecked="{Binding PreselectRecommendedMods}"
                    Content="Preselect recommended mods when prompted" />
          <Grid Grid.Row="7"
                Margin="0,4,0,0"
                ColumnDefinitions="270,*">
            <TextBlock Classes="settings-label"
                       VerticalAlignment="Center"
                       Text="Stability tolerance:" />
            <ComboBox Grid.Column="1"
                      x:Name="StabilityToleranceComboBox"
                      Classes="settings-combo"
                      IsEnabled="{Binding CanEditStabilityTolerance}"
                      ItemsSource="{Binding StabilityToleranceOptions}"
                      SelectedItem="{Binding SelectedStabilityTolerance}" />
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
  </ScrollViewer>
</Window>
