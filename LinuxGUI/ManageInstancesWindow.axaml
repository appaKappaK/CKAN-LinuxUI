<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:CKAN.App.Models"
        x:Class="CKAN.LinuxGUI.ManageInstancesWindow"
        x:CompileBindings="False"
        Width="860"
        Height="500"
        MinWidth="760"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Title="Manage Game Instances"
        Background="#171C22">
  <Window.Styles>
    <Style Selector="Button.dialog-action">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Background" Value="#24303B" />
      <Setter Property="BorderBrush" Value="#405061" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Foreground" Value="#F3F7FC" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Button.dialog-action:pointerover">
      <Setter Property="Background" Value="#2E3C49" />
      <Setter Property="BorderBrush" Value="#5B7084" />
    </Style>
    <Style Selector="Button.dialog-action:pressed">
      <Setter Property="Background" Value="#1D2730" />
      <Setter Property="BorderBrush" Value="#6A7F94" />
    </Style>
    <Style Selector="Button.dialog-action:disabled">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#303A44" />
      <Setter Property="Foreground" Value="#7B8794" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="TextBlock.instance-column-header">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#AEB9C5" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto"
        Margin="20">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="5">
        <TextBlock FontSize="22"
                   FontWeight="SemiBold"
                   Text="Manage Game Instances" />
        <TextBlock FontSize="13"
                   Opacity="0.74"
                   Text="{Binding SummaryText}" />
      </StackPanel>
      <TextBlock Grid.Column="1"
                 VerticalAlignment="Top"
                 FontSize="12"
                 Opacity="0.72"
                 TextWrapping="Wrap"
                 MaxWidth="260"
                 Text="{Binding FooterText}" />
    </Grid>

    <Border Grid.Row="1"
            Margin="0,18,0,0"
            Background="#161B21"
            BorderBrush="#2B323C"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12">
      <Grid RowDefinitions="Auto,Auto,*">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock FontSize="14"
                     FontWeight="SemiBold"
                     Text="Registered Instances" />
          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="10">
            <Button Classes="dialog-action"
                    Click="AddInstanceButton_OnClick"
                    IsEnabled="{Binding CanManageInstances}"
                    Content="Add Instance" />
            <Button Classes="dialog-action"
                    Click="ImportSteamButton_OnClick"
                    IsEnabled="{Binding CanImportSteam}"
                    Content="Import Steam" />
          </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              Margin="10,14,18,6"
              ColumnDefinitions="2*,74,82,78,2.6*">
          <TextBlock Classes="instance-column-header"
                     Text="Name" />
          <TextBlock Grid.Column="1"
                     Classes="instance-column-header"
                     Text="Game" />
          <TextBlock Grid.Column="2"
                     Classes="instance-column-header"
                     Text="Version" />
          <TextBlock Grid.Column="3"
                     Classes="instance-column-header"
                     Text="Hours" />
          <TextBlock Grid.Column="4"
                     Classes="instance-column-header"
                     Text="Path" />
        </Grid>

        <ListBox x:Name="InstancesListBox"
                 Grid.Row="2"
                 Classes="utility-list"
                 ItemsSource="{Binding Instances}"
                 SelectedItem="{Binding SelectedInstance, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="models:InstanceSummary">
              <Border Classes="utility-list-row">
                <Grid ColumnDefinitions="2*,74,82,78,2.6*"
                      MinHeight="32">
                  <StackPanel Orientation="Horizontal"
                              Spacing="8"
                              VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding Name}" />
                    <TextBlock FontSize="11"
                               VerticalAlignment="Center"
                               Foreground="#AEB9C5"
                               Text="Current"
                               IsVisible="{Binding IsCurrent}" />
                    <TextBlock FontSize="11"
                               VerticalAlignment="Center"
                               Foreground="#AEB9C5"
                               Text="Default"
                               IsVisible="{Binding IsDefault}" />
                  </StackPanel>
                  <TextBlock Grid.Column="1"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis"
                             Text="{Binding GameName}" />
                  <TextBlock Grid.Column="2"
                             VerticalAlignment="Center"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis"
                             Text="{Binding VersionText}" />
                  <TextBlock Grid.Column="3"
                             VerticalAlignment="Center"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis"
                             Text="{Binding PlayTimeValue}" />
                  <TextBlock Grid.Column="4"
                             VerticalAlignment="Center"
                             Opacity="0.72"
                             TextTrimming="CharacterEllipsis"
                             Text="{Binding GameDir}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Grid Grid.Row="2"
          Margin="0,18,0,0"
          ColumnDefinitions="Auto,*,Auto">
      <CheckBox VerticalAlignment="Center"
                Content="Set as default"
                Click="SetDefaultCheckBox_OnClick"
                IsEnabled="{Binding CanSetDefault}"
                IsChecked="{Binding IsSelectedDefault, Mode=OneWay}" />

      <StackPanel Grid.Column="2"
                  Orientation="Horizontal"
                  Spacing="10">
        <Button Classes="dialog-action"
                Click="ForgetButton_OnClick"
                IsEnabled="{Binding CanForgetSelection}"
                Content="Forget" />
        <Button Classes="dialog-action"
                Click="RenameButton_OnClick"
                IsEnabled="{Binding CanRenameSelection}"
                Content="Rename" />
        <Button Classes="dialog-action"
                Background="#355779"
                BorderBrush="#5A86B4"
                Foreground="#F4F6F8"
                Click="UseSelectedButton_OnClick"
                IsEnabled="{Binding CanUseSelection}"
                Content="{Binding PrimaryActionText}" />
        <Button Classes="dialog-action"
                Background="#20262D"
                BorderBrush="#39424E"
                Foreground="#F4F6F8"
                Click="CloseButton_OnClick"
                Content="Close" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
