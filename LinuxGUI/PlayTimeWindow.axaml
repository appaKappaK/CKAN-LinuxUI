<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CKAN.LinuxGUI.PlayTimeWindow"
        x:CompileBindings="False"
        Width="760"
        Height="560"
        MinWidth="700"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Title="Play Time"
        Background="#171C22">
  <Window.Styles>
    <Style Selector="Button.dialog-action">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,*,Auto"
        Margin="20">
    <StackPanel Spacing="6">
      <TextBlock FontSize="22"
                 FontWeight="SemiBold"
                 Text="Play Time" />
      <TextBlock FontSize="13"
                 Opacity="0.74"
                 TextWrapping="Wrap"
                 Text="Edit the recorded play time for your registered installs. Values are saved in hours." />
    </StackPanel>

    <TextBlock Grid.Row="1"
               Margin="0,16,0,0"
               FontSize="13"
               Opacity="0.8"
               Text="{Binding TotalHoursLabel}" />

    <Border Grid.Row="2"
            Margin="0,16,0,0"
            Background="#161B21"
            BorderBrush="#2B323C"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12">
      <Grid RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="2.2*,1.4*,0.8*">
          <TextBlock FontWeight="SemiBold"
                     Text="Instance" />
          <TextBlock Grid.Column="1"
                     FontWeight="SemiBold"
                     Text="Path" />
          <TextBlock Grid.Column="2"
                     HorizontalAlignment="Right"
                     FontWeight="SemiBold"
                     Text="Hours" />
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Margin="0,12,0,0">
          <ItemsControl ItemsSource="{Binding Entries}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border BorderBrush="#242B33"
                        BorderThickness="0,0,0,1"
                        Padding="0,10">
                  <Grid ColumnDefinitions="2.2*,1.4*,0.8*">
                    <StackPanel Spacing="3">
                      <TextBlock FontWeight="SemiBold"
                                 Text="{Binding Name}" />
                      <TextBlock FontSize="12"
                                 Opacity="0.66"
                                 Text="{Binding GameName}" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Margin="12,0,12,0"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding GameDir}" />

                    <TextBox Grid.Column="2"
                             HorizontalContentAlignment="Right"
                             Text="{Binding HoursText, Mode=TwoWay}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <Grid Grid.Row="3"
          Margin="0,16,0,0"
          ColumnDefinitions="*,Auto">
      <TextBlock FontSize="12"
                 Foreground="#F06C6C"
                 VerticalAlignment="Center"
                 TextWrapping="Wrap"
                 Text="{Binding ValidationMessage}" />

      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="12">
        <Button Classes="dialog-action"
                Background="#20262D"
                BorderBrush="#39424E"
                Foreground="#F4F6F8"
                Click="CloseButton_OnClick"
                Content="Close" />
        <Button Classes="dialog-action"
                Background="#355779"
                BorderBrush="#5A86B4"
                Foreground="#F4F6F8"
                Click="SaveButton_OnClick"
                Content="Save" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
