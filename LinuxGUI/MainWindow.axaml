      <Setter Property="CornerRadius" Value="0,9,9,0" />
      <Setter Property="Foreground" Value="#F4F6F8" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ComboBox.header-instance-picker-segment:pointerover">
      <Setter Property="Background" Value="#263246" />
    </Style>
    <Style Selector="ComboBox.header-instance-picker-segment:focus">
      <Setter Property="Background" Value="#263246" />
    </Style>
    <Style Selector="ComboBox.header-instance-picker-segment:dropdownopen">
      <Setter Property="Background" Value="#263246" />
    </Style>
    <Style Selector="Button.header-instance-reload">
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="Background" Value="#212938" />
      <Setter Property="BorderBrush" Value="#394654" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Foreground" Value="#DCE4EC" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.header-instance-reload /template/ ContentPresenter">
      <Setter Property="Background" Value="#212938" />
      <Setter Property="BorderBrush" Value="#394654" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>
    <Style Selector="Button.header-instance-reload:pointerover">
      <Setter Property="Background" Value="#263246" />
      <Setter Property="BorderBrush" Value="#4A5B70" />
    </Style>
    <Style Selector="Button.header-instance-reload:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#263246" />
      <Setter Property="BorderBrush" Value="#4A5B70" />
    </Style>
    <Style Selector="TextBox.browser-search">
      <Setter Property="Background" Value="#16202A" />
      <Setter Property="BorderBrush" Value="#3D4E60" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Foreground" Value="#F4F6F8" />
      <Setter Property="SelectionBrush" Value="#355779" />
      <Setter Property="CaretBrush" Value="#F4F6F8" />
    </Style>
    <Style Selector="TextBox.browser-search:pointerover">
      <Setter Property="Background" Value="#1B2631" />
      <Setter Property="BorderBrush" Value="#4B5D70" />
    </Style>
    <Style Selector="TextBox.browser-search:focus">
      <Setter Property="Background" Value="#1B2631" />
      <Setter Property="BorderBrush" Value="#61758B" />
    </Style>
  </Window.Styles>
  <LayoutTransformControl HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">
    <LayoutTransformControl.LayoutTransform>
      <media:ScaleTransform ScaleX="{Binding AppliedUiScaleFactor}"
                            ScaleY="{Binding AppliedUiScaleFactor}" />
    </LayoutTransformControl.LayoutTransform>
  <Grid HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        RowDefinitions="Auto,Auto,*"
        Background="#171C22">
    <Border Background="#20262D"
            Padding="16,10"
            IsVisible="{Binding ShowLegacyHeader}">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto"
            VerticalAlignment="Center">
        <Menu Classes="app-menu-bar"
              VerticalAlignment="Center">
          <MenuItem Header="File">
            <MenuItem Classes="app-menu-item"
                      Header="Manage game instances"
                      Click="ManageGameInstancesMenuItem_OnClick" />
            <MenuItem Classes="app-menu-item"
                      Header="Open game directory"
                      Command="{Binding OpenCurrentGameDirectoryCommand}"
                      IsEnabled="{Binding HasCurrentInstance}" />
            <MenuItem Classes="app-menu-item"
                      Header="Play"
                      IsEnabled="{Binding HasCurrentInstance}">
              <MenuItem Classes="app-menu-item play-submenu-item"
                        Header="Via Steam"
                        Command="{Binding PlayViaSteamCommand}"
                        IsEnabled="{Binding CanPlayViaSteam}" />
              <MenuItem Classes="app-menu-item play-submenu-item"
                        Header="Direct launch"
                        Command="{Binding PlayDirectCommand}"
                        IsEnabled="{Binding CanPlayDirect}" />
              <MenuItem Classes="app-menu-item play-submenu-item"
                        Header="Game command lines"
                        Click="GameCommandLinesMenuItem_OnClick" />
            </MenuItem>
            <Separator />
            <MenuItem Classes="app-menu-item"
                      Header="Mods"
                      IsEnabled="{Binding HasCurrentInstance}">
              <MenuItem Classes="app-menu-item"
                        Header="Installation history"
                        Click="InstallationHistoryMenuItem_OnClick" />
              <MenuItem Classes="app-menu-item"
                        Header="Install from .ckan..."
                        Click="InstallFromCkanMenuItem_OnClick" />
              <MenuItem Classes="app-menu-item"
                        Header="Import downloaded mods..."
                        Click="ImportDownloadedModsMenuItem_OnClick" />
              <MenuItem Classes="app-menu-item"
                        Header="Deduplicate installed files..."
                        Click="DeduplicateInstalledFilesMenuItem_OnClick" />
              <Separator />
              <MenuItem Classes="app-menu-item"
                        Header="Save installed mod list (cannot be re-imported)..."
                        Click="ExportModListMenuItem_OnClick" />
              <MenuItem Classes="app-menu-item"
                        Header="Export modpack (can be re-imported)..."
                        Click="ExportModpackMenuItem_OnClick" />
              <Separator />
              <MenuItem Classes="app-menu-item"
                        Header="Audit recommendations"
                        Click="AuditRecommendationsMenuItem_OnClick" />
              <MenuItem Classes="app-menu-item"
                        Header="Unmanaged files"
                        Click="UnmanagedFilesMenuItem_OnClick" />
            </MenuItem>
            <Separator />
            <MenuItem Classes="app-menu-item"
                      Header="Download statistics"
                      Click="DownloadStatisticsMenuItem_OnClick"
                      IsEnabled="{Binding HasCurrentInstance}" />
            <MenuItem Classes="app-menu-item"
                      Header="Play time"
                      Click="PlayTimeMenuItem_OnClick" />
            <Separator />
            <MenuItem Classes="app-menu-item"
                      Header="Exit"
                      Click="ExitMenuItem_OnClick" />
          </MenuItem>
          <MenuItem Header="Settings">
            <MenuItem Classes="app-menu-item"
                      Header="CKAN settings"
                      Click="SettingsMenuItem_OnClick" />
            <!-- Display scale is hidden for now; keep the handler/view model code in place for easy restoration.
            <MenuItem Classes="app-menu-item"
                      Header="Display scale"
                      Click="DisplayScaleMenuItem_OnClick" />
            -->
            <MenuItem Classes="app-menu-item"
                      Header="Compatible game versions"
                      IsEnabled="{Binding HasCurrentInstance}"
                      Click="CompatibleGameVersionsMenuItem_OnClick" />
            <MenuItem Classes="app-menu-item"
                      Header="Game command lines"
                      IsEnabled="{Binding HasCurrentInstance}"
                      Click="GameCommandLinesMenuItem_OnClick" />
            <MenuItem Classes="app-menu-item"
                      Header="Plugins"
                      IsEnabled="{Binding HasCurrentInstance}"
                      Click="PluginsMenuItem_OnClick" />
            <MenuItem Classes="app-menu-item"
                      Header="Preferred hosts"
                      IsEnabled="{Binding HasCurrentInstance}"
                      Click="PreferredHostsMenuItem_OnClick" />
            <MenuItem Classes="app-menu-item"
                      Header="Installation filters"
                      IsEnabled="{Binding HasCurrentInstance}"
                      Click="InstallationFiltersMenuItem_OnClick" />
          </MenuItem>
          <MenuItem Header="Help">
            <MenuItem Classes="app-menu-item"
                      Header="CKAN user guide"
                      Command="{Binding OpenUserGuideCommand}" />
            <MenuItem Classes="app-menu-item"
                      Header="CKAN Discord"
                      Command="{Binding OpenDiscordCommand}" />
            <MenuItem Classes="app-menu-item"
                      Header="Get help for an in-game problem with mods"
                      Command="{Binding OpenGameSupportCommand}"
                      IsEnabled="{Binding HasCurrentInstance}" />
            <MenuItem Classes="app-menu-item"
                      Header="Report an issue with the CKAN client"
                      Command="{Binding ReportClientIssueCommand}" />
            <MenuItem Classes="app-menu-item"
                      Header="Report an issue with mod metadata"
                      Command="{Binding ReportMetadataIssueCommand}"
                      IsEnabled="{Binding HasCurrentInstance}" />
            <MenuItem Classes="app-menu-item"
                      Header="About"
                      Click="AboutMenuItem_OnClick" />
          </MenuItem>
        </Menu>

        <TextBlock Grid.Column="1"
                   HorizontalAlignment="Center"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Text="CKAN Linux" />

        <Border Grid.Column="2"
                Background="#11161C"
                CornerRadius="999"
                Padding="14,8"
                VerticalAlignment="Center"
                IsVisible="{Binding ShowHeaderStagePill}">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock Opacity="0.7"
                       Text="State" />
            <TextBlock FontWeight="SemiBold"
                       Text="{Binding StageTitle}" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            BorderBrush="#2F3741"
            BorderThickness="0,0,0,1"
            Padding="24,16"
            IsVisible="{Binding ShowLegacyHeader}">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <StackPanel Spacing="4">
          <TextBlock FontSize="12"
                     Opacity="0.7"
                     Text="Active Install" />
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="{Binding CurrentInstanceName}" />
          <TextBlock FontSize="12"
                     Opacity="0.72"
                     TextTrimming="CharacterEllipsis"
                     Text="{Binding CurrentInstanceContext}" />
          <TextBlock FontSize="12"
                     Opacity="0.58"
                     Text="{Binding InstanceCountLabel}" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Margin="16,0"
                    Width="280"
                    Spacing="6"
                    VerticalAlignment="Center">
          <ProgressBar Height="18"
                       Minimum="0"
                       Maximum="100"
                       Value="{Binding ProgressPercent}" />
          <TextBlock FontSize="12"
                     Opacity="0.7"
                     Text="{Binding StatusMessage}" />
        </StackPanel>

        <Button Grid.Column="2"
                Classes="command-button"
                Command="{Binding RefreshCommand}"
                Content="Reload Instances" />
      </Grid>
    </Border>

    <Border Grid.Row="0"
            Background="#1E252D"
            BorderBrush="#2F3741"
            BorderThickness="0,0,0,1"
            Padding="10,5"
            IsVisible="{Binding ShowReadyHeader}">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto"
            VerticalAlignment="Center">
          <Menu Classes="app-menu-bar ready-title-menu"
                IsEnabled="{Binding CanInteractWithCatalog}"
                VerticalAlignment="Center">
            <MenuItem>
              <MenuItem.Header>
                <Grid Classes="ready-menu-key"
                      RowDefinitions="Auto,*,Auto"
                      ColumnDefinitions="Auto,*,Auto">
                  <Border Grid.RowSpan="3"
                          Grid.ColumnSpan="3"
                          Classes="ready-menu-key-shell" />
                  <Border Grid.ColumnSpan="3"
                          Classes="ready-menu-key-top-edge" />
                  <Border Grid.Row="2"
                          Grid.ColumnSpan="3"
                          Classes="ready-menu-key-bottom-edge" />
                  <Border Grid.RowSpan="3"
                          Classes="ready-menu-key-left-edge" />
                  <Border Grid.RowSpan="3"
                          Grid.Column="2"
                          Classes="ready-menu-key-right-edge" />
                  <StackPanel Grid.Row="1"
                              Grid.ColumnSpan="3"
                              Classes="ready-menu-key-content">
                    <Viewbox Classes="ready-menu-globe"
                             Stretch="Uniform">
                      <Canvas Width="16"
                              Height="16">
                        <shapes:Ellipse Classes="ready-menu-icon-ring"
                                        Width="15"
                                        Height="6"
                                        Canvas.Left="0.5"
                                        Canvas.Top="5" />
                        <shapes:Ellipse Classes="ready-menu-icon-planet"
                                        Width="10"
                                        Height="10"
                                        Canvas.Left="3"
                                        Canvas.Top="3" />
                        <shapes:Ellipse Classes="ready-menu-icon-inner"
                                        Width="5"
                                        Height="10"
                                        Canvas.Left="5.5"
                                        Canvas.Top="3" />
                        <shapes:Line Classes="ready-menu-icon-inner"
                                     StartPoint="3,6"
                                     EndPoint="13,6" />
                        <shapes:Line Classes="ready-menu-icon-inner"
                                     StartPoint="3,10"
                                     EndPoint="13,10" />
                      </Canvas>
                    </Viewbox>
                    <TextBlock Classes="ready-menu-key-label"
                               Text="File" />
                  </StackPanel>
                </Grid>
              </MenuItem.Header>
              <MenuItem Classes="app-menu-item"
                        Header="Manage game instances"
                        Click="ManageGameInstancesMenuItem_OnClick" />
              <MenuItem Classes="app-menu-item"
                        Header="Open game directory"
                        Command="{Binding OpenCurrentGameDirectoryCommand}"
                        IsEnabled="{Binding HasCurrentInstance}" />
              <MenuItem Classes="app-menu-item"
                        Header="Play"
                        IsEnabled="{Binding HasCurrentInstance}">
                <MenuItem Classes="app-menu-item play-submenu-item"
                          Header="Via Steam"
                          Command="{Binding PlayViaSteamCommand}"
                          IsEnabled="{Binding CanPlayViaSteam}" />
                <MenuItem Classes="app-menu-item play-submenu-item"
                          Header="Direct launch"
                          Command="{Binding PlayDirectCommand}"
                          IsEnabled="{Binding CanPlayDirect}" />
                <MenuItem Classes="app-menu-item play-submenu-item"
                          Header="Game command lines"
                          Click="GameCommandLinesMenuItem_OnClick" />
              </MenuItem>
              <Separator />
              <MenuItem Classes="app-menu-item"
                        Header="Mods"
                        IsEnabled="{Binding HasCurrentInstance}">
                <MenuItem Classes="app-menu-item"
                          Header="Installation history"
                          Click="InstallationHistoryMenuItem_OnClick" />
                <MenuItem Classes="app-menu-item"
                          Header="Install from .ckan..."
                          Click="InstallFromCkanMenuItem_OnClick" />
                <MenuItem Classes="app-menu-item"
                          Header="Import downloaded mods..."
                          Click="ImportDownloadedModsMenuItem_OnClick" />
                <MenuItem Classes="app-menu-item"
                          Header="Deduplicate installed files..."
                          Click="DeduplicateInstalledFilesMenuItem_OnClick" />
                <Separator />
                <MenuItem Classes="app-menu-item"
                          Header="Save installed mod list (cannot be re-imported)..."
                          Click="ExportModListMenuItem_OnClick" />
                <MenuItem Classes="app-menu-item"
                          Header="Export modpack (can be re-imported)..."
                          Click="ExportModpackMenuItem_OnClick" />
                <Separator />
                <MenuItem Classes="app-menu-item"
                          Header="Audit recommendations"
                          Click="AuditRecommendationsMenuItem_OnClick" />
                <MenuItem Classes="app-menu-item"
                          Header="Unmanaged files"
                          Click="UnmanagedFilesMenuItem_OnClick" />
              </MenuItem>
              <Separator />
              <MenuItem Classes="app-menu-item"
                        Header="Download statistics"
                        Click="DownloadStatisticsMenuItem_OnClick"
                        IsEnabled="{Binding HasCurrentInstance}" />
              <MenuItem Classes="app-menu-item"
                        Header="Play time"
                        Click="PlayTimeMenuItem_OnClick" />
              <Separator />
              <MenuItem Classes="app-menu-item"
                        Header="Exit"
                        Click="ExitMenuItem_OnClick" />
            </MenuItem>
            <MenuItem>
              <MenuItem.Header>
                <Grid Classes="ready-menu-key"
                      RowDefinitions="Auto,*,Auto"
                      ColumnDefinitions="Auto,*,Auto">
                  <Border Grid.RowSpan="3"
                          Grid.ColumnSpan="3"
                          Classes="ready-menu-key-shell" />
                  <Border Grid.ColumnSpan="3"
                          Classes="ready-menu-key-top-edge" />
                  <Border Grid.Row="2"
                          Grid.ColumnSpan="3"
                          Classes="ready-menu-key-bottom-edge" />
                  <Border Grid.RowSpan="3"
                          Classes="ready-menu-key-left-edge" />
                  <Border Grid.RowSpan="3"
                          Grid.Column="2"
                          Classes="ready-menu-key-right-edge" />
                  <StackPanel Grid.Row="1"
                              Grid.ColumnSpan="3"
                              Classes="ready-menu-key-content">
                    <Viewbox Classes="ready-menu-globe"
                             Stretch="Uniform">
                      <Canvas Width="16"
                              Height="16">
                        <shapes:Ellipse Classes="ready-menu-icon-ring"
                                        Width="15"
                                        Height="6"
                                        Canvas.Left="0.5"
                                        Canvas.Top="5" />
                        <shapes:Ellipse Classes="ready-menu-icon-planet"
                                        Width="10"
                                        Height="10"
                                        Canvas.Left="3"
                                        Canvas.Top="3" />
                        <shapes:Ellipse Classes="ready-menu-icon-inner"
                                        Width="5"
                                        Height="10"
                                        Canvas.Left="5.5"
                                        Canvas.Top="3" />
                        <shapes:Line Classes="ready-menu-icon-inner"
                                     StartPoint="3,6"
                                     EndPoint="13,6" />
                        <shapes:Line Classes="ready-menu-icon-inner"
                                     StartPoint="3,10"
                                     EndPoint="13,10" />
                      </Canvas>
                    </Viewbox>
                    <TextBlock Classes="ready-menu-key-label"
                               Text="Settings" />
                  </StackPanel>
                </Grid>
              </MenuItem.Header>
              <MenuItem Classes="app-menu-item"
                        Header="CKAN settings"
                        Click="SettingsMenuItem_OnClick" />
              <!-- Display scale is hidden for now; keep the handler/view model code in place for easy restoration.
              <MenuItem Classes="app-menu-item"
                        Header="Display scale"
                        Click="DisplayScaleMenuItem_OnClick" />
              -->
              <MenuItem Classes="app-menu-item"
                        Header="Compatible game versions"
                        IsEnabled="{Binding HasCurrentInstance}"
                        Click="CompatibleGameVersionsMenuItem_OnClick" />
              <MenuItem Classes="app-menu-item"
                        Header="Game command lines"
                        IsEnabled="{Binding HasCurrentInstance}"
                        Click="GameCommandLinesMenuItem_OnClick" />
              <MenuItem Classes="app-menu-item"
                        Header="Plugins"
                        IsEnabled="{Binding HasCurrentInstance}"
                        Click="PluginsMenuItem_OnClick" />
              <MenuItem Classes="app-menu-item"
                        Header="Preferred hosts"
                        IsEnabled="{Binding HasCurrentInstance}"
                        Click="PreferredHostsMenuItem_OnClick" />
              <MenuItem Classes="app-menu-item"
                        Header="Installation filters"
                        IsEnabled="{Binding HasCurrentInstance}"
                        Click="InstallationFiltersMenuItem_OnClick" />
            </MenuItem>
            <MenuItem>
              <MenuItem.Header>
                <Grid Classes="ready-menu-key"
                      RowDefinitions="Auto,*,Auto"
                      ColumnDefinitions="Auto,*,Auto">
                  <Border Grid.RowSpan="3"
                          Grid.ColumnSpan="3"
                          Classes="ready-menu-key-shell" />
                  <Border Grid.ColumnSpan="3"
                          Classes="ready-menu-key-top-edge" />
                  <Border Grid.Row="2"
                          Grid.ColumnSpan="3"
                          Classes="ready-menu-key-bottom-edge" />
                  <Border Grid.RowSpan="3"
                          Classes="ready-menu-key-left-edge" />
                  <Border Grid.RowSpan="3"
                          Grid.Column="2"
                          Classes="ready-menu-key-right-edge" />
                  <StackPanel Grid.Row="1"
                              Grid.ColumnSpan="3"
                              Classes="ready-menu-key-content">
                    <Viewbox Classes="ready-menu-globe"
                             Stretch="Uniform">
                      <Canvas Width="16"
                              Height="16">
                        <shapes:Ellipse Classes="ready-menu-icon-ring"
                                        Width="15"
                                        Height="6"
                                        Canvas.Left="0.5"
                                        Canvas.Top="5" />
                        <shapes:Ellipse Classes="ready-menu-icon-planet"
                                        Width="10"
                                        Height="10"
                                        Canvas.Left="3"
                                        Canvas.Top="3" />
                        <shapes:Ellipse Classes="ready-menu-icon-inner"
                                        Width="5"
                                        Height="10"
                                        Canvas.Left="5.5"
                                        Canvas.Top="3" />
                        <shapes:Line Classes="ready-menu-icon-inner"
                                     StartPoint="3,6"
                                     EndPoint="13,6" />
                        <shapes:Line Classes="ready-menu-icon-inner"
                                     StartPoint="3,10"
                                     EndPoint="13,10" />
                      </Canvas>
                    </Viewbox>
                    <TextBlock Classes="ready-menu-key-label"
                               Text="Help" />
                  </StackPanel>
                </Grid>
              </MenuItem.Header>
              <MenuItem Classes="app-menu-item"
                        Header="CKAN user guide"
                        Command="{Binding OpenUserGuideCommand}" />
              <MenuItem Classes="app-menu-item"
                        Header="CKAN Discord"
                        Command="{Binding OpenDiscordCommand}" />
              <MenuItem Classes="app-menu-item"
                        Header="Get help for an in-game problem with mods"
                        Command="{Binding OpenGameSupportCommand}"
                        IsEnabled="{Binding HasCurrentInstance}" />
              <MenuItem Classes="app-menu-item"
                        Header="Report an issue with the CKAN client"
                        Command="{Binding ReportClientIssueCommand}" />
              <MenuItem Classes="app-menu-item"
                        Header="Report an issue with mod metadata"
                        Command="{Binding ReportMetadataIssueCommand}"
                        IsEnabled="{Binding HasCurrentInstance}" />
              <MenuItem Classes="app-menu-item"
                        Header="About"
                        Click="AboutMenuItem_OnClick" />
            </MenuItem>
          </Menu>

          <StackPanel Grid.Column="2"
                      Orientation="Horizontal"
                      Spacing="8"
                      Margin="16,0,38,0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center">
            <Button Classes="header-instance-reload"
                    IsEnabled="{Binding CanInteractWithCatalog}"
                    Command="{Binding RefreshCommand}"
                    Content="Reload" />

            <Border Background="#212938"
                    BorderBrush="#394654"
                    BorderThickness="1"
                    CornerRadius="10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">
              <Grid ColumnDefinitions="Auto,Auto">
                <Border Background="#212938"
                        BorderBrush="#394654"
                        BorderThickness="0,0,1,0"
                        CornerRadius="9,0,0,9"
                        MinHeight="30"
                        Padding="12,0">
                  <TextBlock FontSize="11.5"
                             FontWeight="SemiBold"
                             Foreground="#AFBBC8"
                             HorizontalAlignment="Center"
                             TextAlignment="Center"
                             VerticalAlignment="Center"
                             Text="Instance:" />
                </Border>

                <Border Grid.Column="1"
                        Background="#171F2A"
                        CornerRadius="0,9,9,0"
                        MinHeight="30"
                        Padding="12,0"
                        MinWidth="220"
                        MaxWidth="320"
                        VerticalAlignment="Center"
                        IsVisible="{Binding ShowPassiveHeaderInstanceLabel}">
                  <TextBlock FontSize="15"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Stretch"
                             TextWrapping="NoWrap"
                             VerticalAlignment="Center"
                             TextAlignment="Center"
                             TextTrimming="CharacterEllipsis"
                             Text="{Binding CurrentInstanceName}" />
                </Border>

                <ComboBox Grid.Column="1"
                          Classes="header-instance-picker header-instance-picker-segment"
                          MinWidth="220"
                          MaxWidth="320"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowHeaderInstanceSwitcher}"
                          IsEnabled="{Binding CanSwitchInstances}"
                          ItemsSource="{Binding Instances}"
                          SelectedItem="{Binding SelectedInstance}"
                          SelectionChanged="HeaderInstanceSwitcher_OnSelectionChanged">
                  <ComboBox.SelectionBoxItemTemplate>
                    <DataTemplate DataType="models:InstanceSummary">
                      <Grid ColumnDefinitions="24,*,0">
                        <TextBlock Grid.Column="1"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Stretch"
                                   TextWrapping="NoWrap"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding Name}" />
                      </Grid>
                    </DataTemplate>
                  </ComboBox.SelectionBoxItemTemplate>
                  <ComboBox.ItemTemplate>
                    <DataTemplate DataType="models:InstanceSummary">
                      <TextBlock FontSize="15"
                                 FontWeight="SemiBold"
                                 TextWrapping="NoWrap"
                                 TextTrimming="CharacterEllipsis"
                                 Text="{Binding Name}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </Grid>
            </Border>
          </StackPanel>

          <Border Grid.Column="3"
                  Background="{Binding StatusSurfaceBackground}"
                  BorderBrush="{Binding StatusSurfaceBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="10,6"
                  Width="210"
                  Margin="14,0,38,0"
                  IsVisible="{Binding ShowReadyStatusSurface}"
                  VerticalAlignment="Center">
            <Grid ColumnDefinitions="72,*"
                  VerticalAlignment="Center">
              <ProgressBar Width="56"
                           Height="3"
                           VerticalAlignment="Center"
                           Minimum="0"
                           Maximum="100"
                           Value="{Binding ProgressPercent}" />
              <TextBlock Grid.Column="1"
                         FontSize="11.5"
                         Opacity="0.74"
                         TextTrimming="CharacterEllipsis"
                         MaxLines="1"
                         Text="{Binding StatusMessage}" />
            </Grid>
          </Border>
        </Grid>
    </Border>

    <Border Grid.Row="0"
            ZIndex="10"
            Classes="surface-view-logo-bed"
            IsVisible="{Binding ShowReadyHeader}">
      <Image Classes="surface-view-logo-badge"
             Source="avares://CKAN-LinuxGUI/Assets/ckan-256.png" />
    </Border>

    <Border Grid.Row="0"
            x:Name="SurfaceViewToggle"
            ZIndex="20"
            Classes="surface-view-toggle"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            IsVisible="{Binding ShowReadyHeader}">
      <Border Classes="surface-view-toggle-panel"
              Classes.compact="{Binding SurfaceViewToggleCompact}">
        <Grid>
          <Border Classes="surface-view-toggle-rim" />
          <Grid ColumnDefinitions="*,*"
                Margin="8,0"
                VerticalAlignment="Center">
            <Button Classes="surface-view-tab"
                    Classes.active="{Binding ShowBrowseSurface}"
                    Command="{Binding ShowBrowseSurfaceCommand}"
                    IsEnabled="{Binding CanInteractWithCatalog}"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch">
              <Grid RowDefinitions="Auto,*,Auto">
                <Border Grid.RowSpan="3"
                        Classes="surface-view-tab-shell" />
                <Border Grid.RowSpan="3"
                        Classes="surface-view-tab-left-edge" />
                <Border Grid.RowSpan="3"
                        Classes="surface-view-tab-right-edge" />
                <Border Classes="surface-view-tab-top-edge" />
                <StackPanel Grid.Row="1"
                            Classes="surface-view-tab-content">
                  <TextBlock Classes="surface-view-label"
                             Text="Browse" />
                  <Border Classes="surface-view-indicator" />
                </StackPanel>
                <Border Grid.Row="2"
                        Classes="surface-view-tab-bottom-edge" />
              </Grid>
            </Button>
            <Button Classes="surface-view-tab"
                    Classes.active="{Binding ShowPreviewSurface}"
                    Command="{Binding ShowPreviewSurfaceCommand}"
                    IsEnabled="{Binding CanInteractWithCatalog}"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch">
              <Grid RowDefinitions="Auto,*,Auto">
                <Border Grid.RowSpan="3"
                        Classes="surface-view-tab-shell" />
                <Border Grid.RowSpan="3"
                        Classes="surface-view-tab-left-edge" />
                <Border Grid.RowSpan="3"
                        Classes="surface-view-tab-right-edge" />
                <Border Classes="surface-view-tab-top-edge" />
                <StackPanel Grid.Row="1"
                            Classes="surface-view-tab-content">
                  <TextBlock Classes="surface-view-label"
                             Text="{Binding PreviewSurfaceButtonLabel}" />
                  <Border Classes="surface-view-indicator" />
                </StackPanel>
                <Border Grid.Row="2"
                        Classes="surface-view-tab-bottom-edge" />
              </Grid>
            </Button>
          </Grid>
        </Grid>
      </Border>
    </Border>

    <Grid Grid.Row="2"
          ColumnDefinitions="Auto,*"
          Margin="12"
          MinHeight="0">
      <Border Background="#161B21"
              BorderBrush="#2B323C"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16"
              Margin="0"
              Width="{Binding LegacySidebarWidth}"
              IsVisible="{Binding ShowLegacyShell}">
        <Grid RowDefinitions="*,Auto">
          <Grid Grid.Row="0">
            <Grid RowDefinitions="Auto,Auto,*,Auto"
                  IsVisible="{Binding ShowStartupInstancePanel}">
              <TextBlock FontSize="18"
                         FontWeight="SemiBold"
                         Text="Your KSP Installs" />

              <TextBlock Grid.Row="1"
                         Margin="0,8,0,0"
                         FontSize="12"
                         Opacity="0.7"
                         Text="{Binding SelectedActionHint}" />

              <ListBox Grid.Row="2"
                       Margin="0,16,0,16"
                       ItemsSource="{Binding Instances}"
                       SelectedItem="{Binding SelectedInstance}">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="models:InstanceSummary">
                    <Border Padding="10"
                            Margin="0,0,0,8"
                            Background="#1D242C"
                            CornerRadius="8">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                          <TextBlock FontWeight="SemiBold"
                                     Text="{Binding Name}" />
                          <TextBlock FontSize="12"
                                     Opacity="0.75"
                                     Text="{Binding GameName}" />
                          <TextBlock FontSize="12"
                                     Opacity="0.75"
                                     Text="{Binding GameDir}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#2A6B4A"
                                CornerRadius="999"
                                Padding="10,4"
                                VerticalAlignment="Top"
                                IsVisible="{Binding IsCurrent}">
                          <TextBlock FontSize="11"
                                     FontWeight="SemiBold"
                                     Text="Current" />
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Button Grid.Row="3"
                      Classes="command-button primary"
                      Command="{Binding SetCurrentInstanceCommand}"
                      Content="{Binding SelectedActionLabel}" />
            </Grid>

            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
                  IsVisible="{Binding ShowReadyInstancePanel}">
              <TextBlock FontSize="18"
                         FontWeight="SemiBold"
                         Text="Switch Install" />

              <TextBlock Grid.Row="1"
                         Margin="0,8,0,0"
                         FontSize="12"
                         Opacity="0.72"
                         TextWrapping="Wrap"
                         Text="{Binding ReadyInstanceHint}" />

              <Border Grid.Row="2"
                      Background="#20262D"
                      CornerRadius="10"
                      Padding="14"
                      Margin="0,14,0,0"
                      IsVisible="{Binding ShowSwitchSelectedInstanceAction}">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="3">
                      <TextBlock FontSize="11"
                                 Opacity="0.68"
                                 Text="{Binding SelectedInstanceContextTitle}" />
                      <TextBlock FontWeight="SemiBold"
                                 Text="{Binding SelectedInstanceNameLabel}" />
                      <TextBlock FontSize="12"
                                 Opacity="0.74"
                                 Text="{Binding SelectedInstanceGameNameLabel}" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Background="#2A6B4A"
                            CornerRadius="999"
                            Padding="10,4"
                            VerticalAlignment="Top"
                            IsVisible="{Binding SelectedInstanceIsCurrent}">
                      <TextBlock FontSize="11"
                                 FontWeight="SemiBold"
                                 Text="Current" />
                    </Border>
                  </Grid>

                  <TextBlock FontSize="12"
                             Opacity="0.74"
                             TextWrapping="Wrap"
                             Text="{Binding SelectedInstanceGameDirLabel}" />
                </StackPanel>
              </Border>

              <ListBox Grid.Row="3"
                       Margin="0,14,0,0"
                       MaxHeight="260"
                       IsEnabled="{Binding CanSwitchInstances}"
                       ItemsSource="{Binding Instances}"
                       SelectedItem="{Binding SelectedInstance}">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="models:InstanceSummary">
                    <Border Padding="10"
                            Margin="0,0,0,8"
                            Background="#1D242C"
                            CornerRadius="8">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="3">
                          <TextBlock FontWeight="SemiBold"
                                     Text="{Binding Name}" />
                          <TextBlock FontSize="12"
                                     Opacity="0.75"
                                     Text="{Binding GameName}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#2A6B4A"
                                CornerRadius="999"
                                Padding="10,4"
                                VerticalAlignment="Center"
                                IsVisible="{Binding IsCurrent}">
                          <TextBlock FontSize="11"
                                     FontWeight="SemiBold"
                                     Text="Current" />
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <StackPanel Grid.Row="4"
                          Margin="0,14,0,0"
                          Spacing="8">
                <TextBlock FontSize="12"
                           Opacity="0.72"
                           IsVisible="{Binding SelectedInstanceIsCurrent}"
                           Text="You are already browsing this install." />
                <Button Classes="command-button primary"
                        IsVisible="{Binding ShowSwitchSelectedInstanceAction}"
                        Command="{Binding SetCurrentInstanceCommand}"
                        Content="Switch Install" />
              </StackPanel>
            </Grid>
          </Grid>

          <!-- Display scale is hidden for now; keep the markup commented for easy restoration.
          <Border Grid.Row="1"
                  Background="#20262D"
                  CornerRadius="10"
                  Padding="14"
                  Margin="0,16,0,0">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                  <TextBlock FontSize="15"
                             FontWeight="SemiBold"
                             Text="Display Scale" />
                  <TextBlock FontSize="12"
                             Opacity="0.72"
                             TextWrapping="Wrap"
                             Text="{Binding DisplayScaleSummary}" />
                </StackPanel>
                <Button Grid.Column="1"
                        Classes="command-button subtle"
                        VerticalAlignment="Top"
                        Command="{Binding ToggleDisplaySettingsCommand}"
                        Content="{Binding DisplaySettingsToggleLabel}" />
              </Grid>

              <StackPanel IsVisible="{Binding ShowDisplaySettings}"
                          Spacing="10">
                <Slider Minimum="{Binding UiScaleMinimum}"
                        Maximum="{Binding UiScaleMaximum}"
                        TickFrequency="5"
                        TickPlacement="Outside"
                        IsSnapToTickEnabled="True"
                        SmallChange="5"
                        LargeChange="5"
                        Value="{Binding PendingUiScalePercent}" />

                <Grid ColumnDefinitions="Auto,*,Auto">
                  <TextBlock FontSize="12"
                             Opacity="0.68"
                             Text="{Binding UiScaleMinimum}" />
                  <TextBlock Grid.Column="1"
                             HorizontalAlignment="Center"
                             FontWeight="SemiBold"
                             Text="{Binding PendingUiScaleLabel}" />
                  <TextBlock Grid.Column="2"
                             FontSize="12"
                             Opacity="0.68"
                             Text="{Binding UiScaleMaximum}" />
                </Grid>

                <TextBlock FontSize="12"
                           Opacity="0.72"
                           TextWrapping="Wrap"
                           Text="{Binding DisplayScaleHint}" />

                <WrapPanel>
                  <Button Classes="toolbar-chip"
                          IsVisible="{Binding ShowResetUiScaleAction}"
                          Command="{Binding ResetUiScaleCommand}"
                          Content="Reset to 100%" />
                  <Button Classes="toolbar-chip"
                          IsVisible="{Binding UiScaleNeedsRestart}"
                          Command="{Binding RestartToApplyUiScaleCommand}"
                          Content="Restart to Apply" />
                </WrapPanel>
              </StackPanel>
            </StackPanel>
          </Border>
          -->
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Background="Transparent"
              BorderBrush="Transparent"
              BorderThickness="0"
              CornerRadius="0"
              Padding="0"
              Margin="0"
              MinHeight="0">
        <Grid MinHeight="0">
          <Border Background="#202930"
                  CornerRadius="12"
                  Padding="16"
                  IsVisible="{Binding IsLoading}">
            <StackPanel Spacing="14"
                        VerticalAlignment="Center">
              <TextBlock FontSize="24"
                         FontWeight="SemiBold"
                         Text="{Binding StageTitle}" />
              <TextBlock Opacity="0.8"
                         TextWrapping="Wrap"
                         Text="{Binding StageDescription}" />
              <ProgressBar Height="20"
                           Minimum="0"
                           Maximum="100"
                           Value="{Binding ProgressPercent}" />
              <TextBlock FontSize="13"
                         Opacity="0.8"
                         Text="{Binding StatusMessage}" />
            </StackPanel>
          </Border>

          <Border Background="#202930"
                  CornerRadius="12"
                  Padding="16"
                  IsVisible="{Binding IsEmpty}">
            <StackPanel Spacing="16">
              <TextBlock FontSize="24"
                         FontWeight="SemiBold"
                         Text="{Binding StageTitle}" />
              <TextBlock TextWrapping="Wrap"
                         Opacity="0.85"
                         Text="{Binding StageDescription}" />
              <Border Background="#161B21"
                      CornerRadius="10"
                      Padding="16">
                <TextBlock TextWrapping="Wrap"
                           Text="Register a KSP install, then reload to open the mod browser." />
              </Border>
              <Button Width="170"
                      Classes="command-button primary"
                      HorizontalAlignment="Left"
                      Command="{Binding RefreshCommand}"
                      Content="Scan Again" />
            </StackPanel>
          </Border>

          <Border Background="#202930"
                  CornerRadius="12"
                  Padding="16"
                  IsVisible="{Binding NeedsSelection}">
            <StackPanel Spacing="18">
              <TextBlock FontSize="24"
                         FontWeight="SemiBold"
                         Text="{Binding StageTitle}" />
              <TextBlock TextWrapping="Wrap"
                         Opacity="0.85"
                         Text="{Binding StageDescription}" />
              <Border Background="#161B21"
                      CornerRadius="10"
                      Padding="16">
                <StackPanel Spacing="10">
                  <TextBlock FontSize="12"
                             Opacity="0.7"
                             Text="Selected Install" />
                  <TextBlock TextWrapping="Wrap"
                             Text="{Binding SelectedInstanceSummary}" />
                </StackPanel>
              </Border>
              <Button Width="230"
                      Classes="command-button primary"
                      HorizontalAlignment="Left"
                      Command="{Binding SetCurrentInstanceCommand}"
                      Content="{Binding SelectedActionLabel}" />
            </StackPanel>
          </Border>

          <Border Background="#202930"
                  CornerRadius="12"
                  Padding="12"
                  IsHitTestVisible="{Binding CanUseCatalogPanel}"
                  IsVisible="{Binding IsReady}"
                  MinHeight="0">
            <Grid RowDefinitions="Auto,*"
                  MinHeight="0">
              <!-- Display scale restart strip is hidden with the display scale controls.
              <Border Background="#4A3920"
                      BorderBrush="#9A7B37"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="14"
                      Margin="0,0,0,14"
                      IsVisible="{Binding ShowUiScaleRestartStrip}">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <TextBlock VerticalAlignment="Center"
                             FontSize="12"
                             Opacity="0.86"
                             Text="{Binding UiScaleRestartStripText}" />
                  <Button Grid.Column="1"
                          Classes="command-button primary"
                          Margin="10,0,0,0"
                          Command="{Binding RestartToApplyUiScaleCommand}"
                          Content="Restart Now" />
                  <Button Grid.Column="2"
                          Classes="command-button subtle"
                          Margin="10,0,0,0"
                          Command="{Binding DismissUiScaleRestartStripCommand}"
                          Content="Dismiss" />
                </Grid>
              </Border>
              -->

              <Grid Grid.Row="1"
                    ColumnDefinitions="*,Auto"
                    IsVisible="{Binding ShowBrowseSurface}"
                    MinHeight="0">
                <Border Background="#161B21"
                        CornerRadius="10"
                        Padding="10"
                        Margin="0,0,6,0"
                        MinHeight="0">
                  <Grid RowDefinitions="Auto,*"
                        MinHeight="0">
                    <Grid ColumnDefinitions="*,Auto,Auto"
                          Margin="0,0,0,8">
                      <TextBox x:Name="SearchTextBox"
                               Classes="browser-search"
                               MinHeight="34"
                               Padding="12,6"
                               IsEnabled="{Binding CanInteractWithCatalog}"
                               IsReadOnly="{Binding IsCatalogLoading}"
                               Watermark="Search by mod name, author, or description"
                               Text="{Binding ModSearchText}" />
                      <Border Grid.Column="1"
                              Classes="browser-chip"
                              Background="#20262D"
                              Margin="8,0,0,0"
                              MinWidth="84"
                              Padding="14,0"
                              VerticalAlignment="Center">
                        <TextBlock FontSize="12"
                                   HorizontalAlignment="Center"
                                   Opacity="0.8"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="{Binding ModCountLabel}" />
                      </Border>
                      <Button Grid.Column="2"
                              x:Name="MoreFiltersButton"
                              Classes="browser-chip"
                              Margin="8,0,0,0"
                              MinWidth="112"
                              IsEnabled="{Binding CanInteractWithCatalog}"
                              Background="{Binding MoreFiltersButtonBackground}"
                              BorderBrush="{Binding MoreFiltersButtonBorderBrush}"
                              Foreground="#F4F6F8"
                              Command="{Binding ToggleAdvancedFiltersCommand}"
                              HorizontalAlignment="Right"
                              Content="{Binding MoreFiltersLabel}" />

                      <Popup x:Name="AdvancedFiltersPopup"
                             IsOpen="{Binding ShowAdvancedFilters, Mode=TwoWay}"
                             Placement="BottomEdgeAlignedRight"
                             PlacementTarget="{Binding #MoreFiltersButton}"
                             VerticalOffset="6"
                             IsLightDismissEnabled="True"
                             OverlayDismissEventPassThrough="True"
                             OverlayInputPassThroughElement="{Binding #MoreFiltersButton}">
                        <Border Background="#20262D"
                                BorderBrush="#39424E"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Width="{Binding FiltersPopupWidth}"
                                MaxHeight="620"
                                x:CompileBindings="False"
                                BoxShadow="0 18 36 0 #66000000">
                          <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,*">
                              <StackPanel Spacing="8">
                                <TextBlock Classes="filter-drawer-label"
                                           Text="State" />
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterCompatibleOnly, Mode=TwoWay}">
                                  <TextBlock Foreground="#F4F6F8"
                                             Text="{Binding CompatibleFilterLabel}" />
                                </ToggleButton>
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterInstalledOnly, Mode=TwoWay}">
                                  <TextBlock Foreground="#F4F6F8"
                                             Text="{Binding InstalledFilterLabel}" />
                                </ToggleButton>
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterUpdatableOnly, Mode=TwoWay}">
                                  <TextBlock Foreground="#F4F6F8"
                                             Text="{Binding UpdatableFilterLabel}" />
                                </ToggleButton>
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterHasReplacementOnly, Mode=TwoWay}">
                                  <TextBlock Foreground="#F4F6F8"
                                             Text="{Binding ReplaceableFilterLabel}" />
                                </ToggleButton>
                              </StackPanel>
                              <StackPanel Grid.Column="1"
                                          Margin="12,0,0,0"
                                          Spacing="8">
                                <TextBlock Classes="filter-drawer-label"
                                           Text="Availability" />
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterCachedOnly, Mode=TwoWay}">
                                  <TextBlock Foreground="#F4F6F8"
                                             Text="{Binding CachedFilterLabel}" />
                                </ToggleButton>
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterUncachedOnly, Mode=TwoWay}">
                                  <TextBlock Foreground="#F4F6F8"
                                             Text="{Binding UncachedFilterLabel}" />
                                </ToggleButton>
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterNotInstalledOnly, Mode=TwoWay}">
                                  <TextBlock Foreground="#F4F6F8"
                                             Text="{Binding NotInstalledFilterLabel}" />
                                </ToggleButton>
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterIncompatibleOnly, Mode=TwoWay}">
                                  <TextBlock Foreground="#F4F6F8"
                                             Text="{Binding IncompatibleFilterLabel}" />
                                </ToggleButton>
                              </StackPanel>
                            </Grid>
                            <Button Classes="filter-menu-item"
                                    Background="{Binding AllFilterButtonBackground}"
                                    BorderBrush="{Binding AllFilterButtonBorderBrush}"
                                    HorizontalContentAlignment="Center"
                                    Command="{Binding ClearPopupFiltersCommand}">
                              <TextBlock Foreground="#F4F6F8"
                                         TextAlignment="Center"
                                         Text="{Binding AllFilterLabel}" />
                            </Button>
                            <Border Background="#1A2027"
                                    BorderBrush="#333D49"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12"
                                    IsVisible="{Binding HasAvailableTagOptions}">
                              <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Classes="filter-drawer-label"
                                             VerticalAlignment="Center"
                                             Text="Tags" />
                                  <Button Grid.Column="1"
                                          Classes="detail-section-action"
                                          IsVisible="{Binding HasSelectedTagFilter}"
                                          Command="{Binding ClearTagFilterCommand}"
                                          Content="Clear" />
                                </Grid>
                                <ScrollViewer MaxHeight="160"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                  <ItemsControl ItemsSource="{Binding AvailableTagOptions}">
                                    <ItemsControl.ItemsPanel>
                                      <ItemsPanelTemplate>
                                        <WrapPanel />
                                      </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:FilterTagOptionItem">
                                        <Button Classes="category-filter-chip"
                                                Background="{Binding BackgroundBrush}"
                                                BorderBrush="{Binding BorderBrush}"
                                                Command="{Binding #MainWindowRoot.DataContext.SelectTagFilterCommand}"
                                                CommandParameter="{Binding .}">
                                          <StackPanel Orientation="Horizontal"
                                                      Spacing="6">
                                            <TextBlock FontSize="11.5"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding NameForeground}"
                                                       Text="{Binding Name}" />
                                            <TextBlock FontSize="11"
                                                       Foreground="{Binding CountForeground}"
                                                       Text="{Binding CountLabel}" />
                                          </StackPanel>
                                        </Button>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </ScrollViewer>
                              </StackPanel>
                            </Border>
                          </StackPanel>
                        </Border>
                      </Popup>
                    </Grid>

                    <Border Grid.Row="1"
                            Background="#14191F"
                            CornerRadius="8"
                            BorderBrush="#2B323C"
                            BorderThickness="1"
                            Padding="8"
                            ClipToBounds="True">
                      <Grid ClipToBounds="True">
                        <ItemsControl ItemsSource="{Binding CatalogSkeletonRows}"
                                      IsVisible="{Binding ShowCatalogSkeleton}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CatalogSkeletonRow"
                                          x:CompileBindings="False">
                              <Border Background="#1B2128"
                                      CornerRadius="8"
                                      Padding="12"
                                      Margin="0,0,0,2"
                                      Opacity="{Binding Opacity}">
                                <Grid>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="{Binding #MainWindowRoot.DataContext.BrowserMetadataColumnGridLength}" />
                                  </Grid.ColumnDefinitions>
                                  <Border Background="{Binding AccentBrush}"
                                          CornerRadius="8,0,0,8" />
                                  <StackPanel Grid.Column="1"
                                              Margin="12,0,12,0"
                                              VerticalAlignment="Center"
                                              Spacing="7">
                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                      <Grid Grid.Column="0"
                                            ColumnDefinitions="Auto,*">
                                        <Border Background="#2A323C"
                                                CornerRadius="6"
                                                Height="15"
                                                Width="{Binding TitleWidth}"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center" />
                                        <Border Grid.Column="1"
                                                Background="#242B34"
                                                CornerRadius="6"
                                                Height="11"
                                                Width="{Binding AuthorWidth}"
                                                Margin="8,0,0,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding HasAuthor}" />
                                      </Grid>
                                      <StackPanel Grid.Column="1"
                                                  Margin="8,0,0,0"
                                                  Orientation="Horizontal"
                                                  HorizontalAlignment="Right">
                                        <Border Background="{Binding PrimaryBadgeBackground}"
                                                CornerRadius="999"
                                                Height="16"
                                                Width="{Binding PrimaryBadgeWidth}"
                                                Margin="0,0,6,0"
                                                IsVisible="{Binding HasPrimaryBadge}" />
                                        <Border Background="#39424E"
                                                BorderBrush="#607286"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                Height="16"
                                                Width="52"
                                                Margin="0,0,6,0"
                                                IsVisible="{Binding HasCachedBadge}" />
                                        <Border Background="{Binding SecondaryBadgeBackground}"
                                                BorderBrush="{Binding SecondaryBadgeBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                Height="16"
                                                Width="{Binding SecondaryBadgeWidth}"
                                                Margin="0,0,6,0"
                                                IsVisible="{Binding HasSecondaryBadge}" />
                                        <Border Background="{Binding TertiaryBadgeBackground}"
                                                BorderBrush="{Binding TertiaryBadgeBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                Height="16"
                                                Width="{Binding TertiaryBadgeWidth}"
                                                Margin="0,0,6,0"
                                                IsVisible="{Binding HasTertiaryBadge}" />
                                      </StackPanel>
                                      <Border Grid.Column="2"
                                              Margin="8,0,0,0"
                                              Background="{Binding QueueBadgeBackground}"
                                              BorderBrush="{Binding QueueBadgeBorderBrush}"
                                              BorderThickness="1"
                                              CornerRadius="999"
                                              Height="16"
                                              Width="{Binding QueueBadgeWidth}"
                                              VerticalAlignment="Center"
                                              IsVisible="{Binding HasQueueBadge}" />
                                    </Grid>
                                    <Border Background="#242B34"
                                            CornerRadius="6"
                                            Height="11"
                                            Width="{Binding SummaryWidth}"
                                            HorizontalAlignment="Left" />
                                  </StackPanel>
                                  <Grid Grid.Column="2"
                                        VerticalAlignment="Top"
                                        Margin="0,1,0,0">
                                    <Grid.ColumnDefinitions>
                                      <ColumnDefinition Width="{Binding #MainWindowRoot.DataContext.BrowserDownloadsColumnGridLength}" />
                                      <ColumnDefinition Width="{Binding #MainWindowRoot.DataContext.BrowserReleasedColumnGridLength}" />
                                      <ColumnDefinition Width="{Binding #MainWindowRoot.DataContext.BrowserInstalledColumnGridLength}" />
                                      <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#2A323C"
                                            CornerRadius="6"
                                            Height="13"
                                            Width="{Binding DownloadsWidth}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top" />
                                    <Border Grid.Column="1"
                                            Margin="10,0,0,0"
                                            Background="#2A323C"
                                            CornerRadius="6"
                                            Height="13"
                                            Width="{Binding ReleaseWidth}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top" />
                                    <Border Grid.Column="2"
                                            Margin="10,0,0,0"
                                            Background="#2A323C"
                                            CornerRadius="6"
                                            Height="13"
                                            Width="{Binding ReleaseWidth}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top" />
                                    <StackPanel Grid.Column="3"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Top"
                                                Spacing="4">
                                      <Border Background="#2A323C"
                                              CornerRadius="6"
                                              Height="13"
                                              Width="{Binding VersionPrimaryWidth}"
                                              HorizontalAlignment="Left" />
                                      <Border Background="#242B34"
                                              CornerRadius="6"
                                              Height="11"
                                              Width="{Binding VersionSecondaryWidth}"
                                              HorizontalAlignment="Left" />
                                    </StackPanel>
                                  </Grid>
                                </Grid>
                              </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>

                        <Grid RowDefinitions="Auto,Auto,*"
                              IsEnabled="{Binding CanInteractWithCatalog}"
                              IsVisible="{Binding ShowModList}"
                              MinHeight="0">
                          <Border Background="#1A2530"
                                  BorderBrush="#31516C"
                                  BorderThickness="1"
                                  CornerRadius="8"
                                  Padding="10,6"
                                  Margin="0,0,16,8"
                                  IsVisible="{Binding ShowRelationshipBrowserScope}">
                            <Grid ColumnDefinitions="*,Auto">
                              <TextBlock FontSize="12"
                                         Foreground="#DDEAF8"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center"
                                         Text="{Binding RelationshipBrowserScopeText}" />
                              <Button Grid.Column="1"
                                      Classes="detail-section-action"
                                      Margin="10,0,0,0"
                                      Command="{Binding ClearRelationshipBrowserScopeCommand}"
                                      Content="Clear" />
                            </Grid>
                          </Border>

                          <Grid Grid.Row="1"
                                Margin="0,0,16,4">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="4" />
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="{Binding BrowserMetadataColumnGridLength}" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="1"
                                    Classes="column-sort-header"
                                    Command="{Binding SelectNameSortCommand}"
                                    Content="{Binding NameSortLabel}" />
                            <Border Grid.Column="1"
                                    Classes="browser-column-resize-handle"
                                    Tag="Metadata"
                                    PointerPressed="BrowserColumnResizeHandle_OnPointerPressed"
                                    PointerMoved="BrowserColumnResizeHandle_OnPointerMoved"
                                    PointerReleased="BrowserColumnResizeHandle_OnPointerReleased">
                              <Border Classes="browser-column-resize-line" />
                            </Border>
                            <Border Grid.Column="2"
                                    BorderBrush="#2E3842"
                                    BorderThickness="1,0,0,0"
                                    Padding="10,0,0,0">
                              <Grid>
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="{Binding BrowserDownloadsColumnGridLength}" />
                                  <ColumnDefinition Width="{Binding BrowserReleasedColumnGridLength}" />
                                  <ColumnDefinition Width="{Binding BrowserInstalledColumnGridLength}" />
                                  <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Classes="column-sort-header"
                                        Command="{Binding SelectPopularitySortCommand}"
                                        Content="{Binding PopularitySortLabel}" />
                                <Border Grid.Column="0"
                                        Classes="browser-column-resize-handle"
                                        Tag="Downloads"
                                        PointerPressed="BrowserColumnResizeHandle_OnPointerPressed"
                                        PointerMoved="BrowserColumnResizeHandle_OnPointerMoved"
                                        PointerReleased="BrowserColumnResizeHandle_OnPointerReleased">
                                  <Border Classes="browser-column-resize-line" />
                                </Border>
                                <Border Grid.Column="1"
                                        BorderBrush="#24303B"
                                        BorderThickness="1,0,0,0"
                                        Padding="10,0,0,0">
                                  <Button Classes="column-sort-header"
                                          Command="{Binding SelectReleaseDateSortCommand}"
                                          Content="{Binding ReleaseDateSortLabel}" />
                                </Border>
                                <Border Grid.Column="1"
                                        Classes="browser-column-resize-handle"
                                        Tag="Released"
                                        PointerPressed="BrowserColumnResizeHandle_OnPointerPressed"
                                        PointerMoved="BrowserColumnResizeHandle_OnPointerMoved"
                                        PointerReleased="BrowserColumnResizeHandle_OnPointerReleased">
                                  <Border Classes="browser-column-resize-line" />
                                </Border>
                                <Border Grid.Column="2"
                                        BorderBrush="#24303B"
                                        BorderThickness="1,0,0,0"
                                        Padding="10,0,0,0">
                                  <Button Classes="column-sort-header"
                                          Command="{Binding SelectInstallDateSortCommand}"
                                          Content="{Binding InstallDateSortLabel}" />
                                </Border>
                                <Border Grid.Column="2"
                                        Classes="browser-column-resize-handle"
                                        Tag="Installed"
                                        PointerPressed="BrowserColumnResizeHandle_OnPointerPressed"
                                        PointerMoved="BrowserColumnResizeHandle_OnPointerMoved"
                                        PointerReleased="BrowserColumnResizeHandle_OnPointerReleased">
                                  <Border Classes="browser-column-resize-line" />
                                </Border>
                                <Border Grid.Column="3"
                                        BorderBrush="#24303B"
                                        BorderThickness="1,0,0,0"
                                        Padding="10,0,0,0">
                                  <Button Classes="column-sort-header"
                                          Command="{Binding SelectVersionSortCommand}"
                                          Content="{Binding VersionSortLabel}" />
                                </Border>
                              </Grid>
                            </Border>
                          </Grid>

                          <ListBox x:Name="ModsListBox"
                                   Grid.Row="2"
                                   MinHeight="0"
                                   ItemsSource="{Binding Mods}"
                                   AutoScrollToSelectedItem="False"
                                   PointerPressed="ModsListBox_OnPointerPressed"
                                   SelectedItem="{Binding SelectedMod}">
                            <ListBox.ItemTemplate>
                              <DataTemplate DataType="models:ModListItem"
                                            x:CompileBindings="False">
                                <Border Background="#181D23"
                                        CornerRadius="5"
                                        Margin="0,0,0,1"
                                        Padding="0"
                                        PointerPressed="ModRow_OnPointerPressed">
                                  <Grid>
                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="{Binding #MainWindowRoot.DataContext.BrowserMetadataColumnGridLength}" />
                                      </Grid.ColumnDefinitions>
                                      <Border Background="{Binding PrimaryStateColor}"
                                              CornerRadius="5,0,0,5" />

                                      <Border Grid.Column="1"
                                              Padding="8,4">
                                        <StackPanel Spacing="3">
                                          <Grid ColumnDefinitions="*,Auto,Auto">
                                            <Grid Grid.Column="0"
                                                  ColumnDefinitions="Auto,*">
                                              <TextBlock Classes="row-title"
                                                         VerticalAlignment="Center"
                                                         TextTrimming="CharacterEllipsis"
                                                         Text="{Binding Name}" />
                                              <TextBlock Grid.Column="1"
                                                         Classes="row-meta"
                                                         Margin="8,0,0,0"
                                                         VerticalAlignment="Center"
                                                         TextTrimming="CharacterEllipsis"
                                                         Text="{Binding Author, StringFormat=By: {0}}" />
                                            </Grid>

                                            <StackPanel Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                              <Border Background="{Binding PrimaryStateColor}"
                                                      CornerRadius="999"
                                                      Padding="6,1"
                                                      Margin="0,0,6,0">
                                                <TextBlock FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#F7FAFD"
                                                           Text="{Binding PrimaryStateLabel}" />
                                              </Border>
                                              <Border Background="#39424E"
                                                      BorderBrush="#607286"
                                                      BorderThickness="1"
                                                      CornerRadius="999"
                                                      Padding="6,1"
                                                      Margin="0,0,6,0"
                                                      IsVisible="{Binding IsCached}">
                                                <TextBlock FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#EFF4F9"
                                                           Text="Cached" />
                                              </Border>
                                              <Border Background="{Binding SecondaryStateBackground}"
                                                      BorderBrush="{Binding SecondaryStateBorderBrush}"
                                                      BorderThickness="1"
                                                      CornerRadius="999"
                                                      Padding="6,1"
                                                      Margin="0,0,6,0"
                                                      IsVisible="{Binding HasSecondaryState}">
                                                <TextBlock FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFF7E8"
                                                           Text="{Binding SecondaryStateLabel}" />
                                              </Border>
                                              <Border Background="{Binding TertiaryStateBackground}"
                                                      BorderBrush="{Binding TertiaryStateBorderBrush}"
                                                      BorderThickness="1"
                                                      CornerRadius="999"
                                                      Padding="6,1"
                                                      Margin="0,0,6,0"
                                                      IsVisible="{Binding HasTertiaryState}">
                                                <TextBlock FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#EAF4FF"
                                                           Text="{Binding TertiaryStateLabel}" />
                                              </Border>
                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    Margin="8,0,0,0"
                                                    Background="{Binding QueueStateBackground}"
                                                    BorderBrush="{Binding QueueStateBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="999"
                                                    Padding="5,1"
                                                    VerticalAlignment="Center"
                                                    IsVisible="{Binding HasQueueState}">
                                              <TextBlock FontSize="9.5"
                                                         FontWeight="SemiBold"
                                                         Foreground="#E6EDF3"
                                                         Text="{Binding QueueStateLabel}" />
                                            </Border>
                                          </Grid>

                                          <TextBlock Classes="row-summary"
                                                     TextWrapping="Wrap"
                                                     MaxLines="1"
                                                     TextTrimming="CharacterEllipsis"
                                                     Text="{Binding Summary}" />
                                        </StackPanel>
                                      </Border>

                                      <Border Grid.Column="2"
                                              BorderBrush="#2E3842"
                                              BorderThickness="1,0,0,0"
                                              Padding="10,4,0,4">
                                        <Grid>
                                          <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="{Binding #MainWindowRoot.DataContext.BrowserDownloadsColumnGridLength}" />
                                            <ColumnDefinition Width="{Binding #MainWindowRoot.DataContext.BrowserReleasedColumnGridLength}" />
                                            <ColumnDefinition Width="{Binding #MainWindowRoot.DataContext.BrowserInstalledColumnGridLength}" />
                                            <ColumnDefinition Width="*" />
                                          </Grid.ColumnDefinitions>
                                          <TextBlock Classes="row-number"
                                                     HorizontalAlignment="Left"
                                                     VerticalAlignment="Top"
                                                     Text="{Binding DownloadCountLabel}" />

                                          <Border Grid.Column="1"
                                                  BorderBrush="#24303B"
                                                  BorderThickness="1,0,0,0"
                                                  Padding="10,0,0,0">
                                            <TextBlock Classes="row-number"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Top"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding ReleaseDate}" />
                                          </Border>

                                          <Border Grid.Column="2"
                                                  BorderBrush="#24303B"
                                                  BorderThickness="1,0,0,0"
                                                  Padding="10,0,0,0">
                                            <TextBlock Classes="row-number"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Top"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding InstallDate}" />
                                          </Border>

                                          <Border Grid.Column="3"
                                                  BorderBrush="#24303B"
                                                  BorderThickness="1,0,0,0"
                                                  Padding="10,0,0,0">
                                            <StackPanel Spacing="1">
                                              <TextBlock Classes="row-version-primary"
                                                         HorizontalAlignment="Left"
                                                         TextTrimming="CharacterEllipsis"
                                                         Text="{Binding LatestVersion}" />
                                              <TextBlock Classes="row-version-secondary"
                                                         TextTrimming="CharacterEllipsis"
                                                         IsVisible="{Binding ShowInstalledVersionInList}"
                                                         Text="{Binding InstalledVersion}" />
                                            </StackPanel>
                                          </Border>
                                        </Grid>
                                      </Border>
                                    </Grid>

                                    <Border BorderBrush="{Binding QueueRowAccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            IsHitTestVisible="False"
                                            IsVisible="{Binding HasQueueState}" />
                                    <Border Classes="mod-row-status-tint"
                                            Background="{Binding PrimaryStateColor}" />
                                    <Border Classes="mod-row-status-outline"
                                            BorderBrush="{Binding PrimaryStateColor}" />
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ListBox.ItemTemplate>
                          </ListBox>
                        </Grid>

                        <Border Background="#20262D"
                                CornerRadius="10"
                                Padding="18"
                                IsVisible="{Binding ShowEmptyModResults}">
                          <StackPanel Spacing="8"
                                      VerticalAlignment="Center">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="No mods match the current search and filters." />
                            <TextBlock Opacity="0.82"
                                       TextWrapping="Wrap"
                                       Text="Broaden the query or clear the active filters to restore the catalog list." />
                            <Button Width="140"
                                    Classes="command-button"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ClearFiltersCommand}"
                                    Content="Clear Filters" />
                          </StackPanel>
                        </Border>
                      </Grid>
                    </Border>

                  </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="#14191F"
                        BorderBrush="#2B323C"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="8,0,0,0"
                        Width="292"
                        MinWidth="272"
                        MinHeight="0"
                        IsHitTestVisible="{Binding CanInteractWithCatalog}"
                        ClipToBounds="True"
                        IsVisible="{Binding ShowDetailsSidebar}">
                  <Grid MinHeight="0"
                        RowDefinitions="*">
                    <StackPanel Spacing="12"
                                IsVisible="{Binding ShowSelectedModPlaceholder}">
                      <TextBlock FontSize="16"
                                 FontWeight="SemiBold"
                                 Text="No mod selected" />
                      <TextBlock Opacity="0.8"
                                 TextWrapping="Wrap"
                                 Text="Choose a mod from the browser to inspect install state, compatibility, and package metadata." />
                    </StackPanel>

                    <StackPanel Spacing="14"
                                IsVisible="{Binding ShowSelectedModLoadingState}">
                      <TextBlock FontSize="16"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap"
                                 Text="{Binding SelectedModLoadingTitle}" />
                      <Border Background="#26303A"
                              CornerRadius="5"
                              Height="14"
                              Width="170"
                              HorizontalAlignment="Left" />
                      <Border Background="#20262D"
                              Height="1"
                              Margin="0,2" />
                      <Grid ColumnDefinitions="Auto,*"
                            RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                        <TextBlock FontSize="12"
                                   Opacity="0.68"
                                   Text="Version" />
                        <Border Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="132"
                                Margin="12,0,0,0"
                                HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="1"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   Opacity="0.68"
                                   Text="Status" />
                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="164"
                                Margin="12,10,0,0"
                                HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="2"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   Opacity="0.68"
                                   Text="License" />
                        <Border Grid.Row="2"
                                Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="120"
                                Margin="12,10,0,0"
                                HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="3"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   Opacity="0.68"
                                   Text="Type" />
                        <Border Grid.Row="3"
                                Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="108"
                                Margin="12,10,0,0"
                                HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="4"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   Opacity="0.68"
                                   Text="Released" />
                        <Border Grid.Row="4"
                                Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="144"
                                Margin="12,10,0,0"
                                HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="5"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   Opacity="0.68"
                                   Text="Download" />
                        <Border Grid.Row="5"
                                Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="126"
                                Margin="12,10,0,0"
                                HorizontalAlignment="Left" />
                      </Grid>
                      <Border Background="#20262D"
                              Height="1"
                              Margin="0,2" />
                      <Border Background="#242B34"
                              CornerRadius="5"
                              Height="11"
                              Width="240"
                              HorizontalAlignment="Left" />
                      <Border Background="#242B34"
                              CornerRadius="5"
                              Height="11"
                              Width="220"
                              HorizontalAlignment="Left" />
                      <Border Background="#242B34"
                              CornerRadius="5"
                              Height="11"
                              Width="232"
                              HorizontalAlignment="Left" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="0"
                                  x:Name="DetailsScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  VerticalAlignment="Stretch"
                                  MinHeight="0"
                                  IsVisible="{Binding ShowSelectedModContent}">
                      <StackPanel Spacing="10"
                                  Margin="0,0,8,0">
                        <TextBlock Classes="panel-title"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedModTitle}" />
                        <TextBlock Classes="panel-meta"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedModAuthors}" />
                        <TextBlock Classes="panel-body"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedModBody}" />

                        <StackPanel Spacing="6">
                          <WrapPanel IsVisible="{Binding ShowSelectedModStateBadges}">
                            <Border Background="#2B6A98"
                                    BorderBrush="#4A88B5"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="7,2"
                                    Margin="0,0,6,0"
                                    IsVisible="{Binding SelectedModIsInstalled}">
                              <TextBlock FontSize="11"
                                         FontWeight="SemiBold"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         TextAlignment="Center"
                                         Foreground="#F7FAFD"
                                         Text="Installed" />
                            </Border>
                            <Border Background="#39424E"
                                    BorderBrush="#607286"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="7,2"
                                    Margin="0,0,6,0"
                                    IsVisible="{Binding SelectedModIsCached}">
                              <TextBlock FontSize="11"
                                         FontWeight="SemiBold"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         TextAlignment="Center"
                                         Foreground="#EFF4F9"
                                         Text="Cached" />
                            </Border>
                            <Border Background="#6A952B"
                                    BorderBrush="#82AF3D"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="7,2"
                                    Margin="0,0,6,0"
                                    IsVisible="{Binding SelectedModHasUpdate}">
                              <TextBlock FontSize="11"
                                         FontWeight="SemiBold"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         TextAlignment="Center"
                                         Foreground="#F7FAFD"
                                         Text="Update available" />
                            </Border>
                            <Border Background="#5A4322"
                                    BorderBrush="#9F7A40"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="7,2"
                                    Margin="0,0,6,0"
                                    IsVisible="{Binding SelectedModIsAutodetected}">
                              <TextBlock FontSize="11"
                                         FontWeight="SemiBold"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         TextAlignment="Center"
                                         Foreground="#FFF7E8"
                                         Text="External" />
                            </Border>
                            <Border Background="#9A485C"
                                    BorderBrush="#B35D73"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="7,2"
                                    Margin="0,0,6,0"
                                    IsVisible="{Binding SelectedModShowsIncompatibleState}">
                              <TextBlock FontSize="11"
                                         FontWeight="SemiBold"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         TextAlignment="Center"
                                         Foreground="#FFF6F8"
                                         Text="Incompatible" />
                            </Border>
                            <Border Background="#31424F"
                                    BorderBrush="#4C6A86"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="7,2"
                                    Margin="0,0,6,0"
                                    IsVisible="{Binding SelectedModShowsDependencyState}">
                              <TextBlock FontSize="11"
                                         FontWeight="SemiBold"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         TextAlignment="Center"
                                         Foreground="#EAF4FF"
                                         Text="Dependency" />
                            </Border>
                            <Border Background="#734790"
                                    BorderBrush="#8B5FA8"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="7,2"
                                    Margin="0,0,6,0"
                                    IsVisible="{Binding SelectedModHasReplacement}">
                              <TextBlock FontSize="11"
                                         FontWeight="SemiBold"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         TextAlignment="Center"
                                         Foreground="#FBF6FF"
                                         Text="Has replacement" />
                            </Border>
                          </WrapPanel>

                          <WrapPanel IsVisible="{Binding ShowSelectedModActionRow}">
                            <Button Classes="command-button primary"
                                    HorizontalAlignment="Left"
                                    MinHeight="32"
                                    Margin="0,0,10,6"
                                    Padding="10,6"
                                    CornerRadius="7"
                                    Background="{Binding PrimarySelectedModActionBackground}"
                                    BorderBrush="{Binding PrimarySelectedModActionBorderBrush}"
                                    Foreground="#F7FAFD"
                                    IsVisible="{Binding ShowPrimarySelectedModAction}"
                                    Command="{Binding PrimarySelectedModActionCommand}"
                                    Content="{Binding PrimarySelectedModActionLabel}" />
                          </WrapPanel>

                          <Border Background="#3B2B1B"
                                  BorderBrush="#8C6432"
                                  BorderThickness="1"
                                  CornerRadius="8"
                                  Padding="10,8"
                                  IsVisible="{Binding ShowSelectedModActionUnavailableNote}">
                            <TextBlock FontSize="12"
                                       Foreground="#F2E5CF"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModActionUnavailableNote}" />
                          </Border>
                        </StackPanel>

                        <StackPanel Spacing="6">
                          <Border Background="#20262D"
                                  Height="1" />
                          <StackPanel Spacing="0">
                            <StackPanel Spacing="4"
                                        Margin="0,0,0,8"
                                        IsVisible="{Binding ShowSelectedModVersionPicker}">
                                <TextBlock Classes="detail-label"
                                           Text="{Binding SelectedModVersionPickerLabel}" />
                                <ComboBox Classes="detail-version-picker"
                                          ItemsSource="{Binding SelectedModAvailableVersions}"
                                          SelectedItem="{Binding SelectedModVersionChoice}"
                                          MaxDropDownHeight="320">
                                  <ComboBox.SelectionBoxItemTemplate>
                                    <DataTemplate x:DataType="vm:ModVersionChoiceItem">
                                      <Grid ColumnDefinitions="*,Auto"
                                            Margin="0,2">
                                        <TextBlock Classes="detail-value"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding VersionText}" />
                                        <StackPanel Grid.Column="1"
                                                    Margin="10,0,0,0"
                                                    Orientation="Horizontal"
                                                    Spacing="8"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                          <TextBlock Classes="detail-label"
                                                     VerticalAlignment="Center"
                                                     TextWrapping="NoWrap"
                                                     Foreground="{Binding BadgeForeground}"
                                                     Text="{Binding SelectionBadgeText}"
                                                     IsVisible="{Binding HasSelectionBadge}" />
                                          <TextBlock Classes="detail-label"
                                                     MaxWidth="104"
                                                     VerticalAlignment="Center"
                                                     TextWrapping="NoWrap"
                                                     TextTrimming="CharacterEllipsis"
                                                     Text="{Binding MetaText}"
                                                     IsVisible="{Binding HasMetaText}" />
                                        </StackPanel>
                                      </Grid>
                                    </DataTemplate>
                                  </ComboBox.SelectionBoxItemTemplate>
                                  <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ModVersionChoiceItem">
                                      <Grid ColumnDefinitions="*,Auto"
                                            Margin="0,2">
                                        <TextBlock Classes="detail-value"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding VersionText}" />
                                        <StackPanel Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    Orientation="Horizontal"
                                                    Spacing="6"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                          <TextBlock Classes="detail-label"
                                                     VerticalAlignment="Center"
                                                     TextWrapping="NoWrap"
                                                     Foreground="{Binding BadgeForeground}"
                                                     Text="{Binding BadgeText}"
                                                     IsVisible="{Binding HasBadge}" />
                                          <TextBlock Classes="detail-label"
                                                     VerticalAlignment="Center"
                                                     TextWrapping="NoWrap"
                                                     TextTrimming="CharacterEllipsis"
                                                     Text="{Binding MetaText}"
                                                     IsVisible="{Binding HasMetaText}" />
                                        </StackPanel>
                                      </Grid>
                                    </DataTemplate>
                                  </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <Border Background="#24303B"
                                    Height="1"
                                    Margin="0,0,0,8" />

                            <Grid ColumnDefinitions="*,*"
                                  RowDefinitions="Auto,Auto"
                                  Margin="0,0,0,8">
                              <Border Classes="detail-stat-card"
                                      Grid.Row="0"
                                      Grid.Column="0"
                                      Margin="0,0,4,4">
                                <StackPanel Spacing="2">
                                  <TextBlock Classes="detail-label"
                                             Text="Compatibility" />
                                  <TextBlock Classes="detail-value"
                                             TextWrapping="Wrap"
                                             Text="{Binding SelectedModCompatibility}" />
                                </StackPanel>
                              </Border>
                              <Border Classes="detail-stat-card"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Margin="4,0,0,4">
                                <StackPanel Spacing="2">
                                  <TextBlock Classes="detail-label"
                                             Text="Released" />
                                  <TextBlock Classes="detail-value"
                                             TextWrapping="Wrap"
                                             Text="{Binding SelectedModReleaseDate}" />
                                </StackPanel>
                              </Border>
                              <Border Classes="detail-stat-card"
                                      Grid.Row="1"
                                      Grid.Column="0"
                                      Margin="0,4,4,0">
                                <StackPanel Spacing="2">
                                  <TextBlock Classes="detail-label"
                                             Text="Downloads" />
                                  <TextBlock Classes="detail-value"
                                             TextWrapping="Wrap"
                                             Text="{Binding SelectedModDownloadCount}" />
                                </StackPanel>
                              </Border>
                              <Border Classes="detail-stat-card"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      Margin="4,4,0,0">
                                <StackPanel Spacing="2">
                                  <TextBlock Classes="detail-label"
                                             Text="Size" />
                                  <TextBlock Classes="detail-value"
                                             TextWrapping="Wrap"
                                             Text="{Binding SelectedModDownloadSize}" />
                                </StackPanel>
                              </Border>
                            </Grid>
                            <Border Background="#24303B"
                                    Height="1"
                                    Margin="0,0,0,8" />

                            <StackPanel Spacing="2"
                                        Margin="0,0,0,8">
                              <TextBlock Classes="detail-label"
                                         Text="Cached" />
                              <TextBlock Classes="detail-value"
                                         TextWrapping="Wrap"
                                         Text="{Binding SelectedModCacheState}" />
                              <Button Classes="command-button subtle"
                                      HorizontalAlignment="Left"
                                      MinHeight="28"
                                      Margin="0,6,0,0"
                                      Padding="10,5"
                                      CornerRadius="7"
                                      Background="#24303B"
                                      BorderBrush="#3D4D5D"
                                      Foreground="#E8EEF5"
                                      IsVisible="{Binding ShowOpenSelectedModCacheLocationAction}"
                                      Command="{Binding OpenSelectedModCacheLocationCommand}"
                                      Content="Open in file manager" />
                            </StackPanel>
                            <Border Background="#24303B"
                                    Height="1"
                                    Margin="0,0,0,8" />

                            <StackPanel Spacing="2"
                                        Margin="0,0,0,8">
                              <TextBlock Classes="detail-label"
                                         Text="Type" />
                              <TextBlock Classes="detail-value"
                                         TextWrapping="Wrap"
                                         Text="{Binding SelectedModModuleKind}" />
                            </StackPanel>
                            <Border Background="#24303B"
                                    Height="1"
                                    Margin="0,0,0,8" />

                            <StackPanel Spacing="2"
                                        Margin="0,0,0,8">
                              <TextBlock Classes="detail-label"
                                         Text="License" />
                              <TextBlock Classes="detail-value"
                                         TextWrapping="Wrap"
                                         Text="{Binding SelectedModLicense}" />
                            </StackPanel>
                            <Border Background="#24303B"
                                    Height="1"
                                    Margin="0,0,0,8" />

                            <StackPanel Spacing="4"
                                        Margin="0,0,0,8">
                              <Grid ColumnDefinitions="Auto,Auto"
                                    HorizontalAlignment="Left">
                                <Button Classes="detail-disclosure"
                                        Command="{Binding ToggleSelectedModDependenciesCommand}">
                                  <Grid ColumnDefinitions="Auto,Auto"
                                        HorizontalAlignment="Left">
                                    <TextBlock Classes="detail-value"
                                               TextWrapping="Wrap"
                                               Text="{Binding SelectedModDependencyCountLabel}" />
                                    <TextBlock Grid.Column="1"
                                               Classes="detail-chevron"
                                               Text="{Binding SelectedModDependencyChevron}" />
                                  </Grid>
                                </Button>
                                <Button Grid.Column="1"
                                        Classes="detail-section-action"
                                        Margin="8,-1,0,0"
                                        IsVisible="{Binding HasSelectedModDependencies}"
                                        Command="{Binding ViewSelectedModDependenciesInBrowserCommand}"
                                        Content="View" />
                              </Grid>
                              <ItemsControl ItemsSource="{Binding SelectedModDependencies}"
                                            IsVisible="{Binding ShowSelectedModDependenciesExpanded}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Classes="detail-label"
                                               Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding Text}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                            <Border Background="#24303B"
                                    Height="1"
                                    Margin="0,0,0,8" />

                            <StackPanel Spacing="4"
                                        Margin="0,0,0,8">
                              <Grid ColumnDefinitions="Auto,Auto"
                                    HorizontalAlignment="Left">
                                <Button Classes="detail-disclosure"
                                        Command="{Binding ToggleSelectedModRecommendationsCommand}">
                                  <Grid ColumnDefinitions="Auto,Auto"
                                        HorizontalAlignment="Left">
                                    <TextBlock Classes="detail-value"
                                               TextWrapping="Wrap"
                                               Text="{Binding SelectedModRecommendationCountLabel}" />
                                    <TextBlock Grid.Column="1"
                                               Classes="detail-chevron"
                                               Text="{Binding SelectedModRecommendationChevron}" />
                                  </Grid>
                                </Button>
                                <Button Grid.Column="1"
                                        Classes="detail-section-action"
                                        Margin="8,-1,0,0"
                                        IsVisible="{Binding HasSelectedModRecommendations}"
                                        Command="{Binding ViewSelectedModRecommendationsInBrowserCommand}"
                                        Content="View" />
                              </Grid>
                              <ItemsControl ItemsSource="{Binding SelectedModRecommendations}"
                                            IsVisible="{Binding ShowSelectedModRecommendationsExpanded}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Classes="detail-label"
                                               Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding Text}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                            <Border Background="#24303B"
                                    Height="1"
                                    Margin="0,0,0,8" />

                            <StackPanel Spacing="4"
                                        Margin="0,0,0,8">
                              <Grid ColumnDefinitions="Auto,Auto"
                                    HorizontalAlignment="Left">
                                <Button Classes="detail-disclosure"
                                        Command="{Binding ToggleSelectedModSuggestionsCommand}">
                                  <Grid ColumnDefinitions="Auto,Auto"
                                        HorizontalAlignment="Left">
                                    <TextBlock Classes="detail-value"
                                               TextWrapping="Wrap"
                                               Text="{Binding SelectedModSuggestionCountLabel}" />
                                    <TextBlock Grid.Column="1"
                                               Classes="detail-chevron"
                                               Text="{Binding SelectedModSuggestionChevron}" />
                                  </Grid>
                                </Button>
                                <Button Grid.Column="1"
                                        Classes="detail-section-action"
                                        Margin="8,-1,0,0"
                                        IsVisible="{Binding HasSelectedModSuggestions}"
                                        Command="{Binding ViewSelectedModSuggestionsInBrowserCommand}"
                                        Content="View" />
                              </Grid>
                              <ItemsControl ItemsSource="{Binding SelectedModSuggestions}"
                                            IsVisible="{Binding ShowSelectedModSuggestionsExpanded}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Classes="detail-label"
                                               Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding Text}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>

                            <StackPanel Spacing="8"
                                        Margin="0,0,0,8"
                                        IsVisible="{Binding ShowSelectedModResourceLinks}">
                              <Border Background="#24303B"
                                      Height="1" />
                              <ItemsControl ItemsSource="{Binding SelectedModResourceLinks}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:ModResourceLinkItem">
                                    <Grid ColumnDefinitions="76,*"
                                          Margin="0,0,0,2">
                                      <TextBlock Classes="detail-label"
                                                 Margin="0,3,8,0"
                                                 VerticalAlignment="Top"
                                                 Text="{Binding Label}" />
                                      <Button Grid.Column="1"
                                              Classes="detail-link-button"
                                              HorizontalAlignment="Stretch"
                                              Click="SelectedModResourceLinkButton_OnClick">
                                        <TextBlock FontSize="11.5"
                                                   Foreground="#7FAFDF"
                                                   TextWrapping="NoWrap"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding Url}" />
                                      </Button>
                                    </Grid>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </StackPanel>
                        </StackPanel>
                      </StackPanel>
                    </ScrollViewer>
                  </Grid>
                </Border>
              </Grid>

              <Border Grid.Row="1"
                      Background="#161B21"
                      CornerRadius="10"
                      Padding="18"
                      IsVisible="{Binding ShowPreviewSurface}">
                <Grid RowDefinitions="*,Auto">

                  <Border Background="#1A2027"
                          CornerRadius="12"
                          Padding="24"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Top"
                          IsVisible="{Binding ShowPreviewEmptyWorkspace}">
                    <StackPanel Spacing="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="560">
                      <TextBlock FontSize="26"
                                 FontWeight="SemiBold"
                                 HorizontalAlignment="Center"
                                 TextAlignment="Center"
                                 Text="Nothing Queued Yet" />
                      <TextBlock FontSize="14"
                                 Opacity="0.82"
                                 TextWrapping="Wrap"
                                 TextAlignment="Center"
                                 Text="{Binding PreviewPanelGuidance}" />
                      <Border Background="#20262D"
                              CornerRadius="12"
                              Padding="16">
                        <TextBlock Opacity="0.84"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Text="Queue installs, updates, removals, or cache downloads from Browse. This page becomes the holding area where CKAN summarizes what will change before anything is applied." />
                      </Border>
                    </StackPanel>
                  </Border>

                  <Grid ColumnDefinitions="1.08*,0.92*"
                        Classes="preview-workspace-content"
                        Classes.conflict-popup-open="{Binding ShowPreviewConflictPopup}"
                        IsVisible="{Binding ShowPreviewActiveWorkspace}">
                    <Border Background="#1A2027"
                            BorderBrush="#11171D"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0,0,12,0"
                            BoxShadow="0 18 34 0 #24000000">
                      <Grid RowDefinitions="*,Auto">
                        <Border Grid.Row="0"
                                Background="#12171D"
                                BorderBrush="#26313B"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="0"
                                ClipToBounds="True">
                          <Grid RowDefinitions="Auto,*">
                          <Border Background="#14191F"
                                  BorderBrush="#27323C"
                                  BorderThickness="0,0,0,1"
                                  CornerRadius="7,7,0,0"
                                  Margin="0,0,12,0"
                                  Padding="0"
                                  IsVisible="{Binding HasQueuedActions}">
                            <Grid ColumnDefinitions="4,*,116,92">
                              <Border Background="#25313D"
                                      CornerRadius="7,0,0,0" />
                              <TextBlock Grid.Column="1"
                                         Classes="row-meta"
                                         Margin="8,6,0,6"
                                         FontWeight="SemiBold"
                                         Text="Mod" />
                              <Border Grid.Column="2"
                                      BorderBrush="#26323D"
                                      BorderThickness="1,0,0,0"
                                      Padding="10,0,0,0">
                                <TextBlock Classes="row-meta"
                                           Margin="0,6,0,6"
                                           FontWeight="SemiBold"
                                           Text="Action" />
                              </Border>
                              <Border Grid.Column="3"
                                      BorderBrush="#26323D"
                                      BorderThickness="1,0,0,0"
                                      Padding="10,0,0,0">
                                <TextBlock Classes="row-meta"
                                           Margin="0,6,0,6"
                                           FontWeight="SemiBold"
                                           Text="Version" />
                              </Border>
                            </Grid>
                          </Border>

                          <ListBox x:Name="PreviewQueueList"
                                   Grid.Row="1"
                                   MinHeight="0"
                                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                                   ItemsSource="{Binding QueuedActions}"
                                   SelectedItem="{Binding SelectedQueuedAction}"
                                   IsVisible="{Binding HasQueuedActions}">
                            <ListBox.ItemTemplate>
                              <DataTemplate DataType="models:QueuedActionModel">
                                <Border Background="#181D23"
                                        BorderBrush="#11161B"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="5"
                                        Padding="0"
                                        BoxShadow="0 8 18 0 #26000000">
                                  <Grid>
                                    <Grid ColumnDefinitions="4,*,116,92">
                                      <Border Background="{Binding AccentBrush}"
                                              CornerRadius="5,0,0,5" />
                                      <Border Grid.Column="1"
                                              Padding="8,7">
                                        <StackPanel Spacing="3">
                                          <TextBlock Classes="row-title"
                                                     TextTrimming="CharacterEllipsis"
                                                     Text="{Binding Name}" />
                                          <TextBlock Classes="row-summary"
                                                     MaxLines="1"
                                                     TextTrimming="CharacterEllipsis"
                                                     Text="{Binding Identifier}" />
                                        </StackPanel>
                                      </Border>
                                      <Border Grid.Column="2"
                                              BorderBrush="#24303B"
                                              BorderThickness="1,0,0,0"
                                              Padding="10,0,0,0">
                                        <Border Background="{Binding ActionBadgeBackground}"
                                                BorderBrush="{Binding ActionBadgeBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                Padding="7,2"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                          <TextBlock FontSize="10"
                                                     FontWeight="SemiBold"
                                                     Text="{Binding ActionText}" />
                                        </Border>
                                      </Border>
                                      <Border Grid.Column="3"
                                              BorderBrush="#24303B"
                                              BorderThickness="1,0,0,0"
                                              Padding="10,0,0,0">
                                        <TextBlock Classes="row-version-primary"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding VersionText}" />
                                      </Border>
                                    </Grid>
                                    <Border Classes="queue-row-status-tint"
                                            Background="{Binding AccentBrush}" />
                                    <Border Classes="queue-row-status-outline"
                                            BorderBrush="{Binding AccentBrush}" />
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ListBox.ItemTemplate>
                          </ListBox>

                          <Border Background="#20262D"
                                  Grid.RowSpan="2"
                                  CornerRadius="10"
                                  Padding="18"
                                  IsVisible="{Binding ShowEmptyQueueState}">
                            <StackPanel Spacing="8"
                                        VerticalAlignment="Center">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Nothing Queued Yet" />
                              <TextBlock TextWrapping="Wrap"
                                         Opacity="0.82"
                                         Text="Queue install, update, or remove actions from a selected mod to build a preflight summary before applying anything. Right-click a mod to add it to cache." />
                            </StackPanel>
                          </Border>
                          </Grid>
                        </Border>

                        <WrapPanel Grid.Row="1"
                                   Margin="0,12,0,0"
                                   HorizontalAlignment="Left"
                                   ItemHeight="34"
                                   IsVisible="{Binding HasQueuedActions}">
                          <Button Classes="browser-chip"
                                  Margin="0,0,8,0"
                                  Background="#20262D"
                                  BorderBrush="#3C4754"
                                  Foreground="#E8EDF3"
                                  Command="{Binding RemoveQueuedActionCommand}"
                                  Content="Remove Selected" />
                        </WrapPanel>
                      </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#1A2027"
                            CornerRadius="10"
                            Padding="16"
                            Margin="12,0,0,0">
                      <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="12">
                          <Border Background="{Binding ApplyResultBackground}"
                                  BorderBrush="{Binding ApplyResultBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="10"
                                  Padding="12"
                                  IsVisible="{Binding ShowInlineApplyResult}">
                            <StackPanel Spacing="8">
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding ApplyResultTitle}" />
                              <TextBlock TextWrapping="Wrap"
                                         Opacity="0.86"
                                         Text="{Binding ApplyResultMessage}" />

                              <ItemsControl IsVisible="{Binding HasApplyResultSummaryLines}"
                                            ItemsSource="{Binding ApplyResultSummaryLines}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               Opacity="0.82"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>

                              <Border Background="#161B21"
                                      CornerRadius="8"
                                      Padding="10"
                                      IsVisible="{Binding HasApplyResultFollowUpLines}">
                                <StackPanel Spacing="6">
                                  <TextBlock FontWeight="SemiBold"
                                             Text="Follow-Up" />
                                  <ItemsControl ItemsSource="{Binding ApplyResultFollowUpLines}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <TextBlock Margin="0,0,0,4"
                                                   Opacity="0.84"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding}" />
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </Border>
                            </StackPanel>
                          </Border>

                          <ProgressBar Height="12"
                                       IsIndeterminate="{Binding IsPreviewLoading}"
                                       IsVisible="{Binding IsPreviewLoading}" />

                          <Border Background="#161B21"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding HasPreviewAutoRemovals}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Auto-Removals" />
                              <ItemsControl ItemsSource="{Binding PreviewAutoRemovals}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>

                        </StackPanel>
                      </ScrollViewer>
                    </Border>
                  </Grid>

                  <Grid Grid.RowSpan="2"
                        ZIndex="20"
                        IsVisible="{Binding ShowPreviewConflictPopup}">
                    <Border Background="#A80B0F14" />

                    <Border Width="560"
                            MaxHeight="460"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#221018"
                            BorderBrush="#D95A72"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16"
                            BoxShadow="0 24 52 0 #77000000">
                      <Grid RowDefinitions="Auto,*,Auto">
                        <Grid>
                          <StackPanel Spacing="4">
                            <TextBlock FontSize="17"
                                       FontWeight="SemiBold"
                                       Text="{Binding PreviewConflictPopupTitle}" />
                            <TextBlock Opacity="0.84"
                                       TextWrapping="Wrap"
                                       Text="Review each conflict in Browse, then choose which mod should stay installed." />
                          </StackPanel>
                        </Grid>

                        <ListBox x:Name="PreviewConflictList"
                                 Grid.Row="1"
                                 Margin="0,14,0,12"
                                 MaxHeight="250"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ItemsSource="{Binding PreviewConflictChoices}">
                          <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PreviewConflictChoiceItem">
                              <Grid ColumnDefinitions="*,Auto">
                                <Border Classes="preview-conflict-row"
                                        Background="#2A1820"
                                        BorderBrush="#3C212B"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Padding="10"
                                        MinHeight="58">
                                  <StackPanel Spacing="4">
                                    <TextBlock FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               Text="{Binding ActionText}" />
                                    <TextBlock Opacity="0.78"
                                               TextWrapping="Wrap"
                                               Text="{Binding DetailText}" />
                                  </StackPanel>
                                </Border>
                                <Button Grid.Column="1"
                                        Classes="browser-chip"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Stretch"
                                        MinWidth="58"
                                        Padding="12,0"
                                        Background="#2A1820"
                                        BorderBrush="#5A3340"
                                        Foreground="#F4F6F8"
                                        Click="PreviewConflictViewButton_OnClick"
                                        Content="View" />
                              </Grid>
                            </DataTemplate>
                          </ListBox.ItemTemplate>
                        </ListBox>
                      </Grid>
                    </Border>
                  </Grid>

                  <WrapPanel Grid.Row="1"
                             Margin="0,14,0,0"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             ItemHeight="38">
                    <Button Classes="preview-action"
                            Background="#4B535D"
                            BorderBrush="#4B535D"
                            Foreground="#F4F6F8"
                            IsVisible="{Binding ShowInlineApplyResult}"
                            Command="{Binding DismissApplyResultCommand}"
                            Content="Dismiss Result" />
                    <Button Classes="preview-action"
                            Background="#26191C"
                            BorderBrush="#6B2B2B"
                            Foreground="#F4F6F8"
                            IsVisible="{Binding HasQueuedActions}"
                            Command="{Binding ClearQueueCommand}"
                            Content="Clear Queue" />
                    <Button Classes="preview-action"
                            Background="{Binding DownloadQueuedButtonBackground}"
                            BorderBrush="{Binding DownloadQueuedButtonBorderBrush}"
                            Foreground="#F4F6F8"
                            IsVisible="{Binding HasQueuedDownloadActions}"
                            Command="{Binding DownloadQueuedCommand}"
                            Content="{Binding DownloadQueuedButtonLabel}" />
                    <Button Classes="preview-action"
                            MinWidth="144"
                            Background="{Binding ApplyChangesButtonBackground}"
                            BorderBrush="{Binding ApplyChangesButtonBorderBrush}"
                            Foreground="#F4F6F8"
                            IsVisible="{Binding HasQueuedChangeActions}"
                            Command="{Binding ApplyChangesCommand}"
                            Content="Apply Changes" />
                  </WrapPanel>
                </Grid>
              </Border>
            </Grid>
          </Border>

          <Border Background="#3A1E24"
                  BorderBrush="#934354"
                  BorderThickness="1"
                  CornerRadius="12"
                  Padding="24"
                  IsVisible="{Binding HasError}">
            <StackPanel Spacing="16">
              <TextBlock FontSize="24"
                         FontWeight="SemiBold"
                         Text="{Binding StageTitle}" />
              <TextBlock TextWrapping="Wrap"
                         Opacity="0.9"
                         Text="{Binding StageDescription}" />
              <Border Background="#271217"
                      CornerRadius="10"
                      Padding="16">
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding Diagnostics}" />
              </Border>
              <Button Width="170"
                      Classes="command-button primary"
                      HorizontalAlignment="Left"
                      Command="{Binding RefreshCommand}"
                      Content="Retry Startup" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.RowSpan="3"
            ZIndex="80"
            Background="#CC101820"
            IsVisible="{Binding IsCatalogLoading}">
      <Border Background="#1B2430"
              BorderBrush="#4D6177"
              BorderThickness="1"
              CornerRadius="12"
              Padding="14,12"
              Width="360"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              IsVisible="{Binding IsCatalogLoading}"
              BoxShadow="0 18 36 0 #66000000">
        <StackPanel Spacing="8">
          <TextBlock FontSize="12"
                     FontWeight="SemiBold"
                     Opacity="0.86"
                     HorizontalAlignment="Center"
                     Text="Loading Catalog" />
          <ProgressBar Height="12"
                       Minimum="0"
                       Maximum="100"
                       IsIndeterminate="{Binding IsCatalogLoading}" />
          <TextBlock FontSize="12"
                     Opacity="0.78"
                     TextAlignment="Center"
                     TextWrapping="Wrap"
                     MaxLines="2"
                     Text="{Binding CatalogStatusMessage}" />
        </StackPanel>
      </Border>
    </Border>

    <Border Grid.RowSpan="3"
            ZIndex="100"
            Background="#C0141A22"
            IsVisible="{Binding ShowExecutionOverlay}">
      <Grid>
        <Border Background="#14191F"
                BorderBrush="#2B323C"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8"
                Margin="20,90,20,20"
                ClipToBounds="True">
          <ItemsControl ItemsSource="{Binding CatalogSkeletonRows}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:CatalogSkeletonRow"
                            x:CompileBindings="False">
                <Border Background="#1B2128"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,2"
                        Opacity="{Binding Opacity}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="5" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="{Binding #MainWindowRoot.DataContext.BrowserMetadataColumnGridLength}" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{Binding AccentBrush}"
                            CornerRadius="8,0,0,8" />
                    <StackPanel Grid.Column="1"
                                Margin="12,0,12,0"
                                VerticalAlignment="Center"
                                Spacing="7">
                      <Grid ColumnDefinitions="*,Auto,Auto">
                        <Grid Grid.Column="0"
                              ColumnDefinitions="Auto,*">
                          <Border Background="#2A323C"
                                  CornerRadius="6"
                                  Height="15"
                                  Width="{Binding TitleWidth}"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center" />
                          <Border Grid.Column="1"
                                  Background="#242B34"
                                  CornerRadius="6"
                                  Height="11"
                                  Width="{Binding AuthorWidth}"
                                  Margin="8,0,0,0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding HasAuthor}" />
                        </Grid>
                        <StackPanel Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                          <Border Background="{Binding PrimaryBadgeBackground}"
                                  CornerRadius="999"
                                  Height="16"
                                  Width="{Binding PrimaryBadgeWidth}"
                                  Margin="0,0,6,0"
                                  IsVisible="{Binding HasPrimaryBadge}" />
                          <Border Background="#39424E"
                                  BorderBrush="#607286"
                                  BorderThickness="1"
                                  CornerRadius="999"
                                  Height="16"
                                  Width="52"
                                  Margin="0,0,6,0"
                                  IsVisible="{Binding HasCachedBadge}" />
                          <Border Background="{Binding SecondaryBadgeBackground}"
                                  BorderBrush="{Binding SecondaryBadgeBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="999"
                                  Height="16"
                                  Width="{Binding SecondaryBadgeWidth}"
                                  Margin="0,0,6,0"
                                  IsVisible="{Binding HasSecondaryBadge}" />
                        </StackPanel>
                        <Border Grid.Column="2"
                                Margin="8,0,0,0"
                                Background="{Binding QueueBadgeBackground}"
                                BorderBrush="{Binding QueueBadgeBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Height="16"
                                Width="{Binding QueueBadgeWidth}"
                                VerticalAlignment="Center"
                                IsVisible="{Binding HasQueueBadge}" />
                      </Grid>
                      <Border Background="#242B34"
                              CornerRadius="6"
                              Height="11"
                              Width="{Binding SummaryWidth}"
                              HorizontalAlignment="Left" />
                    </StackPanel>
                    <Grid Grid.Column="2"
                          VerticalAlignment="Top"
                          Margin="0,1,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding #MainWindowRoot.DataContext.BrowserDownloadsColumnGridLength}" />
                        <ColumnDefinition Width="{Binding #MainWindowRoot.DataContext.BrowserReleasedColumnGridLength}" />
                        <ColumnDefinition Width="{Binding #MainWindowRoot.DataContext.BrowserInstalledColumnGridLength}" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <Border Background="#2A323C"
                              CornerRadius="6"
                              Height="13"
                              Width="{Binding DownloadsWidth}"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top" />
                      <Border Grid.Column="1"
                              Margin="10,0,0,0"
                              Background="#2A323C"
                              CornerRadius="6"
                              Height="13"
                              Width="{Binding ReleaseWidth}"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top" />
                      <Border Grid.Column="2"
                              Margin="10,0,0,0"
                              Background="#2A323C"
                              CornerRadius="6"
                              Height="13"
                              Width="{Binding ReleaseWidth}"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top" />
                      <StackPanel Grid.Column="3"
                                  Margin="10,0,0,0"
                                  VerticalAlignment="Top"
                                  Spacing="4">
                        <Border Background="#2A323C"
                                CornerRadius="6"
                                Height="13"
                                Width="{Binding VersionPrimaryWidth}"
                                HorizontalAlignment="Left" />
                        <Border Background="#242B34"
                                CornerRadius="6"
                                Height="11"
                                Width="{Binding VersionSecondaryWidth}"
                                HorizontalAlignment="Left" />
                      </StackPanel>
                    </Grid>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Border>

        <Border Background="#1A2027"
                BorderBrush="#36414E"
                BorderThickness="1"
                CornerRadius="14"
                Padding="24"
                Width="520"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsVisible="{Binding ShowExecutionProgressOverlay}">
          <StackPanel Spacing="14">
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Text="{Binding ExecutionDialogTitle}" />
            <TextBlock Opacity="0.84"
                       TextWrapping="Wrap"
                       Text="{Binding ExecutionDialogMessage}" />
            <ProgressBar Height="16"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding ExecutionProgressValue}"
                         IsVisible="{Binding HasExecutionProgressValue}" />
            <ProgressBar Height="16"
                         IsIndeterminate="True"
                         IsVisible="{Binding IsExecutionProgressIndeterminate}" />
            <TextBlock FontSize="12"
                       Opacity="0.72"
                       TextWrapping="Wrap"
                       Text="Please wait while CKAN Linux finishes downloads, file operations, and refreshes the install state." />
          </StackPanel>
        </Border>

        <Border Background="{Binding ApplyResultBackground}"
                BorderBrush="{Binding ApplyResultBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="24"
                Width="560"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsVisible="{Binding ShowExecutionResultOverlay}">
          <StackPanel Spacing="14">
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Text="{Binding ApplyResultTitle}" />
            <TextBlock Opacity="0.88"
                       TextWrapping="Wrap"
                       Text="{Binding ApplyResultMessage}" />

            <ItemsControl IsVisible="{Binding HasApplyResultSummaryLines}"
                          ItemsSource="{Binding ApplyResultSummaryLines}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Margin="0,0,0,4"
                             Opacity="0.84"
                             TextWrapping="Wrap"
                             Text="{Binding}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Background="#161B21"
                    CornerRadius="10"
                    Padding="12"
                    IsVisible="{Binding HasApplyResultFollowUpLines}">
              <StackPanel Spacing="6">
                <TextBlock FontWeight="SemiBold"
                           Text="Follow-Up" />
                <ItemsControl ItemsSource="{Binding ApplyResultFollowUpLines}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Margin="0,0,0,4"
                                 Opacity="0.84"
                                 TextWrapping="Wrap"
                                 Text="{Binding}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Button Classes="preview-action"
                    HorizontalAlignment="Right"
                    Margin="0"
                    Background="#355779"
                    BorderBrush="#5A86B4"
                    Foreground="#F4F6F8"
                    Command="{Binding AcknowledgeExecutionResultCommand}"
                    Content="{Binding ExecutionResultAcknowledgeLabel}" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

  </Grid>
  </LayoutTransformControl>
</Window>
