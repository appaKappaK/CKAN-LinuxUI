<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CKAN.LinuxGUI.PlayTimeWindow"
        x:CompileBindings="False"
        Width="760"
        Height="480"
        MinWidth="700"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Title="Play Time"
        Background="#171C22">
  <Window.Styles>
    <Style Selector="Button.dialog-action">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Background" Value="#24303B" />
      <Setter Property="BorderBrush" Value="#405061" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Foreground" Value="#F3F7FC" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Button.dialog-action:pointerover">
      <Setter Property="Background" Value="#2E3C49" />
      <Setter Property="BorderBrush" Value="#5B7084" />
    </Style>
    <Style Selector="Button.dialog-action:pressed">
      <Setter Property="Background" Value="#1D2730" />
      <Setter Property="BorderBrush" Value="#6A7F94" />
    </Style>
    <Style Selector="Button.dialog-action:disabled">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#303A44" />
      <Setter Property="Foreground" Value="#7B8794" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="TextBox.playtime-hours">
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="Background" Value="#16202A" />
      <Setter Property="BorderBrush" Value="#3D4E60" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Foreground" Value="#F4F6F8" />
      <Setter Property="SelectionBrush" Value="#355779" />
      <Setter Property="CaretBrush" Value="#F4F6F8" />
    </Style>
    <Style Selector="TextBox.playtime-hours:pointerover">
      <Setter Property="Background" Value="#1B2631" />
      <Setter Property="BorderBrush" Value="#4B5D70" />
    </Style>
    <Style Selector="TextBox.playtime-hours:focus">
      <Setter Property="Background" Value="#1B2631" />
      <Setter Property="BorderBrush" Value="#61758B" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="*,Auto"
        Margin="20">
    <Border
            Background="#161B21"
            BorderBrush="#2B323C"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12">
      <Grid RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="2.2*,1.4*,0.8*">
          <TextBlock FontWeight="SemiBold"
                     Text="Instance" />
          <TextBlock Grid.Column="1"
                     FontWeight="SemiBold"
                     Text="Path" />
          <TextBlock Grid.Column="2"
                     HorizontalAlignment="Right"
                     FontWeight="SemiBold"
                     Text="Hours" />
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Margin="0,12,0,0">
          <ItemsControl ItemsSource="{Binding Entries}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border BorderBrush="#242B33"
                        BorderThickness="0,0,0,1"
                        Padding="0,10">
                  <Grid ColumnDefinitions="2.2*,1.4*,0.8*">
                    <StackPanel Spacing="3">
                      <TextBlock FontWeight="SemiBold"
                                 Text="{Binding Name}" />
                      <TextBlock FontSize="12"
                                 Opacity="0.66"
                                 Text="{Binding GameName}" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Margin="12,0,12,0"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding GameDir}" />

                    <TextBox Grid.Column="2"
                             Classes="playtime-hours"
                             HorizontalContentAlignment="Right"
                             Text="{Binding HoursText, Mode=TwoWay}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          Margin="0,16,0,0"
          ColumnDefinitions="*,Auto">
      <StackPanel VerticalAlignment="Center"
                  Spacing="3">
        <TextBlock FontSize="12"
                   Opacity="0.76"
                   Text="{Binding TotalHoursLabel}" />
        <TextBlock FontSize="12"
                   Foreground="#F06C6C"
                   TextWrapping="Wrap"
                   IsVisible="{Binding HasValidationMessage}"
                   Text="{Binding ValidationMessage}" />
      </StackPanel>

      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="12">
        <Button Classes="dialog-action"
                Background="#20262D"
                BorderBrush="#39424E"
                Foreground="#F4F6F8"
                Click="CloseButton_OnClick"
                Content="Close" />
        <Button Classes="dialog-action"
                Background="#355779"
                BorderBrush="#5A86B4"
                Foreground="#F4F6F8"
                Click="SaveButton_OnClick"
                Content="Save" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
