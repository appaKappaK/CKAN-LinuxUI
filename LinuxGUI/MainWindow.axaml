                        <Grid RowDefinitions="Auto,*"
                              IsVisible="{Binding ShowModList}">
                          <Grid ColumnDefinitions="3,*,216"
                                Margin="0,0,0,4">
                            <Button Grid.Column="1"
                                    Classes="column-sort-header"
                                    Command="{Binding SelectNameSortCommand}"
                                    Content="{Binding NameSortLabel}" />
                            <Grid Grid.Column="2"
                                  ColumnDefinitions="72,48,*"
                                  Margin="8,0,4,0">
                              <Button Classes="column-sort-header"
                                      Command="{Binding SelectPopularitySortCommand}"
                                      Content="{Binding PopularitySortLabel}" />
                              <Button Grid.Column="1"
                                      Classes="column-sort-header"
                                      Margin="10,0,0,0"
                                      Command="{Binding SelectCompatibilitySortCommand}"
                                      Content="{Binding CompatibilitySortLabel}" />
                              <Button Grid.Column="2"
                                      Classes="column-sort-header"
                                      Margin="10,0,0,0"
                                      Command="{Binding SelectVersionSortCommand}"
                                      Content="{Binding VersionSortLabel}" />
                            </Grid>
                          </Grid>

                          <ListBox x:Name="ModsListBox"
                                   Grid.Row="1"
                                   ItemsSource="{Binding Mods}"
                                   AutoScrollToSelectedItem="False"
                                   SelectedItem="{Binding SelectedMod}">
                            <ListBox.ItemTemplate>
                              <DataTemplate DataType="models:ModListItem">
                                <Border Background="#181D23"
                                        CornerRadius="5"
                                        Margin="0,0,0,1"
                                        Padding="0"
                                        PointerPressed="ModRow_OnPointerPressed">
                                  <Grid>
                                    <Grid ColumnDefinitions="4,*,220">
                                      <Border Background="{Binding PrimaryStateColor}"
                                              CornerRadius="5,0,0,5" />

                                      <Border Grid.Column="1"
                                              Padding="8,4">
                                        <StackPanel Spacing="2">
                                        <Grid ColumnDefinitions="*,Auto">
                                          <TextBlock Classes="row-title"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding Name}" />

                                          <StackPanel Grid.Column="1"
                                                      Orientation="Horizontal"
                                                      Spacing="6"
                                                      Margin="6,0,0,0"
                                                      VerticalAlignment="Top">
                                            <Border Background="{Binding PrimaryStateColor}"
                                                    CornerRadius="999"
                                                    Padding="6,1">
                                              <TextBlock FontSize="10"
                                                         FontWeight="SemiBold"
                                                         Foreground="#F7FAFD"
                                                         Text="{Binding PrimaryStateLabel}" />
                                            </Border>
                                            <Border Background="#39424E"
                                                    BorderBrush="#607286"
                                                    BorderThickness="1"
                                                    CornerRadius="999"
                                                    Padding="6,1"
                                                    IsVisible="{Binding IsCached}">
                                              <TextBlock FontSize="10"
                                                         FontWeight="SemiBold"
                                                         Foreground="#EFF4F9"
                                                         Text="Cached" />
                                            </Border>
                                            <Border Background="{Binding SecondaryStateBackground}"
                                                    BorderBrush="{Binding SecondaryStateBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="999"
                                                    Padding="6,1"
                                                    IsVisible="{Binding HasSecondaryState}">
                                              <TextBlock FontSize="10"
                                                         FontWeight="SemiBold"
                                                         Foreground="#FFF7E8"
                                                         Text="{Binding SecondaryStateLabel}" />
                                            </Border>
                                            <Border Background="{Binding TertiaryStateBackground}"
                                                    BorderBrush="{Binding TertiaryStateBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="999"
                                                    Padding="6,1"
                                                    IsVisible="{Binding HasTertiaryState}">
                                              <TextBlock FontSize="10"
                                                         FontWeight="SemiBold"
                                                         Foreground="#EAF4FF"
                                                         Text="{Binding TertiaryStateLabel}" />
                                            </Border>
                                            <Border Background="{Binding QueueStateBackground}"
                                                    BorderBrush="{Binding QueueStateBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="999"
                                                    Padding="6,1"
                                                    IsVisible="{Binding HasQueueState}">
                                              <TextBlock FontSize="10"
                                                         FontWeight="SemiBold"
                                                         Foreground="#F7FAFD"
                                                         Text="{Binding QueueStateLabel}" />
                                            </Border>
                                          </StackPanel>
                                        </Grid>

                                        <TextBlock Classes="row-summary"
                                                   TextWrapping="Wrap"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding Summary}" />

                                        <Grid ColumnDefinitions="*,Auto">
                                          <TextBlock Classes="row-meta"
                                                     VerticalAlignment="Center"
                                                     TextTrimming="CharacterEllipsis"
                                                     Text="{Binding Author}" />
                                          <TextBlock Grid.Column="1"
                                                     Classes="row-status"
                                                     Margin="8,0,0,0"
                                                     VerticalAlignment="Center"
                                                     HorizontalAlignment="Right"
                                                     IsVisible="{Binding HasStatusSummary}"
                                                     Text="{Binding StatusSummary}" />
                                        </Grid>
                                        </StackPanel>
                                      </Border>

                                      <Border Grid.Column="2"
                                              BorderBrush="#2E3842"
                                              BorderThickness="1,0,0,0"
                                              Padding="8,4">
                                        <Grid ColumnDefinitions="78,52,*"
                                            >
                                        <TextBlock Classes="row-number"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top"
                                                   Text="{Binding DownloadCountLabel}" />

                                        <TextBlock Grid.Column="1"
                                                   Margin="10,0,0,0"
                                                   Classes="row-compat"
                                                   VerticalAlignment="Top"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"
                                                   Text="{Binding Compatibility}" />

                                        <StackPanel Grid.Column="2"
                                                    Margin="10,0,0,0"
                                                    Spacing="1">
                                          <TextBlock Classes="row-version-primary"
                                                     HorizontalAlignment="Left"
                                                     TextTrimming="CharacterEllipsis"
                                                     Text="{Binding LatestVersion}" />
                                          <TextBlock Classes="row-version-secondary"
                                                     TextTrimming="CharacterEllipsis"
                                                     IsVisible="{Binding IsInstalled}"
                                                     Text="{Binding InstalledVersion}" />
                                        </StackPanel>
                                        </Grid>
                                      </Border>
                                    </Grid>

                                    <Border BorderBrush="{Binding QueueStateBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            IsHitTestVisible="False"
                                            IsVisible="{Binding HasQueueState}" />
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ListBox.ItemTemplate>
                          </ListBox>
                        </Grid>

                        <Border Background="#20262D"
                                CornerRadius="10"
                                Padding="18"
                                IsVisible="{Binding ShowEmptyModResults}">
                          <StackPanel Spacing="8"
                                      VerticalAlignment="Center">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="No mods match the current search and filters." />
                            <TextBlock Opacity="0.82"
                                       TextWrapping="Wrap"
                                       Text="Broaden the query or clear the active filters to restore the catalog list." />
                            <Button Width="140"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ClearFiltersCommand}"
                                    Content="Clear Filters" />
                          </StackPanel>
                        </Border>
                      </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Background="#20262D"
                            CornerRadius="8"
                            Padding="10,8"
                            Margin="0,10,0,0"
                            IsVisible="{Binding IsCatalogLoading}">
                      <Grid ColumnDefinitions="Auto,*">
                        <ProgressBar Width="120"
                                     Height="14"
                                     Minimum="0"
                                     Maximum="100"
                                     IsIndeterminate="{Binding IsCatalogLoading}" />
                        <TextBlock Grid.Column="1"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Opacity="0.78"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding CatalogStatusMessage}" />
                      </Grid>
                    </Border>
                  </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="#14191F"
                        BorderBrush="#2B323C"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="8,0,0,0"
                        Width="292"
                        MinWidth="272"
                        IsVisible="{Binding ShowDetailsSidebar}">
                  <Grid>
                    <StackPanel Spacing="12"
                                IsVisible="{Binding ShowSelectedModPlaceholder}">
                      <TextBlock FontSize="11"
                                 Opacity="0.68"
                                 Text="Mod Details" />
                      <TextBlock FontSize="16"
                                 FontWeight="SemiBold"
                                 Text="No mod selected" />
                      <TextBlock Opacity="0.8"
                                 TextWrapping="Wrap"
                                 Text="Choose a mod from the browser to inspect install state, compatibility, and package metadata." />
                    </StackPanel>

                    <StackPanel Spacing="14"
                                IsVisible="{Binding ShowSelectedModLoadingState}">
                      <TextBlock FontSize="11"
                                 Opacity="0.68"
                                 Text="Mod Details" />
                      <TextBlock FontSize="16"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap"
                                 Text="{Binding SelectedModLoadingTitle}" />
                      <Border Background="#26303A"
                              CornerRadius="5"
                              Height="14"
                              Width="170"
                              HorizontalAlignment="Left" />
                      <Border Background="#20262D"
                              Height="1"
                              Margin="0,2" />
                      <Grid ColumnDefinitions="Auto,*"
                            RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                        <TextBlock FontSize="12"
                                   Opacity="0.68"
                                   Text="Version" />
                        <Border Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="132"
                                Margin="12,0,0,0"
                                HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="1"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   Opacity="0.68"
                                   Text="Status" />
                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="164"
                                Margin="12,10,0,0"
                                HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="2"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   Opacity="0.68"
                                   Text="License" />
                        <Border Grid.Row="2"
                                Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="120"
                                Margin="12,10,0,0"
                                HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="3"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   Opacity="0.68"
                                   Text="Type" />
                        <Border Grid.Row="3"
                                Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="108"
                                Margin="12,10,0,0"
                                HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="4"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   Opacity="0.68"
                                   Text="Released" />
                        <Border Grid.Row="4"
                                Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="144"
                                Margin="12,10,0,0"
                                HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="5"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   Opacity="0.68"
                                   Text="Download" />
                        <Border Grid.Row="5"
                                Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="126"
                                Margin="12,10,0,0"
                                HorizontalAlignment="Left" />
                      </Grid>
                      <Border Background="#20262D"
                              Height="1"
                              Margin="0,2" />
                      <Border Background="#242B34"
                              CornerRadius="5"
                              Height="11"
                              Width="240"
                              HorizontalAlignment="Left" />
                      <Border Background="#242B34"
                              CornerRadius="5"
                              Height="11"
                              Width="220"
                              HorizontalAlignment="Left" />
                      <Border Background="#242B34"
                              CornerRadius="5"
                              Height="11"
                              Width="232"
                              HorizontalAlignment="Left" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding ShowSelectedModContent}">
                      <StackPanel Spacing="8">
                        <TextBlock Classes="panel-kicker"
                                   Text="Mod Details" />
                        <TextBlock Classes="panel-title"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedModTitle}" />
                        <TextBlock Classes="panel-body"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedModBody}" />
                        <TextBlock Classes="panel-meta"
                                   Text="{Binding SelectedModAuthors}" />

                        <WrapPanel ItemHeight="22"
                                   IsVisible="{Binding HasSelectedMod}">
                          <Border Background="#2B6A98"
                                  BorderBrush="#4A88B5"
                                  BorderThickness="1"
                                  CornerRadius="999"
                                  Padding="7,2"
                                  Margin="0,0,6,4"
                                  IsVisible="{Binding SelectedModIsInstalled}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#F7FAFD"
                                       Text="Installed" />
                          </Border>
                          <Border Background="#6A952B"
                                  BorderBrush="#82AF3D"
                                  BorderThickness="1"
                                  CornerRadius="999"
                                  Padding="7,2"
                                  Margin="0,0,6,4"
                                  IsVisible="{Binding SelectedModHasUpdate}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#F7FAFD"
                                       Text="Update available" />
                          </Border>
                          <Border Background="#5A4322"
                                  BorderBrush="#9F7A40"
                                  BorderThickness="1"
                                  CornerRadius="999"
                                  Padding="7,2"
                                  Margin="0,0,6,4"
                                  IsVisible="{Binding SelectedModIsAutodetected}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#FFF7E8"
                                       Text="External" />
                          </Border>
                          <Border Background="#9A485C"
                                  BorderBrush="#B35D73"
                                  BorderThickness="1"
                                  CornerRadius="999"
                                  Padding="7,2"
                                  Margin="0,0,6,4"
                                  IsVisible="{Binding SelectedModShowsIncompatibleState}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#FFF6F8"
                                       Text="Incompatible" />
                          </Border>
                          <Border Background="#31424F"
                                  BorderBrush="#4C6A86"
                                  BorderThickness="1"
                                  CornerRadius="999"
                                  Padding="7,2"
                                  Margin="0,0,6,4"
                                  IsVisible="{Binding SelectedModShowsDependencyState}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#EAF4FF"
                                       Text="Dependency" />
                          </Border>
                          <Border Background="#734790"
                                  BorderBrush="#8B5FA8"
                                  BorderThickness="1"
                                  CornerRadius="999"
                                  Padding="7,2"
                                  Margin="0,0,6,4"
                                  IsVisible="{Binding SelectedModHasReplacement}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#FBF6FF"
                                       Text="Has replacement" />
                          </Border>
                        </WrapPanel>

                        <WrapPanel ItemHeight="34">
                          <Button HorizontalAlignment="Left"
                                  Margin="0,0,8,0"
                                  Padding="12,7"
                                  CornerRadius="8"
                                  Background="#2F7C58"
                                  BorderBrush="#43946E"
                                  Foreground="#F7FAFD"
                                  IsVisible="{Binding ShowInstallNowAction}"
                                  Command="{Binding InstallNowSelectedModCommand}"
                                  Content="Install Now" />
                          <Button HorizontalAlignment="Left"
                                  Margin="0,0,8,0"
                                  Padding="12,7"
                                  CornerRadius="8"
                                  Background="#9A485C"
                                  BorderBrush="#B35D73"
                                  Foreground="#FFF7F8"
                                  IsVisible="{Binding ShowRemoveNowAction}"
                                  Command="{Binding RemoveNowSelectedModCommand}"
                                  Content="Remove Now" />
                          <Button HorizontalAlignment="Left"
                                  Margin="0,0,8,0"
                                  Padding="12,7"
                                  CornerRadius="8"
                                  Background="{Binding PrimarySelectedModActionBackground}"
                                  BorderBrush="{Binding PrimarySelectedModActionBorderBrush}"
                                  Foreground="#F7FAFD"
                                  IsVisible="{Binding ShowPrimarySelectedModAction}"
                                  Command="{Binding PrimarySelectedModActionCommand}"
                                  Content="{Binding PrimarySelectedModActionLabel}" />
                        </WrapPanel>

                        <Border Background="#3B2B1B"
                                BorderBrush="#8C6432"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,8"
                                IsVisible="{Binding ShowSelectedModActionUnavailableNote}">
                          <TextBlock FontSize="12"
                                     Foreground="#F2E5CF"
                                     TextWrapping="Wrap"
                                     Text="{Binding SelectedModActionUnavailableNote}" />
                        </Border>

                        <StackPanel Spacing="6">
                          <Border Background="#20262D"
                                  Height="1" />
                          <Grid ColumnDefinitions="84,*"
                                RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                            <TextBlock Classes="detail-label"
                                       Text="Status" />
                            <TextBlock Grid.Column="1"
                                       Classes="detail-value"
                                       Margin="8,0,0,0"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModInstallState}" />

                            <TextBlock Grid.Row="1"
                                       Classes="detail-label"
                                       Margin="0,6,0,0"
                                       Text="Versions" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Classes="detail-value"
                                       Margin="8,6,0,0"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModVersions}" />

                            <TextBlock Grid.Row="2"
                                       Classes="detail-label"
                                       Margin="0,6,0,0"
                                       Text="Cached" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Classes="detail-value"
                                       Margin="8,6,0,0"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModCacheState}" />

                            <TextBlock Grid.Row="3"
                                       Classes="detail-label"
                                       Margin="0,6,0,0"
                                       Text="Compatibility" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="1"
                                       Classes="detail-value"
                                       Margin="8,6,0,0"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModCompatibility}" />

                            <TextBlock Grid.Row="4"
                                       Classes="detail-label"
                                       Margin="0,6,0,0"
                                       Text="Type" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Classes="detail-value"
                                       Margin="8,6,0,0"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModModuleKind}" />

                            <TextBlock Grid.Row="5"
                                       Classes="detail-label"
                                       Margin="0,6,0,0"
                                       Text="License" />
                            <TextBlock Grid.Row="5"
                                       Grid.Column="1"
                                       Classes="detail-value"
                                       Margin="8,6,0,0"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModLicense}" />

                            <TextBlock Grid.Row="6"
                                       Classes="detail-label"
                                       Margin="0,6,0,0"
                                       Text="Released" />
                            <TextBlock Grid.Row="6"
                                       Grid.Column="1"
                                       Classes="detail-value"
                                       Margin="8,6,0,0"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModReleaseDate}" />

                            <TextBlock Grid.Row="7"
                                       Classes="detail-label"
                                       Margin="0,6,0,0"
                                       Text="Downloads" />
                            <TextBlock Grid.Row="7"
                                       Grid.Column="1"
                                       Classes="detail-value"
                                       Margin="8,6,0,0"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModDownloadCount}" />

                            <TextBlock Grid.Row="8"
                                       Classes="detail-label"
                                       Margin="0,6,0,0"
                                       Text="Size" />
                            <TextBlock Grid.Row="8"
                                       Grid.Column="1"
                                       Classes="detail-value"
                                       Margin="8,6,0,0"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModDownloadSize}" />

                            <TextBlock Grid.Row="9"
                                       Classes="detail-label"
                                       Margin="0,6,0,0"
                                       Text="Depends" />
                            <TextBlock Grid.Row="9"
                                       Grid.Column="1"
                                       Classes="detail-value"
                                       Margin="8,6,0,0"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModDependencyCountLabel}" />

                            <TextBlock Grid.Row="10"
                                       Classes="detail-label"
                                       Margin="0,6,0,0"
                                       Text="Recommends" />
                            <TextBlock Grid.Row="10"
                                       Grid.Column="1"
                                       Classes="detail-value"
                                       Margin="8,6,0,0"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModRecommendationCountLabel}" />

                            <TextBlock Grid.Row="11"
                                       Classes="detail-label"
                                       Margin="0,6,0,0"
                                       Text="Suggests" />
                            <TextBlock Grid.Row="11"
                                       Grid.Column="1"
                                       Classes="detail-value"
                                       Margin="8,6,0,0"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModSuggestionCountLabel}" />
                          </Grid>
                        </StackPanel>
                      </StackPanel>
                    </ScrollViewer>
                  </Grid>
                </Border>
              </Grid>

              <Border Grid.Row="2"
                      Background="#161B21"
                      CornerRadius="10"
                      Padding="18"
                      IsVisible="{Binding ShowPreviewSurface}">
                <Grid RowDefinitions="Auto,*,Auto">
                  <Border Background="#1A2027"
                          CornerRadius="10"
                          Padding="14">
                    <StackPanel Spacing="4">
                      <TextBlock FontSize="16"
                                 FontWeight="SemiBold"
                                 Text="Preview &amp; Apply" />
                      <TextBlock FontSize="12"
                                 Opacity="0.72"
                                 Text="{Binding PreviewSummary}" />
                    </StackPanel>
                  </Border>

                  <Border Grid.Row="1"
                          Background="#1A2027"
                          CornerRadius="12"
                          Padding="24"
                          Margin="0,14,0,0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Top"
                          IsVisible="{Binding ShowPreviewEmptyWorkspace}">
                    <Grid ColumnDefinitions="1.1*,0.9*">
                      <StackPanel Spacing="12"
                                  HorizontalAlignment="Left"
                                  MaxWidth="640"
                                  Margin="0,0,18,0">
                        <TextBlock FontSize="28"
                                   FontWeight="SemiBold"
                                   Text="Nothing Queued Yet" />
                        <TextBlock FontSize="14"
                                   Opacity="0.82"
                                   TextWrapping="Wrap"
                                   Text="{Binding PreviewPanelGuidance}" />
                        <Border Background="#20262D"
                                CornerRadius="12"
                                Padding="16">
                          <StackPanel Spacing="8">
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="What Happens Here" />
                            <TextBlock Opacity="0.84"
                                       TextWrapping="Wrap"
                                       Text="Build a safe preflight before touching GameData. This page collects downloads, dependencies, removals, conflicts, and prompts into one review surface." />
                          </StackPanel>
                        </Border>
                      </StackPanel>

                      <WrapPanel Grid.Column="1"
                                 HorizontalAlignment="Stretch"
                                 ItemWidth="220"
                                 ItemHeight="116"
                                 Margin="0,2,0,0">
                        <Border Background="#20262D"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,0,12,12">
                          <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Downloads" />
                            <TextBlock Opacity="0.82"
                                       TextWrapping="Wrap"
                                       Text="See every archive CKAN needs before anything is applied." />
                          </StackPanel>
                        </Border>
                        <Border Background="#20262D"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,0,12,12">
                          <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Dependencies" />
                            <TextBlock Opacity="0.82"
                                       TextWrapping="Wrap"
                                       Text="Required installs are listed here so there are no hidden surprises." />
                          </StackPanel>
                        </Border>
                        <Border Background="#20262D"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,0,12,12">
                          <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Blockers" />
                            <TextBlock Opacity="0.82"
                                       TextWrapping="Wrap"
                                       Text="Conflicts and required steps appear before Apply becomes available." />
                          </StackPanel>
                        </Border>
                        <Border Background="#20262D"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,0,12,12">
                          <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Auto-Removals" />
                            <TextBlock Opacity="0.82"
                                       TextWrapping="Wrap"
                                       Text="Mods that must leave the install are called out before the queue runs." />
                          </StackPanel>
                        </Border>
                      </WrapPanel>
                    </Grid>
                  </Border>

                  <Grid Grid.Row="1"
                        ColumnDefinitions="0.92*,1.08*"
                        Margin="0,14,0,0"
                        IsVisible="{Binding ShowPreviewActiveWorkspace}">
                    <Border Background="#1A2027"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0,0,12,0">
                      <Grid RowDefinitions="Auto,*,Auto">
                        <StackPanel Spacing="5">
                          <TextBlock Classes="panel-kicker"
                                     Text="Queued Actions" />
                          <TextBlock Classes="panel-body"
                                     Opacity="0.82"
                                     TextWrapping="Wrap"
                                     IsVisible="{Binding HasQueuedActions}"
                                     Text="{Binding PreviewQueuedGuidance}" />
                        </StackPanel>

                        <Grid Grid.Row="1"
                              Margin="0,12,0,0"
                              RowDefinitions="*">
                          <ListBox ItemsSource="{Binding QueuedActions}"
                                   SelectedItem="{Binding SelectedQueuedAction}"
                                   IsVisible="{Binding HasQueuedActions}">
                            <ListBox.ItemTemplate>
                              <DataTemplate DataType="models:QueuedActionModel">
                                <Border Background="#20262D"
                                        CornerRadius="10"
                                        Margin="0,0,0,10"
                                        Padding="12">
                                  <StackPanel Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto">
                                      <TextBlock FontWeight="SemiBold"
                                                 Text="{Binding Name}" />
                                      <Border Grid.Column="1"
                                              Background="#28303A"
                                              CornerRadius="999"
                                              Padding="10,4"
                                              Margin="10,0,0,0">
                                        <TextBlock FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ActionText}" />
                                      </Border>
                                    </Grid>
                                    <TextBlock FontSize="12"
                                               Opacity="0.75"
                                               Text="{Binding Identifier}" />
                                    <TextBlock TextWrapping="Wrap"
                                               Opacity="0.84"
                                               Text="{Binding DetailText}" />
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ListBox.ItemTemplate>
                          </ListBox>

                          <Border Background="#20262D"
                                  CornerRadius="10"
                                  Padding="16"
                                  IsVisible="{Binding ShowEmptyQueueState}">
                            <StackPanel Spacing="8"
                                        VerticalAlignment="Center">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Nothing Queued Yet" />
                              <TextBlock TextWrapping="Wrap"
                                         Opacity="0.82"
                                         Text="Queue install, update, or remove actions from a selected mod to build a preflight summary before applying anything. Right-click a mod for download-only." />
                            </StackPanel>
                          </Border>
                        </Grid>

                        <WrapPanel Grid.Row="2"
                                   Margin="0,12,0,0"
                                   HorizontalAlignment="Left"
                                   ItemHeight="34"
                                   IsVisible="{Binding HasQueuedActions}">
                          <Button Classes="browser-chip"
                                  Margin="0,0,8,0"
                                  Background="#20262D"
                                  BorderBrush="#3C4754"
                                  Foreground="#E8EDF3"
                                  Command="{Binding RemoveQueuedActionCommand}"
                                  Content="Remove Selected" />
                        </WrapPanel>
                      </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#1A2027"
                            CornerRadius="10"
                            Padding="16"
                            Margin="12,0,0,0">
                      <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="12">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="panel-kicker"
                                       Text="Changeset Summary" />
                            <TextBlock Classes="panel-title"
                                       Text="{Binding PreviewOutcomeTitle}" />
                            <TextBlock Classes="panel-body"
                                       Opacity="0.76"
                                       Text="{Binding PreviewStatusLabel}" />
                          </StackPanel>

                          <Border Background="{Binding ApplyResultBackground}"
                                  BorderBrush="{Binding ApplyResultBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="10"
                                  Padding="12"
                                  IsVisible="{Binding ShowInlineApplyResult}">
                            <StackPanel Spacing="8">
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding ApplyResultTitle}" />
                              <TextBlock TextWrapping="Wrap"
                                         Opacity="0.86"
                                         Text="{Binding ApplyResultMessage}" />

                              <ItemsControl IsVisible="{Binding HasApplyResultSummaryLines}"
                                            ItemsSource="{Binding ApplyResultSummaryLines}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               Opacity="0.82"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>

                              <Border Background="#161B21"
                                      CornerRadius="8"
                                      Padding="10"
                                      IsVisible="{Binding HasApplyResultFollowUpLines}">
                                <StackPanel Spacing="6">
                                  <TextBlock FontWeight="SemiBold"
                                             Text="Follow-Up" />
                                  <ItemsControl ItemsSource="{Binding ApplyResultFollowUpLines}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <TextBlock Margin="0,0,0,4"
                                                   Opacity="0.84"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding}" />
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </Border>
                            </StackPanel>
                          </Border>

                          <Border Background="#253244"
                                  CornerRadius="10"
                                  Padding="12"
                                  IsVisible="{Binding PreviewShowsLoadingCard}">
                            <StackPanel Spacing="6">
                              <TextBlock TextWrapping="Wrap"
                                         Opacity="0.84"
                                         Text="{Binding PreviewImpactSummary}" />
                            </StackPanel>
                          </Border>

                          <Border Background="#1F3A2A"
                                  CornerRadius="10"
                                  Padding="12"
                                  IsVisible="{Binding PreviewShowsReadyCard}">
                            <StackPanel Spacing="6">
                              <TextBlock TextWrapping="Wrap"
                                         Opacity="0.84"
                                         Text="{Binding PreviewImpactSummary}" />
                            </StackPanel>
                          </Border>

                          <Border Background="#4A232A"
                                  CornerRadius="10"
                                  Padding="12"
                                  IsVisible="{Binding PreviewShowsBlockedCard}">
                            <StackPanel Spacing="6">
                              <TextBlock TextWrapping="Wrap"
                                         Opacity="0.84"
                                         Text="{Binding PreviewImpactSummary}" />
                            </StackPanel>
                          </Border>

                          <Border Background="#25303B"
                                  CornerRadius="10"
                                  Padding="12"
                                  IsVisible="{Binding PreviewShowsEmptyCard}">
                            <StackPanel Spacing="6">
                              <TextBlock TextWrapping="Wrap"
                                         Opacity="0.84"
                                         Text="{Binding PreviewImpactSummary}" />
                            </StackPanel>
                          </Border>

                          <WrapPanel ItemHeight="52"
                                     IsVisible="{Binding HasQueuedActions}">
                            <Border Classes="preview-summary-metric-card"
                                    Background="#161B21"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,8,8"
                                    Width="168">
                              <StackPanel Classes="preview-summary-metric"
                                          Spacing="3">
                                <TextBlock FontSize="11"
                                           Opacity="0.7"
                                           Text="Direct Changes" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding PreviewQueuedCountLabel}" />
                              </StackPanel>
                            </Border>
                            <Border Classes="preview-summary-metric-card"
                                    Background="#161B21"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,8,8"
                                    Width="168">
                              <StackPanel Classes="preview-summary-metric"
                                          Spacing="3">
                                <TextBlock FontSize="11"
                                           Opacity="0.7"
                                           Text="{Binding PreviewDownloadMetricTitle}" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding PreviewDownloadQueueCountLabel}" />
                              </StackPanel>
                            </Border>
                            <Border Classes="preview-summary-metric-card"
                                    Background="#161B21"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,8,8"
                                    Width="168">
                              <StackPanel Classes="preview-summary-metric"
                                          Spacing="3">
                                <TextBlock FontSize="11"
                                           Opacity="0.7"
                                           Text="Required Downloads" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding PreviewDownloadCountLabel}" />
                              </StackPanel>
                            </Border>
                            <Border Classes="preview-summary-metric-card"
                                    Background="#161B21"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,8,8"
                                    Width="168">
                              <StackPanel Classes="preview-summary-metric"
                                          Spacing="3">
                                <TextBlock FontSize="11"
                                           Opacity="0.7"
                                           Text="Auto Installs" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding PreviewDependencyCountLabel}" />
                              </StackPanel>
                            </Border>
                            <Border Classes="preview-summary-metric-card"
                                    Background="#161B21"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,8,8"
                                    Width="168">
                              <StackPanel Classes="preview-summary-metric"
                                          Spacing="3">
                                <TextBlock FontSize="11"
                                           Opacity="0.7"
                                           Text="Auto-Removals" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding PreviewAutoRemovalCountLabel}" />
                              </StackPanel>
                            </Border>
                            <Border Classes="preview-summary-metric-card"
                                    Background="#161B21"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,8,8"
                                    Width="168">
                              <StackPanel Classes="preview-summary-metric"
                                          Spacing="3">
                                <TextBlock FontSize="11"
                                           Opacity="0.7"
                                           Text="Conflicts" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding PreviewConflictCountLabel}" />
                              </StackPanel>
                            </Border>
                            <Border Classes="preview-summary-metric-card"
                                    Background="#161B21"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,8,8"
                                    Width="168">
                              <StackPanel Classes="preview-summary-metric"
                                          Spacing="3">
                                <TextBlock FontSize="11"
                                           Opacity="0.7"
                                           Text="Required Steps" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding PreviewAttentionCountLabel}" />
                              </StackPanel>
                            </Border>
                          </WrapPanel>

                          <ProgressBar Height="16"
                                       IsIndeterminate="{Binding IsPreviewLoading}"
                                       IsVisible="{Binding IsPreviewLoading}" />

                          <Border Background="#223043"
                                  BorderBrush="#496A92"
                                  BorderThickness="1"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding ShowPreviewDownloadQueueGuidance}">
                            <StackPanel Spacing="8">
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding PreviewDownloadQueueGuidanceTitle}" />
                              <TextBlock Opacity="0.86"
                                         TextWrapping="Wrap"
                                         Text="{Binding PreviewDownloadQueueGuidance}" />
                            </StackPanel>
                          </Border>

                          <Border Background="#3A1E24"
                                  BorderBrush="#934354"
                                  BorderThickness="1"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding HasPreviewConflicts}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Conflicts" />
                              <ItemsControl ItemsSource="{Binding PreviewConflicts}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>

                          <Border Background="#4A3920"
                                  BorderBrush="#9A7B37"
                                  BorderThickness="1"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding HasPreviewAttentionNotes}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Required Before Apply" />
                              <ItemsControl ItemsSource="{Binding PreviewAttentionNotes}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>

                          <Border Background="#2E3540"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding HasPreviewDownloadsRequired}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Will Download" />
                              <ItemsControl ItemsSource="{Binding PreviewDownloadsRequired}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>

                          <Border Background="#203326"
                                  BorderBrush="#3D6F4C"
                                  BorderThickness="1"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding ShowPreviewDependencyGuidance}">
                            <StackPanel Spacing="8">
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding PreviewDependencyGuidanceTitle}" />
                              <TextBlock Opacity="0.86"
                                         TextWrapping="Wrap"
                                         Text="{Binding PreviewDependencyGuidance}" />
                              <ItemsControl ItemsSource="{Binding PreviewDependencies}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <Border Background="#161B21"
                                            CornerRadius="8"
                                            Padding="10"
                                            Margin="0,0,0,6">
                                      <TextBlock TextWrapping="Wrap"
                                                 Text="{Binding}" />
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>

                          <Border Background="#161B21"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding HasPreviewAutoRemovals}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Auto-Removals" />
                              <ItemsControl ItemsSource="{Binding PreviewAutoRemovals}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>

                          <Border Background="#161B21"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding HasPreviewRecommendations}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Recommendations" />
                              <ItemsControl ItemsSource="{Binding PreviewRecommendations}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>

                          <Border Background="#161B21"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding HasPreviewSuggestions}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Suggestions" />
                              <ItemsControl ItemsSource="{Binding PreviewSuggestions}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>
                        </StackPanel>
                      </ScrollViewer>
                    </Border>
                  </Grid>

                  <Border Grid.Row="2"
                          Background="#1A2027"
                          CornerRadius="10"
                          Padding="14"
                          Margin="0,14,0,0">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock VerticalAlignment="Center"
                                 Opacity="0.82"
                                 TextWrapping="Wrap"
                                 Margin="0,0,18,0"
                                 Text="{Binding PreviewFooterNote}" />

                      <WrapPanel Grid.Column="1"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 ItemHeight="38">
                        <Button Classes="preview-action"
                                Background="#4B535D"
                                BorderBrush="#4B535D"
                                Foreground="#F4F6F8"
                                IsVisible="{Binding ShowInlineApplyResult}"
                                Command="{Binding DismissApplyResultCommand}"
                                Content="Dismiss Result" />
                        <Button Classes="preview-action"
                                Background="#26191C"
                                BorderBrush="#6B2B2B"
                                Foreground="#F4F6F8"
                                IsVisible="{Binding HasQueuedActions}"
                                Command="{Binding ClearQueueCommand}"
                                Content="Clear Queue" />
                        <Button Classes="preview-action"
                                Background="{Binding DownloadQueuedButtonBackground}"
                                BorderBrush="{Binding DownloadQueuedButtonBorderBrush}"
                                Foreground="#F4F6F8"
                                IsVisible="{Binding HasQueuedDownloadActions}"
                                Command="{Binding DownloadQueuedCommand}"
                                Content="{Binding DownloadQueuedButtonLabel}" />
                        <Button Classes="preview-action"
                                MinWidth="144"
                                Background="{Binding ApplyChangesButtonBackground}"
                                BorderBrush="{Binding ApplyChangesButtonBorderBrush}"
                                Foreground="#F4F6F8"
                                IsVisible="{Binding HasQueuedChangeActions}"
                                Command="{Binding ApplyChangesCommand}"
                                Content="Apply Changes" />
                      </WrapPanel>
                    </Grid>
                  </Border>
                </Grid>
              </Border>
            </Grid>
          </Border>

          <Border Background="#3A1E24"
                  BorderBrush="#934354"
                  BorderThickness="1"
                  CornerRadius="12"
                  Padding="24"
                  IsVisible="{Binding HasError}">
            <StackPanel Spacing="16">
              <TextBlock FontSize="24"
                         FontWeight="SemiBold"
                         Text="{Binding StageTitle}" />
              <TextBlock TextWrapping="Wrap"
                         Opacity="0.9"
                         Text="{Binding StageDescription}" />
              <Border Background="#271217"
                      CornerRadius="10"
                      Padding="16">
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding Diagnostics}" />
              </Border>
              <Button Width="170"
                      HorizontalAlignment="Left"
                      Command="{Binding RefreshCommand}"
                      Content="Retry Startup" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.RowSpan="3"
            ZIndex="100"
            Background="#C0141A22"
            IsVisible="{Binding ShowExecutionOverlay}">
      <Grid>
        <Border Background="#1A2027"
                BorderBrush="#36414E"
                BorderThickness="1"
                CornerRadius="14"
                Padding="24"
                Width="520"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsVisible="{Binding ShowExecutionProgressOverlay}">
          <StackPanel Spacing="14">
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Text="{Binding ExecutionDialogTitle}" />
            <TextBlock Opacity="0.84"
                       TextWrapping="Wrap"
                       Text="{Binding ExecutionDialogMessage}" />
            <ProgressBar Height="16"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding ExecutionProgressValue}"
                         IsVisible="{Binding HasExecutionProgressValue}" />
            <ProgressBar Height="16"
                         IsIndeterminate="True"
                         IsVisible="{Binding IsExecutionProgressIndeterminate}" />
            <TextBlock FontSize="12"
                       Opacity="0.72"
                       TextWrapping="Wrap"
                       Text="Please wait while CKAN Linux finishes downloads, file operations, and refreshes the install state." />
          </StackPanel>
        </Border>

        <Border Background="#1A2027"
                BorderBrush="{Binding ApplyResultBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="24"
                Width="560"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsVisible="{Binding ShowExecutionResultOverlay}">
          <StackPanel Spacing="14">
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Text="{Binding ApplyResultTitle}" />
            <TextBlock Opacity="0.88"
                       TextWrapping="Wrap"
                       Text="{Binding ApplyResultMessage}" />

            <ItemsControl IsVisible="{Binding HasApplyResultSummaryLines}"
                          ItemsSource="{Binding ApplyResultSummaryLines}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Margin="0,0,0,4"
                             Opacity="0.84"
                             TextWrapping="Wrap"
                             Text="{Binding}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Background="#161B21"
                    CornerRadius="10"
                    Padding="12"
                    IsVisible="{Binding HasApplyResultFollowUpLines}">
              <StackPanel Spacing="6">
                <TextBlock FontWeight="SemiBold"
                           Text="Follow-Up" />
                <ItemsControl ItemsSource="{Binding ApplyResultFollowUpLines}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Margin="0,0,0,4"
                                 Opacity="0.84"
                                 TextWrapping="Wrap"
                                 Text="{Binding}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Button Classes="preview-action"
                    HorizontalAlignment="Right"
                    Margin="0"
                    Background="#355779"
                    BorderBrush="#5A86B4"
                    Foreground="#F4F6F8"
                    Command="{Binding AcknowledgeExecutionResultCommand}"
                    Content="{Binding ExecutionResultAcknowledgeLabel}" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

  </Grid>
  </LayoutTransformControl>
</Window>
