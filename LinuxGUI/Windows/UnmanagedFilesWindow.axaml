<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CKAN.LinuxGUI.UnmanagedFilesWindow"
        x:CompileBindings="False"
        Width="860"
        Height="600"
        MinWidth="760"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Title="Unmanaged Files"
        Background="#171C22">
  <Window.Styles>
    <Style Selector="Button.dialog-action">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Background" Value="#24303B" />
      <Setter Property="BorderBrush" Value="#405061" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Foreground" Value="#F3F7FC" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Button.dialog-action:pointerover">
      <Setter Property="Background" Value="#2E3C49" />
      <Setter Property="BorderBrush" Value="#5B7084" />
    </Style>
    <Style Selector="Button.dialog-action:pressed">
      <Setter Property="Background" Value="#1D2730" />
      <Setter Property="BorderBrush" Value="#6A7F94" />
    </Style>
    <Style Selector="Button.dialog-action:disabled">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#303A44" />
      <Setter Property="Foreground" Value="#7B8794" />
      <Setter Property="Opacity" Value="1" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto"
        Margin="20">
    <StackPanel Spacing="6">
      <TextBlock FontSize="22"
                 FontWeight="SemiBold"
                 Text="Unmanaged Files" />
      <TextBlock FontSize="13"
                 Opacity="0.74"
                 TextWrapping="Wrap"
                 Text="{Binding SummaryText}" />
    </StackPanel>

    <Border Grid.Row="1"
            Margin="0,18,0,0"
            Background="#161B21"
            BorderBrush="#2B323C"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12">
      <Grid RowDefinitions="Auto,*">
        <TextBlock FontWeight="SemiBold"
                   Text="{Binding CountLabel}" />

        <ListBox Grid.Row="1"
                 Classes="utility-list"
                 Margin="0,12,0,0"
                 ItemsSource="{Binding Paths}"
                 SelectedItem="{Binding SelectedPath, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Classes="utility-list-row">
                <TextBlock Text="{Binding}" />
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <StackPanel Grid.Row="2"
                Margin="0,18,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="12">
      <Button Classes="dialog-action"
              Background="#1F3D58"
              BorderBrush="#31597B"
              Foreground="#F4F6F8"
              Click="RefreshButton_OnClick"
              Content="Refresh" />
      <Button Classes="dialog-action"
              Background="#355779"
              BorderBrush="#5A86B4"
              Foreground="#F4F6F8"
              Click="OpenSelectedButton_OnClick"
              IsEnabled="{Binding HasSelection}"
              Content="Open Selected" />
      <Button Classes="dialog-action"
              Background="#20262D"
              BorderBrush="#39424E"
              Foreground="#F4F6F8"
              Click="CloseButton_OnClick"
              Content="Close" />
    </StackPanel>
  </Grid>
</Window>
