<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CKAN.LinuxGUI.DownloadStatisticsWindow"
        x:CompileBindings="False"
        Width="720"
        Height="540"
        MinWidth="640"
        MinHeight="440"
        WindowStartupLocation="CenterOwner"
        Title="Download Statistics"
        Background="#171C22">
  <Window.Styles>
    <Style Selector="Button.dialog-action">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Background" Value="#24303B" />
      <Setter Property="BorderBrush" Value="#405061" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Foreground" Value="#F3F7FC" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Button.dialog-action:pointerover">
      <Setter Property="Background" Value="#2E3C49" />
      <Setter Property="BorderBrush" Value="#5B7084" />
    </Style>
    <Style Selector="Button.dialog-action:pressed">
      <Setter Property="Background" Value="#1D2730" />
      <Setter Property="BorderBrush" Value="#6A7F94" />
    </Style>
    <Style Selector="Button.dialog-action:disabled">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#303A44" />
      <Setter Property="Foreground" Value="#7B8794" />
      <Setter Property="Opacity" Value="1" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto"
        Margin="20">
    <StackPanel Spacing="6">
      <TextBlock FontSize="22"
                 FontWeight="SemiBold"
                 Text="Download Statistics" />
      <TextBlock FontSize="13"
                 Opacity="0.74"
                 TextWrapping="Wrap"
                 Text="{Binding SummaryText}" />
    </StackPanel>

    <Border Grid.Row="1"
            Margin="0,18,0,0"
            Background="#161B21"
            BorderBrush="#2B323C"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12">
      <Grid RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock FontWeight="SemiBold"
                     Text="Host" />
          <TextBlock Grid.Column="1"
                     HorizontalAlignment="Right"
                     FontWeight="SemiBold"
                     Text="Cached Size" />
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Margin="0,12,0,0">
          <ItemsControl ItemsSource="{Binding Rows}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border BorderBrush="#242B33"
                        BorderThickness="0,0,0,1"
                        Padding="0,10">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding Host}" />
                    <TextBlock Grid.Column="1"
                               Opacity="0.78"
                               Text="{Binding SizeLabel}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <StackPanel Grid.Row="2"
                Margin="0,18,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="12">
      <Button Classes="dialog-action"
              Background="#20262D"
              BorderBrush="#39424E"
              Foreground="#F4F6F8"
              Click="CloseButton_OnClick"
              Content="Close" />
    </StackPanel>
  </Grid>
</Window>
