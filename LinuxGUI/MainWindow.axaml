<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CKAN.LinuxGUI"
        xmlns:models="using:CKAN.App.Models"
        xmlns:media="using:Avalonia.Media"
        mc:Ignorable="d"
        x:Class="CKAN.LinuxGUI.MainWindow"
        x:Name="MainWindowRoot"
        KeyDown="Window_OnKeyDown"
        x:DataType="vm:MainWindowViewModel"
        Width="1200"
        Height="760"
        MinWidth="1040"
        MinHeight="700"
        Title="CKAN Linux"
        FontFamily="Inter, Noto Sans, Segoe UI, Arial"
        Background="#171C22">
  <Window.Styles>
    <Style Selector="ToggleButton.toolbar-chip">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="86" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Margin" Value="0,0,8,8" />
    </Style>
    <Style Selector="Button.toolbar-chip">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Margin" Value="0,0,8,8" />
    </Style>
    <Style Selector="Button.preview-action">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="MinWidth" Value="132" />
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="StackPanel.preview-summary-metric">
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.preview-summary-metric-card">
      <Setter Property="Height" Value="52" />
    </Style>
    <Style Selector="ToggleButton.browser-chip">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="#161B21" />
      <Setter Property="BorderBrush" Value="#34404C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Button.browser-chip">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="#161B21" />
      <Setter Property="BorderBrush" Value="#34404C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Border.browser-chip">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#34404C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Button.column-sort-header">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Foreground" Value="#D7E0EA" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="ToggleButton.filter-menu-item">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="Background" Value="#5B6068" />
      <Setter Property="BorderBrush" Value="#6A7079" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="ToggleButton.filter-menu-item:pointerover">
      <Setter Property="Background" Value="#666C75" />
      <Setter Property="BorderBrush" Value="#7A828D" />
    </Style>
    <Style Selector="ToggleButton.filter-menu-item:checked">
      <Setter Property="Background" Value="#8A1BB6" />
      <Setter Property="BorderBrush" Value="#B61BD1" />
    </Style>
    <Style Selector="ToggleButton.sort-menu-item">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="Background" Value="#161B21" />
      <Setter Property="BorderBrush" Value="#2B323C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="ToggleButton.sort-menu-item:checked">
      <Setter Property="Background" Value="#26303A" />
      <Setter Property="BorderBrush" Value="#4A5563" />
    </Style>
    <Style Selector="ToggleButton.details-section-chip">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Background" Value="#161B21" />
      <Setter Property="BorderBrush" Value="#2B323C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ToggleButton.details-section-chip:checked">
      <Setter Property="Background" Value="#B61BD1" />
      <Setter Property="BorderBrush" Value="#B61BD1" />
    </Style>
    <Style Selector="ContextMenu.mod-row-menu /template/ Border">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#39424E" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>
    <Style Selector="MenuItem.mod-row-menu-item">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="Foreground" Value="#F4F6F8" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,8" />
    </Style>
    <Style Selector="MenuItem.mod-row-menu-item:pointerover">
      <Setter Property="Background" Value="#2A323C" />
      <Setter Property="BorderBrush" Value="#475C73" />
    </Style>
    <Style Selector="Menu.app-menu-bar">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#F4F6F8" />
    </Style>
    <Style Selector="Menu.app-menu-bar > MenuItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#F4F6F8" />
      <Setter Property="Padding" Value="10,6" />
    </Style>
    <Style Selector="Menu.app-menu-bar > MenuItem:selected">
      <Setter Property="Background" Value="#2A323C" />
    </Style>
    <Style Selector="MenuItem.app-menu-item">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="Foreground" Value="#F4F6F8" />
      <Setter Property="Padding" Value="12,8" />
    </Style>
    <Style Selector="MenuItem.app-menu-item:pointerover">
      <Setter Property="Background" Value="#2A323C" />
    </Style>
    <Style Selector="Button.surface-view-tab">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="MinWidth" Value="96" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="ListBox#ModsListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="ScrollViewer.AllowAutoHide" Value="False" />
    </Style>
    <Style Selector="ListBox#ModsListBox > ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,12,0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox#ModsListBox > ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#B61BD1" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="ListBox#ModsListBox ScrollBar:vertical">
      <Setter Property="Width" Value="10" />
      <Setter Property="MinWidth" Value="10" />
      <Setter Property="Margin" Value="4,2,2,2" />
    </Style>
    <Style Selector="ListBox#ModsListBox ScrollBar:vertical:pointerover">
      <Setter Property="Width" Value="10" />
      <Setter Property="MinWidth" Value="10" />
      <Setter Property="Margin" Value="4,2,2,2" />
    </Style>
    <Style Selector="ListBox#ModsListBox ScrollBar:vertical:expanded">
      <Setter Property="Width" Value="10" />
      <Setter Property="MinWidth" Value="10" />
      <Setter Property="Margin" Value="4,2,2,2" />
    </Style>
    <Style Selector="TextBlock.row-title">
      <Setter Property="FontSize" Value="13.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#F1F5F9" />
    </Style>
    <Style Selector="TextBlock.row-summary">
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="Foreground" Value="#D3DAE4" />
    </Style>
    <Style Selector="TextBlock.row-meta">
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="Foreground" Value="#AFB8C6" />
    </Style>
    <Style Selector="TextBlock.row-status">
      <Setter Property="FontSize" Value="10" />
      <Setter Property="Foreground" Value="#AAB5C3" />
    </Style>
    <Style Selector="TextBlock.row-number">
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Foreground" Value="#E6EDF5" />
    </Style>
    <Style Selector="TextBlock.row-compat">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#F1F6FB" />
    </Style>
    <Style Selector="TextBlock.row-version-primary">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#F3F7FC" />
    </Style>
    <Style Selector="TextBlock.row-version-secondary">
      <Setter Property="FontSize" Value="10" />
      <Setter Property="Foreground" Value="#BBC6D3" />
    </Style>
    <Style Selector="TextBlock.panel-kicker">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Foreground" Value="#93A0AF" />
    </Style>
    <Style Selector="TextBlock.panel-title">
      <Setter Property="FontSize" Value="17" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#F3F6FA" />
    </Style>
    <Style Selector="TextBlock.panel-body">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="#D6DEE8" />
    </Style>
    <Style Selector="TextBlock.panel-meta">
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="Foreground" Value="#BCC6D3" />
    </Style>
    <Style Selector="TextBlock.detail-label">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Foreground" Value="#92A0AF" />
    </Style>
    <Style Selector="TextBlock.detail-value">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="#EDF2F7" />
    </Style>
  </Window.Styles>
  <LayoutTransformControl HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">
    <LayoutTransformControl.LayoutTransform>
      <media:ScaleTransform ScaleX="{Binding AppliedUiScaleFactor}"
                            ScaleY="{Binding AppliedUiScaleFactor}" />
    </LayoutTransformControl.LayoutTransform>
  <Grid HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        RowDefinitions="Auto,Auto,*"
        Background="#171C22">
    <Border Background="#20262D"
            Padding="16,10"
            IsVisible="{Binding ShowLegacyHeader}">
      <Grid ColumnDefinitions="Auto,*,Auto"
            VerticalAlignment="Center">
        <Menu Classes="app-menu-bar"
              VerticalAlignment="Center">
          <MenuItem Header="File">
            <MenuItem Classes="app-menu-item"
                      Header="Manage game instances"
                      Click="ManageGameInstancesMenuItem_OnClick" />
            <Separator />
            <MenuItem Classes="app-menu-item"
                      Header="Open game directory"
                      Command="{Binding OpenCurrentGameDirectoryCommand}"
                      IsEnabled="{Binding HasCurrentInstance}" />
            <MenuItem Classes="app-menu-item"
                      Header="Installation history"
                      Click="InstallationHistoryMenuItem_OnClick"
                      IsEnabled="{Binding HasCurrentInstance}" />
            <MenuItem Classes="app-menu-item"
                      Header="Download statistics"
                      Click="DownloadStatisticsMenuItem_OnClick"
                      IsEnabled="{Binding HasCurrentInstance}" />
            <MenuItem Classes="app-menu-item"
                      Header="Play time"
                      Click="PlayTimeMenuItem_OnClick" />
            <MenuItem Classes="app-menu-item"
                      Header="Unmanaged files"
                      Click="UnmanagedFilesMenuItem_OnClick"
                      IsEnabled="{Binding HasCurrentInstance}" />
            <Separator />
            <MenuItem Classes="app-menu-item"
                      Header="Reload"
                      Command="{Binding RefreshCommand}" />
            <Separator />
            <MenuItem Classes="app-menu-item"
                      Header="Exit"
                      Click="ExitMenuItem_OnClick" />
          </MenuItem>
          <MenuItem Header="Settings">
            <MenuItem Classes="app-menu-item"
                      Header="Display scale"
                      Click="DisplayScaleMenuItem_OnClick" />
            <Separator />
            <MenuItem Classes="app-menu-item"
                      Header="Compatible game versions"
                      IsEnabled="{Binding HasCurrentInstance}"
                      Click="CompatibleGameVersionsMenuItem_OnClick" />
            <MenuItem Classes="app-menu-item"
                      Header="Game command lines"
                      IsEnabled="{Binding HasCurrentInstance}"
                      Click="GameCommandLinesMenuItem_OnClick" />
            <MenuItem Classes="app-menu-item"
                      Header="Plugins"
                      IsEnabled="{Binding HasCurrentInstance}"
                      Click="PluginsMenuItem_OnClick" />
            <MenuItem Classes="app-menu-item"
                      Header="Preferred hosts"
                      IsEnabled="{Binding HasCurrentInstance}"
                      Click="PreferredHostsMenuItem_OnClick" />
            <MenuItem Classes="app-menu-item"
                      Header="Installation filters"
                      IsEnabled="{Binding HasCurrentInstance}"
                      Click="InstallationFiltersMenuItem_OnClick" />
          </MenuItem>
          <MenuItem Header="Help">
            <MenuItem Classes="app-menu-item"
                      Header="CKAN user guide"
                      Command="{Binding OpenUserGuideCommand}" />
            <MenuItem Classes="app-menu-item"
                      Header="CKAN Discord"
                      Command="{Binding OpenDiscordCommand}" />
            <MenuItem Classes="app-menu-item"
                      Header="Get help for an in-game problem with mods"
                      Command="{Binding OpenGameSupportCommand}"
                      IsEnabled="{Binding HasCurrentInstance}" />
            <MenuItem Classes="app-menu-item"
                      Header="Report an issue with the CKAN client"
                      Command="{Binding ReportClientIssueCommand}" />
            <MenuItem Classes="app-menu-item"
                      Header="Report an issue with mod metadata"
                      Command="{Binding ReportMetadataIssueCommand}"
                      IsEnabled="{Binding HasCurrentInstance}" />
          </MenuItem>
        </Menu>

        <TextBlock Grid.Column="1"
                   HorizontalAlignment="Center"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Text="CKAN Linux" />

        <Border Grid.Column="2"
                Background="#11161C"
                CornerRadius="999"
                Padding="14,8"
                VerticalAlignment="Center"
                IsVisible="{Binding ShowHeaderStagePill}">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock Opacity="0.7"
                       Text="State" />
            <TextBlock FontWeight="SemiBold"
                       Text="{Binding StageTitle}" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            BorderBrush="#2F3741"
            BorderThickness="0,0,0,1"
            Padding="24,16"
            IsVisible="{Binding ShowLegacyHeader}">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <StackPanel Spacing="4">
          <TextBlock FontSize="12"
                     Opacity="0.7"
                     Text="Active Install" />
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="{Binding CurrentInstanceName}" />
          <TextBlock FontSize="12"
                     Opacity="0.72"
                     TextTrimming="CharacterEllipsis"
                     Text="{Binding CurrentInstanceContext}" />
          <TextBlock FontSize="12"
                     Opacity="0.58"
                     Text="{Binding InstanceCountLabel}" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Margin="16,0"
                    Width="280"
                    Spacing="6"
                    VerticalAlignment="Center">
          <ProgressBar Height="18"
                       Minimum="0"
                       Maximum="100"
                       Value="{Binding ProgressPercent}" />
          <TextBlock FontSize="12"
                     Opacity="0.7"
                     Text="{Binding StatusMessage}" />
        </StackPanel>

        <Button Grid.Column="2"
                Command="{Binding RefreshCommand}"
                Content="Reload Instances" />
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Background="#1E252D"
            BorderBrush="#2F3741"
            BorderThickness="0,0,0,1"
            Padding="24,8"
            IsVisible="{Binding ShowReadyHeader}">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="Auto,*,Auto"
              VerticalAlignment="Center">
          <Menu Classes="app-menu-bar"
                VerticalAlignment="Center">
            <MenuItem Header="File">
              <MenuItem Classes="app-menu-item"
                        Header="Manage game instances"
                        Click="ManageGameInstancesMenuItem_OnClick" />
              <Separator />
              <MenuItem Classes="app-menu-item"
                        Header="Open game directory"
                        Command="{Binding OpenCurrentGameDirectoryCommand}"
                        IsEnabled="{Binding HasCurrentInstance}" />
              <MenuItem Classes="app-menu-item"
                        Header="Installation history"
                        Click="InstallationHistoryMenuItem_OnClick"
                        IsEnabled="{Binding HasCurrentInstance}" />
              <MenuItem Classes="app-menu-item"
                        Header="Download statistics"
                        Click="DownloadStatisticsMenuItem_OnClick"
                        IsEnabled="{Binding HasCurrentInstance}" />
              <MenuItem Classes="app-menu-item"
                        Header="Play time"
                        Click="PlayTimeMenuItem_OnClick" />
              <MenuItem Classes="app-menu-item"
                        Header="Unmanaged files"
                        Click="UnmanagedFilesMenuItem_OnClick"
                        IsEnabled="{Binding HasCurrentInstance}" />
              <Separator />
              <MenuItem Classes="app-menu-item"
                        Header="Reload"
                        Command="{Binding RefreshCommand}" />
              <Separator />
              <MenuItem Classes="app-menu-item"
                        Header="Exit"
                        Click="ExitMenuItem_OnClick" />
            </MenuItem>
            <MenuItem Header="Settings">
              <MenuItem Classes="app-menu-item"
                        Header="Display scale"
                        Click="DisplayScaleMenuItem_OnClick" />
              <Separator />
              <MenuItem Classes="app-menu-item"
                        Header="Compatible game versions"
                        IsEnabled="{Binding HasCurrentInstance}"
                        Click="CompatibleGameVersionsMenuItem_OnClick" />
              <MenuItem Classes="app-menu-item"
                        Header="Game command lines"
                        IsEnabled="{Binding HasCurrentInstance}"
                        Click="GameCommandLinesMenuItem_OnClick" />
              <MenuItem Classes="app-menu-item"
                        Header="Plugins"
                        IsEnabled="{Binding HasCurrentInstance}"
                        Click="PluginsMenuItem_OnClick" />
              <MenuItem Classes="app-menu-item"
                        Header="Preferred hosts"
                        IsEnabled="{Binding HasCurrentInstance}"
                        Click="PreferredHostsMenuItem_OnClick" />
              <MenuItem Classes="app-menu-item"
                        Header="Installation filters"
                        IsEnabled="{Binding HasCurrentInstance}"
                        Click="InstallationFiltersMenuItem_OnClick" />
            </MenuItem>
            <MenuItem Header="Help">
              <MenuItem Classes="app-menu-item"
                        Header="CKAN user guide"
                        Command="{Binding OpenUserGuideCommand}" />
              <MenuItem Classes="app-menu-item"
                        Header="CKAN Discord"
                        Command="{Binding OpenDiscordCommand}" />
              <MenuItem Classes="app-menu-item"
                        Header="Get help for an in-game problem with mods"
                        Command="{Binding OpenGameSupportCommand}"
                        IsEnabled="{Binding HasCurrentInstance}" />
              <MenuItem Classes="app-menu-item"
                        Header="Report an issue with the CKAN client"
                        Command="{Binding ReportClientIssueCommand}" />
              <MenuItem Classes="app-menu-item"
                        Header="Report an issue with mod metadata"
                        Command="{Binding ReportMetadataIssueCommand}"
                        IsEnabled="{Binding HasCurrentInstance}" />
            </MenuItem>
          </Menu>

          <Grid Grid.Column="1"
                Margin="18,0,0,0"
                ColumnDefinitions="Auto,Auto,*"
                VerticalAlignment="Center">
            <TextBlock FontSize="12"
                       Opacity="0.68"
                       VerticalAlignment="Center"
                       Text="Current Install" />
            <TextBlock Grid.Column="1"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       IsVisible="{Binding ShowPassiveHeaderInstanceLabel}"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding CurrentInstanceName}" />
            <ComboBox Grid.Column="1"
                      MinWidth="220"
                      Margin="10,0,0,0"
                      VerticalAlignment="Center"
                      IsVisible="{Binding ShowHeaderInstanceSwitcher}"
                      ItemsSource="{Binding Instances}"
                      SelectedItem="{Binding SelectedInstance}"
                      SelectionChanged="HeaderInstanceSwitcher_OnSelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate DataType="models:InstanceSummary">
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Grid.Column="2"
                       FontSize="12"
                       Margin="10,0,0,0"
                       Opacity="0.72"
                       VerticalAlignment="Center"
                       MaxLines="1"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding CurrentInstanceContext}" />
          </Grid>

          <Border Grid.Column="2"
                  Background="{Binding StatusSurfaceBackground}"
                  BorderBrush="{Binding StatusSurfaceBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="10"
                  Padding="10,7"
                  Width="220"
                  IsVisible="{Binding ShowReadyStatusSurface}"
                  VerticalAlignment="Center">
            <StackPanel Spacing="5">
              <ProgressBar Height="4"
                           Minimum="0"
                           Maximum="100"
                           Value="{Binding ProgressPercent}" />
              <TextBlock FontSize="12"
                         Opacity="0.74"
                         TextTrimming="CharacterEllipsis"
                         MaxLines="1"
                         Text="{Binding StatusMessage}" />
            </StackPanel>
          </Border>

        </Grid>
      </StackPanel>
    </Border>

    <Grid Grid.Row="2"
          ColumnDefinitions="Auto,*"
          Margin="16">
      <Border Background="#161B21"
              BorderBrush="#2B323C"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16"
              Margin="0"
              Width="{Binding LegacySidebarWidth}"
              IsVisible="{Binding ShowLegacyShell}">
        <Grid RowDefinitions="*,Auto">
          <Grid Grid.Row="0">
            <Grid RowDefinitions="Auto,Auto,*,Auto"
                  IsVisible="{Binding ShowStartupInstancePanel}">
              <TextBlock FontSize="18"
                         FontWeight="SemiBold"
                         Text="Your KSP Installs" />

              <TextBlock Grid.Row="1"
                         Margin="0,8,0,0"
                         FontSize="12"
                         Opacity="0.7"
                         Text="{Binding SelectedActionHint}" />

              <ListBox Grid.Row="2"
                       Margin="0,16,0,16"
                       ItemsSource="{Binding Instances}"
                       SelectedItem="{Binding SelectedInstance}">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="models:InstanceSummary">
                    <Border Padding="10"
                            Margin="0,0,0,8"
                            Background="#1D242C"
                            CornerRadius="8">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                          <TextBlock FontWeight="SemiBold"
                                     Text="{Binding Name}" />
                          <TextBlock FontSize="12"
                                     Opacity="0.75"
                                     Text="{Binding GameName}" />
                          <TextBlock FontSize="12"
                                     Opacity="0.75"
                                     Text="{Binding GameDir}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#2A6B4A"
                                CornerRadius="999"
                                Padding="10,4"
                                VerticalAlignment="Top"
                                IsVisible="{Binding IsCurrent}">
                          <TextBlock FontSize="11"
                                     FontWeight="SemiBold"
                                     Text="Current" />
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Button Grid.Row="3"
                      Command="{Binding SetCurrentInstanceCommand}"
                      Content="{Binding SelectedActionLabel}" />
            </Grid>

            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
                  IsVisible="{Binding ShowReadyInstancePanel}">
              <TextBlock FontSize="18"
                         FontWeight="SemiBold"
                         Text="Switch Install" />

              <TextBlock Grid.Row="1"
                         Margin="0,8,0,0"
                         FontSize="12"
                         Opacity="0.72"
                         TextWrapping="Wrap"
                         Text="{Binding ReadyInstanceHint}" />

              <Border Grid.Row="2"
                      Background="#20262D"
                      CornerRadius="10"
                      Padding="14"
                      Margin="0,14,0,0"
                      IsVisible="{Binding ShowSwitchSelectedInstanceAction}">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="3">
                      <TextBlock FontSize="11"
                                 Opacity="0.68"
                                 Text="{Binding SelectedInstanceContextTitle}" />
                      <TextBlock FontWeight="SemiBold"
                                 Text="{Binding SelectedInstanceNameLabel}" />
                      <TextBlock FontSize="12"
                                 Opacity="0.74"
                                 Text="{Binding SelectedInstanceGameNameLabel}" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Background="#2A6B4A"
                            CornerRadius="999"
                            Padding="10,4"
                            VerticalAlignment="Top"
                            IsVisible="{Binding SelectedInstanceIsCurrent}">
                      <TextBlock FontSize="11"
                                 FontWeight="SemiBold"
                                 Text="Current" />
                    </Border>
                  </Grid>

                  <TextBlock FontSize="12"
                             Opacity="0.74"
                             TextWrapping="Wrap"
                             Text="{Binding SelectedInstanceGameDirLabel}" />
                </StackPanel>
              </Border>

              <ListBox Grid.Row="3"
                       Margin="0,14,0,0"
                       MaxHeight="260"
                       ItemsSource="{Binding Instances}"
                       SelectedItem="{Binding SelectedInstance}">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="models:InstanceSummary">
                    <Border Padding="10"
                            Margin="0,0,0,8"
                            Background="#1D242C"
                            CornerRadius="8">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="3">
                          <TextBlock FontWeight="SemiBold"
                                     Text="{Binding Name}" />
                          <TextBlock FontSize="12"
                                     Opacity="0.75"
                                     Text="{Binding GameName}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#2A6B4A"
                                CornerRadius="999"
                                Padding="10,4"
                                VerticalAlignment="Center"
                                IsVisible="{Binding IsCurrent}">
                          <TextBlock FontSize="11"
                                     FontWeight="SemiBold"
                                     Text="Current" />
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <StackPanel Grid.Row="4"
                          Margin="0,14,0,0"
                          Spacing="8">
                <TextBlock FontSize="12"
                           Opacity="0.72"
                           IsVisible="{Binding SelectedInstanceIsCurrent}"
                           Text="You are already browsing this install." />
                <Button IsVisible="{Binding ShowSwitchSelectedInstanceAction}"
                        Command="{Binding SetCurrentInstanceCommand}"
                        Content="Switch Install" />
              </StackPanel>
            </Grid>
          </Grid>

          <Border Grid.Row="1"
                  Background="#20262D"
                  CornerRadius="10"
                  Padding="14"
                  Margin="0,16,0,0">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                  <TextBlock FontSize="15"
                             FontWeight="SemiBold"
                             Text="Display Scale" />
                  <TextBlock FontSize="12"
                             Opacity="0.72"
                             TextWrapping="Wrap"
                             Text="{Binding DisplayScaleSummary}" />
                </StackPanel>
                <Button Grid.Column="1"
                        VerticalAlignment="Top"
                        Command="{Binding ToggleDisplaySettingsCommand}"
                        Content="{Binding DisplaySettingsToggleLabel}" />
              </Grid>

              <StackPanel IsVisible="{Binding ShowDisplaySettings}"
                          Spacing="10">
                <Slider Minimum="{Binding UiScaleMinimum}"
                        Maximum="{Binding UiScaleMaximum}"
                        TickFrequency="5"
                        TickPlacement="Outside"
                        IsSnapToTickEnabled="True"
                        SmallChange="5"
                        LargeChange="5"
                        Value="{Binding PendingUiScalePercent}" />

                <Grid ColumnDefinitions="Auto,*,Auto">
                  <TextBlock FontSize="12"
                             Opacity="0.68"
                             Text="{Binding UiScaleMinimum}" />
                  <TextBlock Grid.Column="1"
                             HorizontalAlignment="Center"
                             FontWeight="SemiBold"
                             Text="{Binding PendingUiScaleLabel}" />
                  <TextBlock Grid.Column="2"
                             FontSize="12"
                             Opacity="0.68"
                             Text="{Binding UiScaleMaximum}" />
                </Grid>

                <TextBlock FontSize="12"
                           Opacity="0.72"
                           TextWrapping="Wrap"
                           Text="{Binding DisplayScaleHint}" />

                <WrapPanel>
                  <Button Classes="toolbar-chip"
                          IsVisible="{Binding ShowResetUiScaleAction}"
                          Command="{Binding ResetUiScaleCommand}"
                          Content="Reset to 100%" />
                  <Button Classes="toolbar-chip"
                          IsVisible="{Binding UiScaleNeedsRestart}"
                          Command="{Binding RestartToApplyUiScaleCommand}"
                          Content="Restart to Apply" />
                </WrapPanel>
              </StackPanel>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Background="Transparent"
              BorderBrush="Transparent"
              BorderThickness="0"
              CornerRadius="0"
              Padding="0"
              Margin="0">
        <Grid>
          <Border Background="#202930"
                  CornerRadius="12"
                  Padding="16"
                  IsVisible="{Binding IsLoading}">
            <StackPanel Spacing="14"
                        VerticalAlignment="Center">
              <TextBlock FontSize="24"
                         FontWeight="SemiBold"
                         Text="{Binding StageTitle}" />
              <TextBlock Opacity="0.8"
                         TextWrapping="Wrap"
                         Text="{Binding StageDescription}" />
              <ProgressBar Height="20"
                           Minimum="0"
                           Maximum="100"
                           Value="{Binding ProgressPercent}" />
              <TextBlock FontSize="13"
                         Opacity="0.8"
                         Text="{Binding StatusMessage}" />
            </StackPanel>
          </Border>

          <Border Background="#202930"
                  CornerRadius="12"
                  Padding="16"
                  IsVisible="{Binding IsEmpty}">
            <StackPanel Spacing="16">
              <TextBlock FontSize="24"
                         FontWeight="SemiBold"
                         Text="{Binding StageTitle}" />
              <TextBlock TextWrapping="Wrap"
                         Opacity="0.85"
                         Text="{Binding StageDescription}" />
              <Border Background="#161B21"
                      CornerRadius="10"
                      Padding="16">
                <TextBlock TextWrapping="Wrap"
                           Text="Register a KSP install, then reload to open the mod browser." />
              </Border>
              <Button Width="170"
                      HorizontalAlignment="Left"
                      Command="{Binding RefreshCommand}"
                      Content="Scan Again" />
            </StackPanel>
          </Border>

          <Border Background="#202930"
                  CornerRadius="12"
                  Padding="16"
                  IsVisible="{Binding NeedsSelection}">
            <StackPanel Spacing="18">
              <TextBlock FontSize="24"
                         FontWeight="SemiBold"
                         Text="{Binding StageTitle}" />
              <TextBlock TextWrapping="Wrap"
                         Opacity="0.85"
                         Text="{Binding StageDescription}" />
              <Border Background="#161B21"
                      CornerRadius="10"
                      Padding="16">
                <StackPanel Spacing="10">
                  <TextBlock FontSize="12"
                             Opacity="0.7"
                             Text="Selected Install" />
                  <TextBlock TextWrapping="Wrap"
                             Text="{Binding SelectedInstanceSummary}" />
                </StackPanel>
              </Border>
              <Button Width="230"
                      HorizontalAlignment="Left"
                      Command="{Binding SetCurrentInstanceCommand}"
                      Content="{Binding SelectedActionLabel}" />
            </StackPanel>
          </Border>

          <Border Background="#202930"
                  CornerRadius="12"
                  Padding="16"
                  IsVisible="{Binding IsReady}">
            <Grid RowDefinitions="Auto,Auto,*">
              <Border Background="#4A3920"
                      BorderBrush="#9A7B37"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="14"
                      Margin="0,0,0,14"
                      IsVisible="{Binding ShowUiScaleRestartStrip}">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <TextBlock VerticalAlignment="Center"
                             FontSize="12"
                             Opacity="0.86"
                             Text="{Binding UiScaleRestartStripText}" />
                  <Button Grid.Column="1"
                          Margin="10,0,0,0"
                          Command="{Binding RestartToApplyUiScaleCommand}"
                          Content="Restart Now" />
                  <Button Grid.Column="2"
                          Margin="10,0,0,0"
                          Command="{Binding DismissUiScaleRestartStripCommand}"
                          Content="Dismiss" />
                </Grid>
              </Border>

              <Border Grid.Row="1"
                      Background="#14191F"
                      BorderBrush="#2B323C"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="6"
                      Margin="0,0,0,14"
                      HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal"
                            Spacing="6">
                  <Button Classes="surface-view-tab"
                          Background="{Binding BrowseSurfaceButtonBackground}"
                          BorderBrush="{Binding BrowseSurfaceButtonBorderBrush}"
                          Foreground="#F4F6F8"
                          Command="{Binding ShowBrowseSurfaceCommand}"
                          Content="Browse" />
                  <Button Classes="surface-view-tab"
                          Background="{Binding PreviewSurfaceButtonBackground}"
                          BorderBrush="{Binding PreviewSurfaceButtonBorderBrush}"
                          Foreground="#F4F6F8"
                          Command="{Binding ShowPreviewSurfaceCommand}"
                          Content="{Binding PreviewSurfaceButtonLabel}" />
                </StackPanel>
              </Border>

              <Grid Grid.Row="2"
                    ColumnDefinitions="*,Auto"
                    IsVisible="{Binding ShowBrowseSurface}">
                <Border Background="#161B21"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,0,6,0">
                  <Grid RowDefinitions="Auto,*,Auto">
                    <Grid ColumnDefinitions="*,Auto,Auto"
                          Margin="0,0,0,8">
                      <TextBox x:Name="SearchTextBox"
                               MinHeight="34"
                               Padding="12,6"
                               Watermark="Search mods by name, author, or identifier"
                               Text="{Binding ModSearchText}" />
                      <Border Grid.Column="1"
                              Classes="browser-chip"
                              Background="#20262D"
                              Margin="8,0,0,0"
                              VerticalAlignment="Center">
                        <TextBlock FontSize="12"
                                   Opacity="0.8"
                                   Text="{Binding ModCountLabel}" />
                      </Border>
                      <Button Grid.Column="2"
                              x:Name="MoreFiltersButton"
                              Classes="browser-chip"
                              Margin="8,0,0,0"
                              MinWidth="112"
                              Background="{Binding MoreFiltersButtonBackground}"
                              BorderBrush="{Binding MoreFiltersButtonBorderBrush}"
                              Foreground="#F4F6F8"
                              Command="{Binding ToggleAdvancedFiltersCommand}"
                              HorizontalAlignment="Right"
                              Content="{Binding MoreFiltersLabel}" />

                      <Popup x:Name="AdvancedFiltersPopup"
                             IsOpen="{Binding ShowAdvancedFilters, Mode=TwoWay}"
                             Placement="Bottom"
                             PlacementTarget="{Binding #MoreFiltersButton}"
                             HorizontalOffset="-206"
                             VerticalOffset="8"
                             IsLightDismissEnabled="True"
                             OverlayDismissEventPassThrough="True"
                             OverlayInputPassThroughElement="{Binding #MoreFiltersButton}"
                             Opened="AdvancedFiltersPopup_OnOpened">
                        <Border Background="#20262D"
                                BorderBrush="#39424E"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16"
                                Width="560"
                                BoxShadow="0 18 36 0 #66000000">
                          <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="Auto"
                                  HorizontalAlignment="Right">
                              <Button Width="88"
                                      Opacity="{Binding ClearFiltersButtonOpacity}"
                                      IsEnabled="{Binding HasActiveFilters}"
                                      Background="{Binding ClearFiltersButtonBackground}"
                                      BorderBrush="{Binding ClearFiltersButtonBorderBrush}"
                                      Foreground="#F4F6F8"
                                      Command="{Binding ClearFiltersCommand}"
                                      Content="Clear All" />
                            </Grid>
                            <Grid ColumnDefinitions="*,*">
                              <StackPanel Grid.Column="0"
                                          Spacing="6">
                                <TextBlock FontSize="11"
                                           Opacity="0.62"
                                           Text="State" />
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterCompatibleOnly}"
                                              Content="{Binding CompatibleFilterLabel}" />
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterInstalledOnly}"
                                              Content="{Binding InstalledFilterLabel}" />
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterUpdatableOnly}"
                                              Content="{Binding UpdatableFilterLabel}" />
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterHasReplacementOnly}"
                                              Content="{Binding ReplaceableFilterLabel}" />
                              </StackPanel>
                              <StackPanel Grid.Column="1"
                                          Margin="12,0,0,0">
                                <TextBlock FontSize="11"
                                           Opacity="0.62"
                                           Text="Availability" />
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterCachedOnly}"
                                              Content="{Binding CachedFilterLabel}" />
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterUncachedOnly}"
                                              Content="{Binding UncachedFilterLabel}" />
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterNotInstalledOnly}"
                                              Content="{Binding NotInstalledFilterLabel}" />
                                <ToggleButton Classes="filter-menu-item"
                                              IsChecked="{Binding FilterIncompatibleOnly}"
                                              Content="{Binding IncompatibleFilterLabel}" />
                              </StackPanel>
                            </Grid>
                            <Border Background="#2B323C"
                                    Height="1" />
                            <Grid ColumnDefinitions="*,*">
                              <TextBox x:Name="AdvancedAuthorFilterTextBox"
                                       Watermark="Author contains"
                                       Text="{Binding AdvancedAuthorFilter}" />
                              <TextBox Grid.Column="1"
                                       Margin="12,0,0,0"
                                       Watermark="Compatibility contains"
                                       Text="{Binding AdvancedCompatibilityFilter}" />
                            </Grid>
                            <TextBlock FontSize="12"
                                       Opacity="0.72"
                                       TextWrapping="Wrap"
                                       Text="{Binding AdvancedFilterSummary}" />
                          </StackPanel>
                        </Border>
                      </Popup>
                    </Grid>

                    <Border Grid.Row="1"
                            Background="#14191F"
                            CornerRadius="8"
                            BorderBrush="#2B323C"
                            BorderThickness="1"
                            Padding="8"
                            ClipToBounds="True">
                      <Grid ClipToBounds="True">
                        <StackPanel Spacing="8"
                                    VerticalAlignment="Top"
                                    IsVisible="{Binding ShowCatalogSkeleton}">
                          <Border Background="#1B2128"
                                  CornerRadius="8"
                                  Padding="12"
                                  Margin="0,0,0,2">
                            <Grid ColumnDefinitions="5,*,216">
                              <Border Background="#24588A"
                                      CornerRadius="8,0,0,8" />
                              <StackPanel Grid.Column="1"
                                          Margin="12,0,12,0"
                                          Spacing="8">
                                <Border Background="#2A323C"
                                        CornerRadius="6"
                                        Height="16"
                                        Width="168"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="108"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="292"
                                        HorizontalAlignment="Left" />
                              </StackPanel>
                              <Grid Grid.Column="2"
                                    ColumnDefinitions="72,48,*"
                                    RowDefinitions="Auto,Auto,Auto">
                                <Border Grid.Row="0"
                                        Background="#2A323C"
                                        CornerRadius="6"
                                        Height="13"
                                        Width="64"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Row="1"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="74"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Row="2"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="68"
                                        HorizontalAlignment="Left" />

                                <Border Grid.Column="1"
                                        Grid.Row="0"
                                        Margin="10,0,0,0"
                                        Background="#2A323C"
                                        CornerRadius="6"
                                        Height="13"
                                        Width="40"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Column="1"
                                        Grid.Row="1"
                                        Margin="10,0,0,0"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="36"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Column="1"
                                        Grid.Row="2"
                                        Margin="10,0,0,0"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="42"
                                        HorizontalAlignment="Left" />

                                <Border Grid.Column="2"
                                        Grid.Row="0"
                                        Margin="10,0,0,0"
                                        Background="#2A323C"
                                        CornerRadius="6"
                                        Height="13"
                                        Width="58"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Column="2"
                                        Grid.Row="1"
                                        Margin="10,0,0,0"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="62"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Column="2"
                                        Grid.Row="2"
                                        Margin="10,0,0,0"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="60"
                                        HorizontalAlignment="Left" />
                              </Grid>
                            </Grid>
                          </Border>

                          <Border Background="#1B2128"
                                  CornerRadius="8"
                                  Padding="12"
                                  Margin="0,0,0,2"
                                  Opacity="0.94">
                            <Grid ColumnDefinitions="5,*,216">
                              <Border Background="#39424E"
                                      CornerRadius="8,0,0,8" />
                              <StackPanel Grid.Column="1"
                                          Margin="12,0,12,0"
                                          Spacing="8">
                                <Border Background="#2A323C"
                                        CornerRadius="6"
                                        Height="16"
                                        Width="190"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="96"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="252"
                                        HorizontalAlignment="Left" />
                              </StackPanel>
                              <Grid Grid.Column="2"
                                    ColumnDefinitions="72,48,*"
                                    RowDefinitions="Auto,Auto,Auto">
                                <Border Grid.Row="0"
                                        Background="#2A323C"
                                        CornerRadius="6"
                                        Height="13"
                                        Width="62"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Row="1"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="70"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Row="2"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="64"
                                        HorizontalAlignment="Left" />

                                <Border Grid.Column="1"
                                        Grid.Row="0"
                                        Margin="10,0,0,0"
                                        Background="#2A323C"
                                        CornerRadius="6"
                                        Height="13"
                                        Width="36"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Column="1"
                                        Grid.Row="1"
                                        Margin="10,0,0,0"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="34"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Column="1"
                                        Grid.Row="2"
                                        Margin="10,0,0,0"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="40"
                                        HorizontalAlignment="Left" />

                                <Border Grid.Column="2"
                                        Grid.Row="0"
                                        Margin="10,0,0,0"
                                        Background="#2A323C"
                                        CornerRadius="6"
                                        Height="13"
                                        Width="56"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Column="2"
                                        Grid.Row="1"
                                        Margin="10,0,0,0"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="58"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Column="2"
                                        Grid.Row="2"
                                        Margin="10,0,0,0"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="54"
                                        HorizontalAlignment="Left" />
                              </Grid>
                            </Grid>
                          </Border>

                          <Border Background="#1B2128"
                                  CornerRadius="8"
                                  Padding="12"
                                  Margin="0,0,0,2"
                                  Opacity="0.92">
                            <Grid ColumnDefinitions="5,*,216">
                              <Border Background="#2E7C59"
                                      CornerRadius="8,0,0,8" />
                              <StackPanel Grid.Column="1"
                                          Margin="12,0,12,0"
                                          Spacing="8">
                                <Border Background="#2A323C"
                                        CornerRadius="6"
                                        Height="16"
                                        Width="214"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="118"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="274"
                                        HorizontalAlignment="Left" />
                              </StackPanel>
                              <Grid Grid.Column="2"
                                    ColumnDefinitions="72,48,*"
                                    RowDefinitions="Auto,Auto,Auto">
                                <Border Grid.Row="0"
                                        Background="#2A323C"
                                        CornerRadius="6"
                                        Height="13"
                                        Width="66"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Row="1"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="72"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Row="2"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="60"
                                        HorizontalAlignment="Left" />

                                <Border Grid.Column="1"
                                        Grid.Row="0"
                                        Margin="10,0,0,0"
                                        Background="#2A323C"
                                        CornerRadius="6"
                                        Height="13"
                                        Width="38"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Column="1"
                                        Grid.Row="1"
                                        Margin="10,0,0,0"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="34"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Column="1"
                                        Grid.Row="2"
                                        Margin="10,0,0,0"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="40"
                                        HorizontalAlignment="Left" />

                                <Border Grid.Column="2"
                                        Grid.Row="0"
                                        Margin="10,0,0,0"
                                        Background="#2A323C"
                                        CornerRadius="6"
                                        Height="13"
                                        Width="54"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Column="2"
                                        Grid.Row="1"
                                        Margin="10,0,0,0"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="56"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Column="2"
                                        Grid.Row="2"
                                        Margin="10,0,0,0"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="52"
                                        HorizontalAlignment="Left" />
                              </Grid>
                            </Grid>
                          </Border>

                          <Border Background="#1B2128"
                                  CornerRadius="8"
                                  Padding="12"
                                  Margin="0,0,0,2"
                                  Opacity="0.9">
                            <Grid ColumnDefinitions="5,*,216">
                              <Border Background="#9B4559"
                                      CornerRadius="8,0,0,8" />
                              <StackPanel Grid.Column="1"
                                          Margin="12,0,12,0"
                                          Spacing="8">
                                <Border Background="#2A323C"
                                        CornerRadius="6"
                                        Height="16"
                                        Width="176"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="102"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="238"
                                        HorizontalAlignment="Left" />
                              </StackPanel>
                              <Grid Grid.Column="2"
                                    ColumnDefinitions="72,48,*"
                                    RowDefinitions="Auto,Auto,Auto">
                                <Border Grid.Row="0"
                                        Background="#2A323C"
                                        CornerRadius="6"
                                        Height="13"
                                        Width="64"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Row="1"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="66"
                                        HorizontalAlignment="Left" />
                                <Border Grid.Row="2"
                                        Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="58"
                                        HorizontalAlignment="Left" />

                                <Border Grid.Column="1"
                                        Grid.Row="0"
                                        Margin="10,0,0,0"
