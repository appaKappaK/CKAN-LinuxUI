<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CKAN.LinuxGUI.SimplePromptWindow"
        x:CompileBindings="False"
        Width="620"
        MaxHeight="720"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="CKAN Linux"
        Background="#171C22">
  <Window.Styles>
    <Style Selector="Button.dialog-action">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Background" Value="#24303B" />
      <Setter Property="BorderBrush" Value="#405061" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Foreground" Value="#F3F7FC" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Button.dialog-action:pointerover">
      <Setter Property="Background" Value="#2E3C49" />
      <Setter Property="BorderBrush" Value="#5B7084" />
    </Style>
    <Style Selector="Button.dialog-action:pressed">
      <Setter Property="Background" Value="#1D2730" />
      <Setter Property="BorderBrush" Value="#6A7F94" />
    </Style>
    <Style Selector="Button.dialog-action:disabled">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#303A44" />
      <Setter Property="Foreground" Value="#7B8794" />
      <Setter Property="Opacity" Value="1" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto"
        Margin="20">
    <Border Background="#161B21"
            BorderBrush="#2B3642"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16">
      <StackPanel Spacing="12">
        <TextBlock FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="#F4F6F8"
                   TextWrapping="Wrap"
                   Text="{Binding Prompt}" />

        <TextBlock FontSize="12"
                   Foreground="#7F8D9B"
                   IsVisible="{Binding HasOptions}"
                   Text="{Binding SelectionHint}" />

        <ListBox Classes="utility-list"
                 MaxHeight="420"
                 ItemsSource="{Binding Options}"
                 SelectedIndex="{Binding SelectedIndex}"
                 IsVisible="{Binding HasOptions}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Classes="utility-list-row">
                <Grid RowDefinitions="Auto,Auto,Auto">
                  <TextBlock FontWeight="SemiBold"
                             Foreground="#F4F6F8"
                             TextTrimming="CharacterEllipsis"
                             Text="{Binding Primary}" />
                  <TextBlock Grid.Row="1"
                             Margin="0,3,0,0"
                             FontSize="12"
                             Foreground="#AAB6C4"
                             MaxLines="1"
                             TextTrimming="CharacterEllipsis"
                             IsVisible="{Binding HasSecondary}"
                             Text="{Binding Secondary}" />
                  <TextBlock Grid.Row="2"
                             Margin="0,5,0,0"
                             FontSize="12"
                             Foreground="#8E9EAE"
                             MaxLines="2"
                             TextWrapping="Wrap"
                             TextTrimming="CharacterEllipsis"
                             IsVisible="{Binding HasDetail}"
                             Text="{Binding Detail}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </StackPanel>
    </Border>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="12"
                Margin="0,20,0,0">
      <Button Classes="dialog-action"
              Click="CancelButton_OnClick"
              Content="{Binding CancelLabel}" />
      <Button Classes="dialog-action"
              Click="ConfirmButton_OnClick"
              Content="{Binding ConfirmLabel}" />
    </StackPanel>
  </Grid>
</Window>
