<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CKAN.LinuxGUI"
        xmlns:models="using:CKAN.App.Models"
        xmlns:media="using:Avalonia.Media"
        xmlns:shapes="using:Avalonia.Controls.Shapes"
        mc:Ignorable="d"
        x:Class="CKAN.LinuxGUI.MainWindow"
        x:Name="MainWindowRoot"
        KeyDown="Window_OnKeyDown"
        x:DataType="vm:MainWindowViewModel"
        Width="1200"
        Height="760"
        MinWidth="1040"
        MinHeight="700"
        Title="CKAN Linux"
        FontFamily="Inter, Noto Sans, Segoe UI, Arial"
        Background="#171C22">
  <Window.Styles>
    <Style Selector="ToggleButton.toolbar-chip">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="86" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="Background" Value="#202B35" />
      <Setter Property="BorderBrush" Value="#3B4B5B" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Foreground" Value="#E6EEF7" />
    </Style>
    <Style Selector="Button.toolbar-chip">
