<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CKAN.LinuxGUI.AddRepositoryWindow"
        x:CompileBindings="False"
        Width="620"
        Height="420"
        MinWidth="560"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Title="Add Repository"
        Background="#171C22">
  <Window.Styles>
    <Style Selector="Button.dialog-action">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Background" Value="#24303B" />
      <Setter Property="BorderBrush" Value="#405061" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Foreground" Value="#F3F7FC" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Button.dialog-action:pointerover">
      <Setter Property="Background" Value="#2E3C49" />
      <Setter Property="BorderBrush" Value="#5B7084" />
    </Style>
    <Style Selector="Button.dialog-action:pressed">
      <Setter Property="Background" Value="#1D2730" />
      <Setter Property="BorderBrush" Value="#6A7F94" />
    </Style>
    <Style Selector="Button.dialog-action:disabled">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#303A44" />
      <Setter Property="Foreground" Value="#7B8794" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="TextBlock.repo-column-header">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#AEB9C5" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="*,Auto,Auto"
        Margin="20">
    <Border Background="#161B21"
            BorderBrush="#2B323C"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12">
      <Grid RowDefinitions="Auto,Auto,*">
        <TextBlock FontSize="14"
                   FontWeight="SemiBold"
                   Text="Official Repositories" />

        <Grid Grid.Row="1"
              ColumnDefinitions="120,*"
              Margin="10,14,10,6">
          <TextBlock Classes="repo-column-header"
                     Text="Name" />
          <TextBlock Grid.Column="1"
                     Classes="repo-column-header"
                     Text="URL" />
        </Grid>

        <ListBox x:Name="OfficialReposListBox"
                 Grid.Row="2"
                 Classes="utility-list"
                 ItemsSource="{Binding OfficialRepositories}"
                 SelectionChanged="OfficialReposListBox_OnSelectionChanged"
                 DoubleTapped="OfficialReposListBox_OnDoubleTapped">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Classes="utility-list-row">
                <Grid ColumnDefinitions="120,*">
                  <TextBlock FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis"
                             Text="{Binding Name}" />
                  <TextBlock Grid.Column="1"
                             Opacity="0.78"
                             TextTrimming="CharacterEllipsis"
                             Text="{Binding Url}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          Margin="0,16,0,0"
          RowDefinitions="Auto,Auto"
          ColumnDefinitions="160,*">
      <TextBlock Classes="repo-column-header"
                 Text="Name" />
      <TextBlock Grid.Column="1"
                 Classes="repo-column-header"
                 Text="URL" />
      <TextBox x:Name="RepoNameTextBox"
               Grid.Row="1"
               TextChanged="RepoTextBox_OnTextChanged" />
      <TextBox x:Name="RepoUrlTextBox"
               Grid.Row="1"
               Grid.Column="1"
               Margin="8,0,0,0"
               TextChanged="RepoTextBox_OnTextChanged" />
    </Grid>

    <Grid Grid.Row="2"
          Margin="0,18,0,0"
          ColumnDefinitions="*,Auto">
      <TextBlock x:Name="ErrorTextBlock"
                 FontSize="12"
                 Foreground="#FF6B6B"
                 VerticalAlignment="Center"
                 TextWrapping="Wrap" />
      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="12">
        <Button Classes="dialog-action"
                Click="CancelButton_OnClick"
                Content="Cancel" />
        <Button x:Name="AddButton"
                Classes="dialog-action"
                Background="#355779"
                BorderBrush="#5A86B4"
                Click="AddButton_OnClick"
                Content="Add" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
