<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CKAN.LinuxGUI.App">
  <Application.Styles>
    <FluentTheme />
    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Background" Value="#16202A" />
      <Setter Property="BorderBrush" Value="#3D4E60" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Foreground" Value="#F4F6F8" />
      <Setter Property="SelectionBrush" Value="#355779" />
      <Setter Property="CaretBrush" Value="#F4F6F8" />
    </Style>
    <Style Selector="TextBox:pointerover">
      <Setter Property="Background" Value="#1B2631" />
      <Setter Property="BorderBrush" Value="#4B5D70" />
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="Background" Value="#1B2631" />
      <Setter Property="BorderBrush" Value="#61758B" />
    </Style>
    <Style Selector="ListBox.utility-list">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="ScrollViewer.AllowAutoHide" Value="False" />
    </Style>
    <Style Selector="ListBox.utility-list > ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ListBox.utility-list > ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#EA8AF7" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ListBox.utility-list > ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.utility-list > ListBoxItem:selected /template/ Border">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#EA8AF7" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ListBox.utility-list > ListBoxItem:pointerover">
      <Setter Property="Background" Value="#261C2B" />
      <Setter Property="BorderBrush" Value="#B06AC4" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ListBox.utility-list > ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#261C2B" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.utility-list > ListBoxItem:pointerover /template/ Border">
      <Setter Property="Background" Value="#261C2B" />
      <Setter Property="BorderBrush" Value="#B06AC4" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ListBox.utility-list > ListBoxItem:selected:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#EA8AF7" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ListBox.utility-list > ListBoxItem:selected:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.utility-list > ListBoxItem:selected:pointerover /template/ Border">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#EA8AF7" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ListBox.utility-list ScrollBar:vertical">
      <Setter Property="Width" Value="10" />
      <Setter Property="MinWidth" Value="10" />
      <Setter Property="Margin" Value="2,2,0,2" />
    </Style>
    <Style Selector="ListBox.utility-list ScrollBar:vertical:pointerover">
      <Setter Property="Width" Value="10" />
      <Setter Property="MinWidth" Value="10" />
      <Setter Property="Margin" Value="2,2,0,2" />
    </Style>
    <Style Selector="ListBox.utility-list ScrollBar:vertical:expanded">
      <Setter Property="Width" Value="10" />
      <Setter Property="MinWidth" Value="10" />
      <Setter Property="Margin" Value="2,2,0,2" />
    </Style>
    <Style Selector="Border.utility-list-row">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#242B33" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="10,8" />
    </Style>
  </Application.Styles>
</Application>
