<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CKAN.LinuxGUI"
        xmlns:models="using:CKAN.App.Models"
        xmlns:media="using:Avalonia.Media"
        mc:Ignorable="d"
        x:Class="CKAN.LinuxGUI.MainWindow"
        KeyDown="Window_OnKeyDown"
        x:DataType="vm:MainWindowViewModel"
        Width="1200"
        Height="760"
        MinWidth="1040"
        MinHeight="700"
        Title="CKAN Linux">
  <Window.Styles>
    <Style Selector="ToggleButton.toolbar-chip">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="86" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Margin" Value="0,0,8,8" />
    </Style>
    <Style Selector="Button.toolbar-chip">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Margin" Value="0,0,8,8" />
    </Style>
    <Style Selector="ToggleButton.browser-chip">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Margin" Value="0,0,8,6" />
    </Style>
    <Style Selector="Button.browser-chip">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Margin" Value="0,0,8,6" />
    </Style>
  </Window.Styles>
  <LayoutTransformControl HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">
    <LayoutTransformControl.LayoutTransform>
      <media:ScaleTransform ScaleX="{Binding AppliedUiScaleFactor}"
                            ScaleY="{Binding AppliedUiScaleFactor}" />
    </LayoutTransformControl.LayoutTransform>
  <Grid HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        RowDefinitions="Auto,Auto,*">
    <Border Background="#20262D" Padding="24,20">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="2">
          <TextBlock FontSize="28"
                     FontWeight="SemiBold"
                     Text="CKAN Linux" />
        </StackPanel>

        <Border Grid.Column="1"
                Background="#11161C"
                CornerRadius="999"
                Padding="14,8"
                VerticalAlignment="Center"
                IsVisible="{Binding ShowHeaderStagePill}">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock Opacity="0.7"
                       Text="State" />
            <TextBlock FontWeight="SemiBold"
                       Text="{Binding StageTitle}" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            BorderBrush="#2F3741"
            BorderThickness="0,0,0,1"
            Padding="24,16"
            IsVisible="{Binding ShowLegacyHeader}">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <StackPanel Spacing="4">
          <TextBlock FontSize="12"
                     Opacity="0.7"
                     Text="Active Install" />
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="{Binding CurrentInstanceName}" />
          <TextBlock FontSize="12"
                     Opacity="0.72"
                     TextTrimming="CharacterEllipsis"
                     Text="{Binding CurrentInstanceContext}" />
          <TextBlock FontSize="12"
                     Opacity="0.58"
                     Text="{Binding InstanceCountLabel}" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Margin="16,0"
                    Width="280"
                    Spacing="6"
                    VerticalAlignment="Center">
          <ProgressBar Height="18"
                       Minimum="0"
                       Maximum="100"
                       Value="{Binding ProgressPercent}" />
          <TextBlock FontSize="12"
                     Opacity="0.7"
                     Text="{Binding StatusMessage}" />
        </StackPanel>

        <Button Grid.Column="2"
                Command="{Binding RefreshCommand}"
                Content="Reload Instances" />
      </Grid>
    </Border>

    <Border Grid.Row="1"
            BorderBrush="#2F3741"
            BorderThickness="0,0,0,1"
            Padding="24,14"
            IsVisible="{Binding ShowReadyHeader}">
      <StackPanel Spacing="12">
        <Grid ColumnDefinitions="*,240,Auto,Auto,Auto">
          <StackPanel Spacing="3">
            <TextBlock FontSize="12"
                       Opacity="0.68"
                       Text="Current Install" />
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       IsVisible="{Binding ShowPassiveHeaderInstanceLabel}"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding CurrentInstanceName}" />
            <ComboBox MinWidth="220"
                      IsVisible="{Binding ShowHeaderInstanceSwitcher}"
                      ItemsSource="{Binding Instances}"
                      SelectedItem="{Binding SelectedInstance}"
                      SelectionChanged="HeaderInstanceSwitcher_OnSelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate DataType="models:InstanceSummary">
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock FontSize="12"
                       Opacity="0.72"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding CurrentInstanceContext}" />
          </StackPanel>

          <Border Grid.Column="1"
                  Background="#161B21"
                  BorderBrush="#2B323C"
                  BorderThickness="1"
                  CornerRadius="10"
                  Padding="12,10">
            <StackPanel Spacing="6">
              <ProgressBar Height="6"
                           Minimum="0"
                           Maximum="100"
                           Value="{Binding ProgressPercent}" />
              <TextBlock FontSize="12"
                         Opacity="0.74"
                         TextTrimming="CharacterEllipsis"
                         MaxLines="1"
                         Text="{Binding StatusMessage}" />
            </StackPanel>
          </Border>

          <Button Grid.Column="2"
                  Margin="12,0,0,0"
                  VerticalAlignment="Center"
                  Command="{Binding ToggleDisplaySettingsCommand}"
                  Content="Settings" />

          <Button Grid.Column="3"
                  Margin="12,0,0,0"
                  VerticalAlignment="Center"
                  Command="{Binding ToggleDetailsPaneCommand}"
                  ToolTip.Tip="{Binding DetailsPaneToggleLabel}"
                  Content="{Binding DetailsPaneToggleLabel}" />

          <Button Grid.Column="4"
                  Margin="12,0,0,0"
                  VerticalAlignment="Center"
                  Command="{Binding RefreshCommand}"
                  Content="Reload" />
        </Grid>

        <Border Background="#161B21"
                BorderBrush="#2B323C"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14"
                IsVisible="{Binding ShowDisplaySettings}">
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="4">
                <TextBlock FontSize="15"
                           FontWeight="SemiBold"
                           Text="Display Scale" />
                <TextBlock FontSize="12"
                           Opacity="0.72"
                           TextWrapping="Wrap"
                           Text="{Binding DisplayScaleSummary}" />
              </StackPanel>
              <Button Grid.Column="1"
                      VerticalAlignment="Top"
                      Command="{Binding ToggleDisplaySettingsCommand}"
                      Content="Close" />
            </Grid>

            <Slider Minimum="{Binding UiScaleMinimum}"
                    Maximum="{Binding UiScaleMaximum}"
                    TickFrequency="5"
                    TickPlacement="Outside"
                    IsSnapToTickEnabled="True"
                    SmallChange="5"
                    LargeChange="5"
                    Value="{Binding PendingUiScalePercent}" />

            <Grid ColumnDefinitions="Auto,*,Auto">
              <TextBlock FontSize="12"
                         Opacity="0.68"
                         Text="{Binding UiScaleMinimum}" />
              <TextBlock Grid.Column="1"
                         HorizontalAlignment="Center"
                         FontWeight="SemiBold"
                         Text="{Binding PendingUiScaleLabel}" />
              <TextBlock Grid.Column="2"
                         FontSize="12"
                         Opacity="0.68"
                         Text="{Binding UiScaleMaximum}" />
            </Grid>

            <TextBlock FontSize="12"
                       Opacity="0.72"
                       TextWrapping="Wrap"
                       Text="{Binding DisplayScaleHint}" />

            <WrapPanel>
              <Button Classes="toolbar-chip"
                      IsVisible="{Binding ShowResetUiScaleAction}"
                      Command="{Binding ResetUiScaleCommand}"
                      Content="Reset to 100%" />
              <Button Classes="toolbar-chip"
                      IsVisible="{Binding UiScaleNeedsRestart}"
                      Command="{Binding RestartToApplyUiScaleCommand}"
                      Content="Restart Now" />
            </WrapPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <Grid Grid.Row="2"
          ColumnDefinitions="Auto,*"
          Margin="24">
      <Border Background="#161B21"
              BorderBrush="#2B323C"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16"
              Margin="0"
              Width="{Binding LegacySidebarWidth}"
              IsVisible="{Binding ShowLegacyShell}">
        <Grid RowDefinitions="*,Auto">
          <Grid Grid.Row="0">
            <Grid RowDefinitions="Auto,Auto,*,Auto"
                  IsVisible="{Binding ShowStartupInstancePanel}">
              <TextBlock FontSize="18"
                         FontWeight="SemiBold"
                         Text="Your KSP Installs" />

              <TextBlock Grid.Row="1"
                         Margin="0,8,0,0"
                         FontSize="12"
                         Opacity="0.7"
                         Text="{Binding SelectedActionHint}" />

              <ListBox Grid.Row="2"
                       Margin="0,16,0,16"
                       ItemsSource="{Binding Instances}"
                       SelectedItem="{Binding SelectedInstance}">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="models:InstanceSummary">
                    <Border Padding="10"
                            Margin="0,0,0,8"
                            Background="#1D242C"
                            CornerRadius="8">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                          <TextBlock FontWeight="SemiBold"
                                     Text="{Binding Name}" />
                          <TextBlock FontSize="12"
                                     Opacity="0.75"
                                     Text="{Binding GameName}" />
                          <TextBlock FontSize="12"
                                     Opacity="0.75"
                                     Text="{Binding GameDir}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#2A6B4A"
                                CornerRadius="999"
                                Padding="10,4"
                                VerticalAlignment="Top"
                                IsVisible="{Binding IsCurrent}">
                          <TextBlock FontSize="11"
                                     FontWeight="SemiBold"
                                     Text="Current" />
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Button Grid.Row="3"
                      Command="{Binding SetCurrentInstanceCommand}"
                      Content="{Binding SelectedActionLabel}" />
            </Grid>

            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
                  IsVisible="{Binding ShowReadyInstancePanel}">
              <TextBlock FontSize="18"
                         FontWeight="SemiBold"
                         Text="Switch Install" />

              <TextBlock Grid.Row="1"
                         Margin="0,8,0,0"
                         FontSize="12"
                         Opacity="0.72"
                         TextWrapping="Wrap"
                         Text="{Binding ReadyInstanceHint}" />

              <Border Grid.Row="2"
                      Background="#20262D"
                      CornerRadius="10"
                      Padding="14"
                      Margin="0,14,0,0"
                      IsVisible="{Binding ShowSwitchSelectedInstanceAction}">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="3">
                      <TextBlock FontSize="11"
                                 Opacity="0.68"
                                 Text="{Binding SelectedInstanceContextTitle}" />
                      <TextBlock FontWeight="SemiBold"
                                 Text="{Binding SelectedInstance.Name}" />
                      <TextBlock FontSize="12"
                                 Opacity="0.74"
                                 Text="{Binding SelectedInstance.GameName}" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Background="#2A6B4A"
                            CornerRadius="999"
                            Padding="10,4"
                            VerticalAlignment="Top"
                            IsVisible="{Binding SelectedInstanceIsCurrent}">
                      <TextBlock FontSize="11"
                                 FontWeight="SemiBold"
                                 Text="Current" />
                    </Border>
                  </Grid>

                  <TextBlock FontSize="12"
                             Opacity="0.74"
                             TextWrapping="Wrap"
                             Text="{Binding SelectedInstance.GameDir}" />
                </StackPanel>
              </Border>

              <ListBox Grid.Row="3"
                       Margin="0,14,0,0"
                       MaxHeight="260"
                       ItemsSource="{Binding Instances}"
                       SelectedItem="{Binding SelectedInstance}">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="models:InstanceSummary">
                    <Border Padding="10"
                            Margin="0,0,0,8"
                            Background="#1D242C"
                            CornerRadius="8">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="3">
                          <TextBlock FontWeight="SemiBold"
                                     Text="{Binding Name}" />
                          <TextBlock FontSize="12"
                                     Opacity="0.75"
                                     Text="{Binding GameName}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#2A6B4A"
                                CornerRadius="999"
                                Padding="10,4"
                                VerticalAlignment="Center"
                                IsVisible="{Binding IsCurrent}">
                          <TextBlock FontSize="11"
                                     FontWeight="SemiBold"
                                     Text="Current" />
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <StackPanel Grid.Row="4"
                          Margin="0,14,0,0"
                          Spacing="8">
                <TextBlock FontSize="12"
                           Opacity="0.72"
                           IsVisible="{Binding SelectedInstanceIsCurrent}"
                           Text="You are already browsing this install." />
                <Button IsVisible="{Binding ShowSwitchSelectedInstanceAction}"
                        Command="{Binding SetCurrentInstanceCommand}"
                        Content="Switch Install" />
              </StackPanel>
            </Grid>
          </Grid>

          <Border Grid.Row="1"
                  Background="#20262D"
                  CornerRadius="10"
                  Padding="14"
                  Margin="0,16,0,0">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                  <TextBlock FontSize="15"
                             FontWeight="SemiBold"
                             Text="Display Scale" />
                  <TextBlock FontSize="12"
                             Opacity="0.72"
                             TextWrapping="Wrap"
                             Text="{Binding DisplayScaleSummary}" />
                </StackPanel>
                <Button Grid.Column="1"
                        VerticalAlignment="Top"
                        Command="{Binding ToggleDisplaySettingsCommand}"
                        Content="{Binding DisplaySettingsToggleLabel}" />
              </Grid>

              <StackPanel IsVisible="{Binding ShowDisplaySettings}"
                          Spacing="10">
                <Slider Minimum="{Binding UiScaleMinimum}"
                        Maximum="{Binding UiScaleMaximum}"
                        TickFrequency="5"
                        TickPlacement="Outside"
                        IsSnapToTickEnabled="True"
                        SmallChange="5"
                        LargeChange="5"
                        Value="{Binding PendingUiScalePercent}" />

                <Grid ColumnDefinitions="Auto,*,Auto">
                  <TextBlock FontSize="12"
                             Opacity="0.68"
                             Text="{Binding UiScaleMinimum}" />
                  <TextBlock Grid.Column="1"
                             HorizontalAlignment="Center"
                             FontWeight="SemiBold"
                             Text="{Binding PendingUiScaleLabel}" />
                  <TextBlock Grid.Column="2"
                             FontSize="12"
                             Opacity="0.68"
                             Text="{Binding UiScaleMaximum}" />
                </Grid>

                <TextBlock FontSize="12"
                           Opacity="0.72"
                           TextWrapping="Wrap"
                           Text="{Binding DisplayScaleHint}" />

                <WrapPanel>
                  <Button Classes="toolbar-chip"
                          IsVisible="{Binding ShowResetUiScaleAction}"
                          Command="{Binding ResetUiScaleCommand}"
                          Content="Reset to 100%" />
                  <Button Classes="toolbar-chip"
                          IsVisible="{Binding UiScaleNeedsRestart}"
                          Command="{Binding RestartToApplyUiScaleCommand}"
                          Content="Restart to Apply" />
                </WrapPanel>
              </StackPanel>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Background="#161B21"
              BorderBrush="#2B323C"
              BorderThickness="1"
              CornerRadius="12"
              Padding="20"
              Margin="0">
        <Grid>
          <Border Background="#20262D"
                  CornerRadius="12"
                  Padding="24"
                  IsVisible="{Binding IsLoading}">
            <StackPanel Spacing="14"
                        VerticalAlignment="Center">
              <TextBlock FontSize="24"
                         FontWeight="SemiBold"
                         Text="{Binding StageTitle}" />
              <TextBlock Opacity="0.8"
                         TextWrapping="Wrap"
                         Text="{Binding StageDescription}" />
              <ProgressBar Height="20"
                           Minimum="0"
                           Maximum="100"
                           Value="{Binding ProgressPercent}" />
              <TextBlock FontSize="13"
                         Opacity="0.8"
                         Text="{Binding StatusMessage}" />
            </StackPanel>
          </Border>

          <Border Background="#20262D"
                  CornerRadius="12"
                  Padding="24"
                  IsVisible="{Binding IsEmpty}">
            <StackPanel Spacing="16">
              <TextBlock FontSize="24"
                         FontWeight="SemiBold"
                         Text="{Binding StageTitle}" />
              <TextBlock TextWrapping="Wrap"
                         Opacity="0.85"
                         Text="{Binding StageDescription}" />
              <Border Background="#161B21"
                      CornerRadius="10"
                      Padding="16">
                <TextBlock TextWrapping="Wrap"
                           Text="Register a KSP install, then reload to open the mod browser." />
              </Border>
              <Button Width="170"
                      HorizontalAlignment="Left"
                      Command="{Binding RefreshCommand}"
                      Content="Scan Again" />
            </StackPanel>
          </Border>

          <Border Background="#20262D"
                  CornerRadius="12"
                  Padding="24"
                  IsVisible="{Binding NeedsSelection}">
            <StackPanel Spacing="18">
              <TextBlock FontSize="24"
                         FontWeight="SemiBold"
                         Text="{Binding StageTitle}" />
              <TextBlock TextWrapping="Wrap"
                         Opacity="0.85"
                         Text="{Binding StageDescription}" />
              <Border Background="#161B21"
                      CornerRadius="10"
                      Padding="16">
                <StackPanel Spacing="10">
                  <TextBlock FontSize="12"
                             Opacity="0.7"
                             Text="Selected Install" />
                  <TextBlock TextWrapping="Wrap"
                             Text="{Binding SelectedInstanceSummary}" />
                </StackPanel>
              </Border>
              <Button Width="230"
                      HorizontalAlignment="Left"
                      Command="{Binding SetCurrentInstanceCommand}"
                      Content="{Binding SelectedActionLabel}" />
            </StackPanel>
          </Border>

          <Border Background="#20262D"
                  CornerRadius="12"
                  Padding="24"
                  IsVisible="{Binding IsReady}">
            <Grid RowDefinitions="Auto,*,Auto">
              <Border Background="#4A3920"
                      BorderBrush="#9A7B37"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="14"
                      Margin="0,0,0,14"
                      IsVisible="{Binding ShowUiScaleRestartStrip}">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <TextBlock VerticalAlignment="Center"
                             FontSize="12"
                             Opacity="0.86"
                             Text="{Binding UiScaleRestartStripText}" />
                  <Button Grid.Column="1"
                          Margin="10,0,0,0"
                          Command="{Binding RestartToApplyUiScaleCommand}"
                          Content="Restart Now" />
                  <Button Grid.Column="2"
                          Margin="10,0,0,0"
                          Command="{Binding DismissUiScaleRestartStripCommand}"
                          Content="Dismiss" />
                </Grid>
              </Border>

              <Grid Grid.Row="1"
                    ColumnDefinitions="*,Auto">
                <Border Background="#161B21"
                        CornerRadius="10"
                        Padding="16"
                        Margin="0,0,8,0">
                  <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <Grid ColumnDefinitions="*,Auto"
                          Margin="0,0,0,10">
                      <TextBox x:Name="SearchTextBox"
                               Watermark="Search mods by name, author, or identifier"
                               Text="{Binding ModSearchText}" />
                      <Border Grid.Column="1"
                              Background="#20262D"
                              CornerRadius="999"
                              Padding="10,6"
                              Margin="10,0,0,0"
                              VerticalAlignment="Center">
                        <TextBlock FontSize="12"
                                   Opacity="0.8"
                                   Text="{Binding ModCountLabel}" />
                      </Border>
                    </Grid>

                    <Grid Grid.Row="1"
                          RowDefinitions="Auto,Auto"
                          Margin="0,0,0,10">
                      <WrapPanel VerticalAlignment="Center"
                                 MaxWidth="620">
                        <ToggleButton Classes="browser-chip"
                                      IsChecked="{Binding FilterInstalledOnly}"
                                      Content="Installed" />
                        <ToggleButton Classes="browser-chip"
                                      IsChecked="{Binding FilterNotInstalledOnly}"
                                      Content="Not Installed" />
                        <ToggleButton Classes="browser-chip"
                                      IsChecked="{Binding FilterUpdatableOnly}"
                                      Content="Updates" />
                        <ToggleButton Classes="browser-chip"
                                      IsChecked="{Binding FilterCachedOnly}"
                                      Content="Cached" />
                        <ToggleButton Classes="browser-chip"
                                      IsChecked="{Binding FilterIncompatibleOnly}"
                                      Content="Incompatible" />
                      </WrapPanel>

                      <Grid Grid.Row="1"
                            ColumnDefinitions="Auto,*,Auto,Auto"
                            Margin="0,2,0,0">
                        <Border Background="#20262D"
                                CornerRadius="999"
                                Padding="10,6"
                                VerticalAlignment="Center">
                          <StackPanel Orientation="Horizontal"
                                      Spacing="8">
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="12"
                                       Opacity="0.68"
                                       Text="Sort" />
                            <ComboBox Width="150"
                                      ItemsSource="{Binding SortOptions}"
                                      SelectedItem="{Binding SelectedSortOption}">
                              <ComboBox.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                              </ComboBox.ItemTemplate>
                            </ComboBox>
                          </StackPanel>
                        </Border>

                        <TextBlock Grid.Column="1" />

                        <Button Grid.Column="2"
                                x:Name="MoreFiltersButton"
                                Classes="browser-chip"
                                Command="{Binding ToggleAdvancedFiltersCommand}"
                                HorizontalAlignment="Right"
                                Content="{Binding MoreFiltersLabel}" />
                        <Button Grid.Column="3"
                                Classes="browser-chip"
                                IsVisible="{Binding HasActiveFilters}"
                                Command="{Binding ClearFiltersCommand}"
                                HorizontalAlignment="Right"
                                Content="Clear Filters" />

                      </Grid>

                      <Popup x:Name="AdvancedFiltersPopup"
                             IsOpen="{Binding ShowAdvancedFilters, Mode=TwoWay}"
                             Placement="Bottom"
                             PlacementTarget="{Binding #MoreFiltersButton}"
                             HorizontalOffset="-206"
                             VerticalOffset="8"
                             IsLightDismissEnabled="True"
                             OverlayDismissEventPassThrough="True"
                             Opened="AdvancedFiltersPopup_OnOpened">
                        <Border Background="#20262D"
                                BorderBrush="#39424E"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16"
                                MinWidth="520"
                                MaxWidth="560"
                                BoxShadow="0 18 36 0 #66000000">
                          <StackPanel Spacing="12">
                            <TextBlock FontSize="12"
                                       Opacity="0.76"
                                       Text="Advanced Filters" />
                            <Grid ColumnDefinitions="*,*,Auto">
                              <TextBox x:Name="AdvancedAuthorFilterTextBox"
                                       Watermark="Author contains"
                                       Text="{Binding AdvancedAuthorFilter}" />
                              <TextBox Grid.Column="1"
                                       Margin="12,0,0,0"
                                       Watermark="Compatibility contains"
                                       Text="{Binding AdvancedCompatibilityFilter}" />
                              <ToggleButton Grid.Column="2"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding FilterHasReplacementOnly}"
                                            Content="Has Replacement" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                              <TextBlock VerticalAlignment="Center"
                                         FontSize="12"
                                         Opacity="0.72"
                                         TextWrapping="Wrap"
                                         Text="{Binding AdvancedFilterSummary}" />
                              <Button Grid.Column="1"
                                      Margin="12,0,0,0"
                                      IsVisible="{Binding HasActiveAdvancedFilters}"
                                      Command="{Binding ClearAdvancedFiltersCommand}"
                                      Content="Clear Advanced" />
                            </Grid>
                          </StackPanel>
                        </Border>
                      </Popup>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="#14191F"
                            CornerRadius="8"
                            BorderBrush="#2B323C"
                            BorderThickness="1"
                            Padding="8">
                      <Grid>
                        <StackPanel Spacing="12"
                                    IsVisible="{Binding ShowCatalogSkeleton}">
                          <Border Background="#1B2128"
                                  CornerRadius="8"
                                  Padding="12"
                                  Margin="0,0,0,4">
                            <Grid ColumnDefinitions="5,*,144">
                              <Border Background="#24588A"
                                      CornerRadius="8,0,0,8" />
                              <StackPanel Grid.Column="1"
                                          Margin="12,0,12,0"
                                          Spacing="8">
                                <Border Background="#2A323C"
                                        CornerRadius="6"
                                        Height="16"
                                        Width="168"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="108"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="292"
                                        HorizontalAlignment="Left" />
                              </StackPanel>
                              <StackPanel Grid.Column="2"
                                          Spacing="8">
                                <Border Background="#2A323C"
                                        CornerRadius="6"
                                        Height="13"
                                        Width="86"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="74"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="98"
                                        HorizontalAlignment="Left" />
                              </StackPanel>
                            </Grid>
                          </Border>

                          <Border Background="#1B2128"
                                  CornerRadius="8"
                                  Padding="12"
                                  Margin="0,0,0,4"
                                  Opacity="0.94">
                            <Grid ColumnDefinitions="5,*,144">
                              <Border Background="#39424E"
                                      CornerRadius="8,0,0,8" />
                              <StackPanel Grid.Column="1"
                                          Margin="12,0,12,0"
                                          Spacing="8">
                                <Border Background="#2A323C"
                                        CornerRadius="6"
                                        Height="16"
                                        Width="190"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="96"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="252"
                                        HorizontalAlignment="Left" />
                              </StackPanel>
                              <StackPanel Grid.Column="2"
                                          Spacing="8">
                                <Border Background="#2A323C"
                                        CornerRadius="6"
                                        Height="13"
                                        Width="80"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="84"
                                        HorizontalAlignment="Left" />
                                <Border Background="#242B34"
                                        CornerRadius="6"
                                        Height="11"
                                        Width="104"
                                        HorizontalAlignment="Left" />
                              </StackPanel>
                            </Grid>
                          </Border>

                        </StackPanel>

                        <ListBox x:Name="ModsListBox"
                                 ItemsSource="{Binding Mods}"
                                 SelectedItem="{Binding SelectedMod}"
                                 IsVisible="{Binding ShowModList}">
                          <ListBox.ItemTemplate>
                              <DataTemplate DataType="models:ModListItem">
                                <Border Background="#1B2128"
                                        CornerRadius="8"
                                        Margin="0,0,0,3"
                                        Padding="0">
                                  <Grid ColumnDefinitions="5,*,120">
                                    <Border Background="{Binding PrimaryStateColor}"
                                          CornerRadius="8,0,0,8" />

                                  <Border Grid.Column="1"
                                          Padding="10,7">
                                    <StackPanel Spacing="4">
                                      <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="2">
                                          <TextBlock FontSize="14"
                                                     FontWeight="SemiBold"
                                                     TextTrimming="CharacterEllipsis"
                                                     Text="{Binding Name}" />
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Background="{Binding PrimaryStateColor}"
                                                CornerRadius="999"
                                                Padding="7,2"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Top">
                                          <TextBlock FontSize="10"
                                                     FontWeight="SemiBold"
                                                     Text="{Binding PrimaryStateLabel}" />
                                        </Border>
                                      </Grid>

                                      <TextBlock TextWrapping="Wrap"
                                                 FontSize="12"
                                                 MaxHeight="16"
                                                 MaxLines="1"
                                                 Opacity="0.9"
                                                 TextTrimming="CharacterEllipsis"
                                                 Text="{Binding Summary}" />

                                      <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock FontSize="11"
                                                   Opacity="0.78"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding Author}" />
                                        <TextBlock Grid.Column="1"
                                                   FontSize="11"
                                                   Opacity="0.72"
                                                   Margin="12,0,0,0"
                                                   HorizontalAlignment="Right"
                                                   IsVisible="{Binding HasStatusSummary}"
                                                   Text="{Binding StatusSummary}" />
                                      </Grid>
                                    </StackPanel>
                                  </Border>

                                  <Border Grid.Column="2"
                                          Background="#171C22"
                                          CornerRadius="0,8,8,0"
                                          Padding="8,7">
                                    <StackPanel Spacing="4">
                                      <TextBlock FontSize="13"
                                                 FontWeight="SemiBold"
                                                 Text="{Binding LatestVersion}" />
                                      <TextBlock FontSize="10"
                                                 Opacity="0.72"
                                                 TextTrimming="CharacterEllipsis"
                                                 IsVisible="{Binding IsInstalled}"
                                                 Text="{Binding InstalledVersion}" />
                                      <TextBlock FontSize="10"
                                                 FontWeight="SemiBold"
                                                 Opacity="0.8"
                                                 TextWrapping="Wrap"
                                                 MaxLines="2"
                                                 Text="{Binding Compatibility}" />
                                    </StackPanel>
                                  </Border>
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Background="#20262D"
                                CornerRadius="10"
                                Padding="18"
                                IsVisible="{Binding ShowEmptyModResults}">
                          <StackPanel Spacing="8"
                                      VerticalAlignment="Center">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="No mods match the current search and filters." />
                            <TextBlock Opacity="0.82"
                                       TextWrapping="Wrap"
                                       Text="Broaden the query or clear the active filters to restore the catalog list." />
                            <Button Width="140"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ClearFiltersCommand}"
                                    Content="Clear Filters" />
                          </StackPanel>
                        </Border>
                      </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Background="#20262D"
                            CornerRadius="8"
                            Padding="10,8"
                            Margin="0,10,0,0">
                      <Grid ColumnDefinitions="Auto,*">
                        <ProgressBar Width="120"
                                     Height="14"
                                     Minimum="0"
                                     Maximum="100"
                                     IsVisible="{Binding IsCatalogLoading}"
                                     IsIndeterminate="{Binding IsCatalogLoading}" />
                        <TextBlock Grid.Column="1"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Opacity="0.78"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding CatalogStatusMessage}" />
                      </Grid>
                    </Border>
                  </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="#161B21"
                        CornerRadius="10"
                        Padding="16"
                        Margin="8,0,0,0"
                        Width="296"
                        MinWidth="280"
                        IsVisible="{Binding ShowDetailsPane}">
                  <Grid>
                    <StackPanel Spacing="12"
                                IsVisible="{Binding ShowSelectedModPlaceholder}">
                      <TextBlock FontSize="11"
                                 Opacity="0.68"
                                 Text="Mod Details" />
                      <TextBlock FontSize="16"
                                 FontWeight="SemiBold"
                                 Text="No mod selected" />
                      <TextBlock Opacity="0.8"
                                 TextWrapping="Wrap"
                                 Text="Choose a mod from the browser to inspect install state, compatibility, and package metadata." />
                    </StackPanel>

                    <StackPanel Spacing="14"
                                IsVisible="{Binding ShowSelectedModLoadingState}">
                      <TextBlock FontSize="11"
                                 Opacity="0.68"
                                 Text="Mod Details" />
                      <TextBlock FontSize="16"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap"
                                 Text="{Binding SelectedModLoadingTitle}" />
                      <Border Background="#26303A"
                              CornerRadius="5"
                              Height="14"
                              Width="170"
                              HorizontalAlignment="Left" />
                      <Border Background="#20262D"
                              Height="1"
                              Margin="0,2" />
                      <Grid ColumnDefinitions="Auto,*"
                            RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                        <TextBlock FontSize="12"
                                   Opacity="0.68"
                                   Text="Version" />
                        <Border Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="132"
                                Margin="12,0,0,0"
                                HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="1"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   Opacity="0.68"
                                   Text="Status" />
                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="164"
                                Margin="12,10,0,0"
                                HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="2"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   Opacity="0.68"
                                   Text="License" />
                        <Border Grid.Row="2"
                                Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="120"
                                Margin="12,10,0,0"
                                HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="3"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   Opacity="0.68"
                                   Text="Type" />
                        <Border Grid.Row="3"
                                Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="108"
                                Margin="12,10,0,0"
                                HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="4"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   Opacity="0.68"
                                   Text="Released" />
                        <Border Grid.Row="4"
                                Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="144"
                                Margin="12,10,0,0"
                                HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="5"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   Opacity="0.68"
                                   Text="Download" />
                        <Border Grid.Row="5"
                                Grid.Column="1"
                                Background="#26303A"
                                CornerRadius="5"
                                Height="12"
                                Width="126"
                                Margin="12,10,0,0"
                                HorizontalAlignment="Left" />
                      </Grid>
                      <Border Background="#20262D"
                              Height="1"
                              Margin="0,2" />
                      <Border Background="#242B34"
                              CornerRadius="5"
                              Height="11"
                              Width="240"
                              HorizontalAlignment="Left" />
                      <Border Background="#242B34"
                              CornerRadius="5"
                              Height="11"
                              Width="220"
                              HorizontalAlignment="Left" />
                      <Border Background="#242B34"
                              CornerRadius="5"
                              Height="11"
                              Width="232"
                              HorizontalAlignment="Left" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding ShowSelectedModContent}">
                      <StackPanel Spacing="12">
                        <TextBlock FontSize="11"
                                   Opacity="0.68"
                                   Text="Mod Details" />
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedModTitle}" />
                        <TextBlock TextWrapping="Wrap"
                                   Opacity="0.82"
                                   Text="{Binding SelectedModSubtitle}" />
                        <TextBlock FontSize="12"
                                   Opacity="0.72"
                                   Text="{Binding SelectedModAuthors}" />

                        <WrapPanel ItemHeight="26"
                                   IsVisible="{Binding HasSelectedMod}">
                          <Border Background="#1B4D77"
                                  CornerRadius="999"
                                  Padding="8,3"
                                  Margin="0,0,8,0"
                                  IsVisible="{Binding SelectedModIsInstalled}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Text="Installed" />
                          </Border>
                          <Border Background="#4B6C23"
                                  CornerRadius="999"
                                  Padding="8,3"
                                  Margin="0,0,8,0"
                                  IsVisible="{Binding SelectedModHasUpdate}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Text="Update available" />
                          </Border>
                          <Border Background="#7A5B1E"
                                  CornerRadius="999"
                                  Padding="8,3"
                                  Margin="0,0,8,0"
                                  IsVisible="{Binding SelectedModIsCached}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Text="Cached" />
                          </Border>
                          <Border Background="#6B2B2B"
                                  CornerRadius="999"
                                  Padding="8,3"
                                  Margin="0,0,8,0"
                                  IsVisible="{Binding SelectedModIsIncompatible}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Text="Incompatible" />
                          </Border>
                          <Border Background="#5C376D"
                                  CornerRadius="999"
                                  Padding="8,3"
                                  Margin="0,0,8,0"
                                  IsVisible="{Binding SelectedModHasReplacement}">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Text="Has replacement" />
                          </Border>
                        </WrapPanel>

                        <Grid ColumnDefinitions="Auto,*">
                          <StackPanel Spacing="8">
                            <Button HorizontalAlignment="Left"
                                    IsVisible="{Binding ShowPrimarySelectedModAction}"
                                    Command="{Binding PrimarySelectedModActionCommand}"
                                    Content="{Binding PrimarySelectedModActionLabel}" />
                          </StackPanel>
                          <TextBlock Grid.Column="1"
                                     Margin="12,0,0,0"
                                     VerticalAlignment="Center"
                                     FontSize="12"
                                     Opacity="0.78"
                                     TextWrapping="Wrap"
                                     Text="{Binding SelectedModQueueStatus}" />
                        </Grid>

                        <Border Background="#20262D"
                                Height="1"
                                IsVisible="{Binding HasSelectedMod}" />

                        <Grid ColumnDefinitions="Auto,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              IsVisible="{Binding HasSelectedMod}">
                          <TextBlock FontSize="12"
                                     Opacity="0.68"
                                     Text="Version" />
                          <TextBlock Grid.Column="1"
                                     Margin="12,0,0,0"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap"
                                     Text="{Binding SelectedModVersions}" />

                          <TextBlock Grid.Row="1"
                                     FontSize="12"
                                     Margin="0,8,0,0"
                                     Opacity="0.68"
                                     Text="Status" />
                          <TextBlock Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="12,8,0,0"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap"
                                     Text="{Binding SelectedModInstallState}" />

                          <TextBlock Grid.Row="2"
                                     FontSize="12"
                                     Margin="0,8,0,0"
                                     Opacity="0.68"
                                     Text="Compatibility" />
                          <TextBlock Grid.Row="2"
                                     Grid.Column="1"
                                     Margin="12,8,0,0"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap"
                                     Text="{Binding SelectedModCompatibility}" />

                          <TextBlock Grid.Row="3"
                                     FontSize="12"
                                     Margin="0,8,0,0"
                                     Opacity="0.68"
                                     Text="Type" />
                          <TextBlock Grid.Row="3"
                                     Grid.Column="1"
                                     Margin="12,8,0,0"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap"
                                     Text="{Binding SelectedModModuleKind}" />

                          <TextBlock Grid.Row="4"
                                     FontSize="12"
                                     Margin="0,8,0,0"
                                     Opacity="0.68"
                                     Text="License" />
                          <TextBlock Grid.Row="4"
                                     Grid.Column="1"
                                     Margin="12,8,0,0"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap"
                                     Text="{Binding SelectedModLicense}" />

                          <TextBlock Grid.Row="5"
                                     FontSize="12"
                                     Margin="0,8,0,0"
                                     Opacity="0.68"
                                     Text="Released" />
                          <TextBlock Grid.Row="5"
                                     Grid.Column="1"
                                     Margin="12,8,0,0"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap"
                                     Text="{Binding SelectedModReleaseDate}" />

                          <TextBlock Grid.Row="6"
                                     FontSize="12"
                                     Margin="0,8,0,0"
                                     Opacity="0.68"
                                     Text="Download" />
                          <TextBlock Grid.Row="6"
                                     Grid.Column="1"
                                     Margin="12,8,0,0"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap"
                                     Text="{Binding SelectedModDownloadSize}" />

                          <TextBlock Grid.Row="7"
                                     FontSize="12"
                                     Margin="0,8,0,0"
                                     Opacity="0.68"
                                     Text="Relationships" />
                          <StackPanel Grid.Row="7"
                                      Grid.Column="1"
                                      Margin="12,8,0,0"
                                      Spacing="6">
                            <TextBlock FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModRelationships}" />
                            <TextBlock FontSize="12"
                                       Opacity="0.78"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModDependencyCountLabel}" />
                            <TextBlock FontSize="12"
                                       Opacity="0.78"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModRecommendationCountLabel}" />
                            <TextBlock FontSize="12"
                                       Opacity="0.78"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedModSuggestionCountLabel}" />
                          </StackPanel>
                        </Grid>

                        <Border Background="#20262D"
                                Height="1"
                                IsVisible="{Binding HasSelectedMod}" />

                        <StackPanel Spacing="8">
                          <TextBlock FontSize="11"
                                     Opacity="0.68"
                                     Text="Description" />
                          <TextBlock TextWrapping="Wrap"
                                     Text="{Binding SelectedModBody}" />
                        </StackPanel>
                      </StackPanel>
                    </ScrollViewer>
                  </Grid>
                </Border>
              </Grid>

              <Border Grid.Row="2"
                      Background="#161B21"
                      CornerRadius="10"
                      Padding="14,12"
                      Margin="0,12,0,0"
                      IsVisible="{Binding ShowEmptyQueueStub}">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock VerticalAlignment="Center"
                             FontWeight="SemiBold"
                             Text="No pending changes" />
                  <TextBlock Grid.Column="1"
                             VerticalAlignment="Center"
                             FontSize="12"
                             Opacity="0.7"
                             Text="Queue install, update, or remove actions to preview changes." />
                </Grid>
              </Border>

              <Border Grid.Row="2"
                      Background="{Binding CollapsedQueueStubBackground}"
                      BorderBrush="{Binding CollapsedQueueStubBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="14,12"
                      Margin="0,12,0,0"
                      IsVisible="{Binding ShowCollapsedQueuedActionsStub}">
                <Grid ColumnDefinitions="*,Auto">
                  <Button HorizontalContentAlignment="Stretch"
                          Padding="0"
                          Background="Transparent"
                          BorderThickness="0"
                          Command="{Binding ToggleQueueDrawerCommand}">
                    <StackPanel Spacing="4">
                      <TextBlock FontWeight="SemiBold"
                                 Text="{Binding CollapsedQueueStubTitle}" />
                      <TextBlock FontSize="12"
                                 Opacity="0.74"
                                 TextWrapping="Wrap"
                                 Text="{Binding CollapsedQueueStubSummary}" />
                    </StackPanel>
                  </Button>

                  <Button Grid.Column="1"
                          Margin="14,0,0,0"
                          VerticalAlignment="Center"
                          Command="{Binding ApplyChangesFromCollapsedQueueCommand}"
                          Content="Apply Changes" />
                </Grid>
              </Border>

              <Border Grid.Row="2"
                      Background="{Binding CollapsedQueueStubBackground}"
                      BorderBrush="{Binding CollapsedQueueStubBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="14,12"
                      Margin="0,12,0,0"
                      IsVisible="{Binding ShowCollapsedApplyResultStub}">
                <Grid ColumnDefinitions="*,Auto">
                  <Button HorizontalContentAlignment="Stretch"
                          Padding="0"
                          Background="Transparent"
                          BorderThickness="0"
                          Command="{Binding ToggleQueueDrawerCommand}">
                    <StackPanel Spacing="4">
                      <TextBlock FontWeight="SemiBold"
                                 Text="{Binding CollapsedQueueStubTitle}" />
                      <TextBlock FontSize="12"
                                 Opacity="0.82"
                                 TextWrapping="Wrap"
                                 Text="{Binding CollapsedQueueStubSummary}" />
                    </StackPanel>
                  </Button>

                  <Button Grid.Column="1"
                          Margin="14,0,0,0"
                          VerticalAlignment="Center"
                          Command="{Binding DismissApplyResultCommand}"
                          Content="Dismiss" />
                </Grid>
              </Border>

              <Border Grid.Row="2"
                      Background="#161B21"
                      CornerRadius="10"
                      Padding="18"
                      Margin="0,12,0,0"
                      MinHeight="260"
                      IsVisible="{Binding ShowExpandedQueuePanel}">
                <Grid RowDefinitions="Auto,*">
                  <Border Background="#1A2027"
                          CornerRadius="10"
                          Padding="14">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Spacing="4">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="Actions to Apply" />
                        <TextBlock FontSize="12"
                                   Opacity="0.72"
                                   Text="{Binding QueueCountLabel}" />
                      </StackPanel>
                      <WrapPanel Grid.Column="1"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center">
                        <Button Classes="toolbar-chip"
                                Command="{Binding ToggleQueueDrawerCommand}"
                                Content="Collapse" />
                        <Button Classes="toolbar-chip"
                                Command="{Binding RemoveQueuedActionCommand}"
                                Content="Remove Selected" />
                        <Button Classes="toolbar-chip"
                                Command="{Binding ClearQueueCommand}"
                                Content="Clear Queue" />
                        <Button Classes="toolbar-chip"
                                Command="{Binding ApplyChangesCommand}"
                                Content="Apply Changes" />
                      </WrapPanel>
                    </Grid>
                  </Border>

                  <Grid Grid.Row="1"
                        ColumnDefinitions="0.9*,1.1*"
                        Margin="0,14,0,0">
                    <StackPanel Spacing="8">
                      <TextBlock FontSize="11"
                                 Opacity="0.68"
                                 Text="Queued Actions" />
                      <Border Background="#1A2027"
                              CornerRadius="10"
                              Padding="14"
                              Margin="0,0,12,0">
                        <Grid RowDefinitions="*">
                          <ListBox ItemsSource="{Binding QueuedActions}"
                                   SelectedItem="{Binding SelectedQueuedAction}"
                                   IsVisible="{Binding HasQueuedActions}">
                            <ListBox.ItemTemplate>
                              <DataTemplate DataType="models:QueuedActionModel">
                                <Border Background="#20262D"
                                        CornerRadius="10"
                                        Margin="0,0,0,10"
                                        Padding="12">
                                  <StackPanel Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto">
                                      <TextBlock FontWeight="SemiBold"
                                                 Text="{Binding Name}" />
                                      <Border Grid.Column="1"
                                              Background="#28303A"
                                              CornerRadius="999"
                                              Padding="10,4"
                                              Margin="10,0,0,0">
                                        <TextBlock FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ActionText}" />
                                      </Border>
                                    </Grid>
                                    <TextBlock FontSize="12"
                                               Opacity="0.75"
                                               Text="{Binding Identifier}" />
                                    <TextBlock TextWrapping="Wrap"
                                               Opacity="0.84"
                                               Text="{Binding DetailText}" />
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ListBox.ItemTemplate>
                          </ListBox>

                          <Border Background="#20262D"
                                  CornerRadius="10"
                                  Padding="16"
                                  IsVisible="{Binding ShowEmptyQueueState}">
                            <StackPanel Spacing="8"
                                        VerticalAlignment="Center">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Nothing Queued Yet" />
                              <TextBlock TextWrapping="Wrap"
                                         Opacity="0.82"
                                         Text="Queue install, update, or remove actions from a selected mod to build a preflight summary before applying anything." />
                            </StackPanel>
                          </Border>
                        </Grid>
                      </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="8">
                      <TextBlock FontSize="11"
                                 Opacity="0.68"
                                 Text="Impact Preview" />
                      <Border Background="#1A2027"
                              CornerRadius="10"
                              Padding="14"
                              Margin="12,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                          <StackPanel Spacing="12">
                            <StackPanel Spacing="4">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Preview of Changes" />
                              <TextBlock FontSize="12"
                                         Opacity="0.72"
                                         Text="{Binding PreviewStatusLabel}" />
                            </StackPanel>

                          <Border Background="{Binding ApplyResultBackground}"
                                  BorderBrush="{Binding ApplyResultBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="10"
                                  Padding="12"
                                  IsVisible="{Binding HasApplyResult}">
                            <StackPanel Spacing="8">
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding ApplyResultTitle}" />
                              <TextBlock TextWrapping="Wrap"
                                         Opacity="0.86"
                                         Text="{Binding ApplyResultMessage}" />

                              <ItemsControl IsVisible="{Binding HasApplyResultSummaryLines}"
                                            ItemsSource="{Binding ApplyResultSummaryLines}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               Opacity="0.82"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>

                              <Border Background="#161B21"
                                      CornerRadius="8"
                                      Padding="10"
                                      IsVisible="{Binding HasApplyResultFollowUpLines}">
                                <StackPanel Spacing="6">
                                  <TextBlock FontWeight="SemiBold"
                                             Text="Follow-Up" />
                                  <ItemsControl ItemsSource="{Binding ApplyResultFollowUpLines}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <TextBlock Margin="0,0,0,4"
                                                   Opacity="0.84"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding}" />
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </Border>
                            </StackPanel>
                          </Border>

                          <Border Background="#253244"
                                  CornerRadius="10"
                                  Padding="12"
                                  IsVisible="{Binding PreviewShowsLoadingCard}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding PreviewOutcomeTitle}" />
                              <TextBlock TextWrapping="Wrap"
                                         Opacity="0.84"
                                         Text="{Binding PreviewImpactSummary}" />
                            </StackPanel>
                          </Border>

                          <Border Background="#1F3A2A"
                                  CornerRadius="10"
                                  Padding="12"
                                  IsVisible="{Binding PreviewShowsReadyCard}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding PreviewOutcomeTitle}" />
                              <TextBlock TextWrapping="Wrap"
                                         Opacity="0.84"
                                         Text="{Binding PreviewImpactSummary}" />
                            </StackPanel>
                          </Border>

                          <Border Background="#4A232A"
                                  CornerRadius="10"
                                  Padding="12"
                                  IsVisible="{Binding PreviewShowsBlockedCard}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding PreviewOutcomeTitle}" />
                              <TextBlock TextWrapping="Wrap"
                                         Opacity="0.84"
                                         Text="{Binding PreviewImpactSummary}" />
                            </StackPanel>
                          </Border>

                          <Border Background="#25303B"
                                  CornerRadius="10"
                                  Padding="12"
                                  IsVisible="{Binding PreviewShowsEmptyCard}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding PreviewOutcomeTitle}" />
                              <TextBlock TextWrapping="Wrap"
                                         Opacity="0.84"
                                         Text="{Binding PreviewImpactSummary}" />
                            </StackPanel>
                          </Border>

                          <WrapPanel ItemHeight="56"
                                     IsVisible="{Binding HasQueuedActions}">
                            <Border Background="#161B21"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,8,8"
                                    Width="112">
                              <StackPanel Spacing="3">
                                <TextBlock FontSize="11"
                                           Opacity="0.7"
                                           Text="Queued" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding PreviewQueuedCountLabel}" />
                              </StackPanel>
                            </Border>
                            <Border Background="#161B21"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,8,8"
                                    Width="124">
                              <StackPanel Spacing="3">
                                <TextBlock FontSize="11"
                                           Opacity="0.7"
                                           Text="Downloads" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding PreviewDownloadCountLabel}" />
                              </StackPanel>
                            </Border>
                            <Border Background="#161B21"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,8,8"
                                    Width="142">
                              <StackPanel Spacing="3">
                                <TextBlock FontSize="11"
                                           Opacity="0.7"
                                           Text="Dependencies" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding PreviewDependencyCountLabel}" />
                              </StackPanel>
                            </Border>
                            <Border Background="#161B21"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,8,8"
                                    Width="136">
                              <StackPanel Spacing="3">
                                <TextBlock FontSize="11"
                                           Opacity="0.7"
                                           Text="Auto-Removals" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding PreviewAutoRemovalCountLabel}" />
                              </StackPanel>
                            </Border>
                            <Border Background="#161B21"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,8,8"
                                    Width="112">
                              <StackPanel Spacing="3">
                                <TextBlock FontSize="11"
                                           Opacity="0.7"
                                           Text="Conflicts" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding PreviewConflictCountLabel}" />
                              </StackPanel>
                            </Border>
                            <Border Background="#161B21"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,8,8"
                                    Width="132">
                              <StackPanel Spacing="3">
                                <TextBlock FontSize="11"
                                           Opacity="0.7"
                                           Text="Attention" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding PreviewAttentionCountLabel}" />
                              </StackPanel>
                            </Border>
                          </WrapPanel>

                          <TextBlock FontSize="11"
                                     Opacity="0.68"
                                     Text="Summary" />
                          <TextBlock TextWrapping="Wrap"
                                     Opacity="0.86"
                                     Text="{Binding PreviewSummary}" />

                          <ProgressBar Height="16"
                                       IsIndeterminate="{Binding IsPreviewLoading}"
                                       IsVisible="{Binding IsPreviewLoading}" />

                          <Border Background="#3A1E24"
                                  BorderBrush="#934354"
                                  BorderThickness="1"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding HasPreviewConflicts}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Conflicts" />
                              <ItemsControl ItemsSource="{Binding PreviewConflicts}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>

                          <Border Background="#4A3920"
                                  BorderBrush="#9A7B37"
                                  BorderThickness="1"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding HasPreviewAttentionNotes}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Before You Apply" />
                              <ItemsControl ItemsSource="{Binding PreviewAttentionNotes}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>

                          <Border Background="#2E3540"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding HasPreviewDownloadsRequired}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Downloads Required" />
                              <ItemsControl ItemsSource="{Binding PreviewDownloadsRequired}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>

                          <Border Background="#161B21"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding HasPreviewDependencies}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Dependency Installs" />
                              <ItemsControl ItemsSource="{Binding PreviewDependencies}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>

                          <Border Background="#161B21"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding HasPreviewAutoRemovals}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Auto-Removals" />
                              <ItemsControl ItemsSource="{Binding PreviewAutoRemovals}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>

                          <Border Background="#161B21"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding HasPreviewRecommendations}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Recommendations" />
                              <ItemsControl ItemsSource="{Binding PreviewRecommendations}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>

                          <Border Background="#161B21"
                                  CornerRadius="8"
                                  Padding="12"
                                  IsVisible="{Binding HasPreviewSuggestions}">
                            <StackPanel Spacing="6">
                              <TextBlock FontWeight="SemiBold"
                                         Text="Suggestions" />
                              <ItemsControl ItemsSource="{Binding PreviewSuggestions}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               TextWrapping="Wrap"
                                               Text="{Binding}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>
                          </StackPanel>
                        </ScrollViewer>
                      </Border>
                    </StackPanel>
                  </Grid>
                </Grid>
              </Border>
            </Grid>
          </Border>

          <Border Background="#3A1E24"
                  BorderBrush="#934354"
                  BorderThickness="1"
                  CornerRadius="12"
                  Padding="24"
                  IsVisible="{Binding HasError}">
            <StackPanel Spacing="16">
              <TextBlock FontSize="24"
                         FontWeight="SemiBold"
                         Text="{Binding StageTitle}" />
              <TextBlock TextWrapping="Wrap"
                         Opacity="0.9"
                         Text="{Binding StageDescription}" />
              <Border Background="#271217"
                      CornerRadius="10"
                      Padding="16">
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding Diagnostics}" />
              </Border>
              <Button Width="170"
                      HorizontalAlignment="Left"
                      Command="{Binding RefreshCommand}"
                      Content="Retry Startup" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </Grid>

  </Grid>
  </LayoutTransformControl>
</Window>
