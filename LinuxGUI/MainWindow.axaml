<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CKAN.LinuxGUI"
        xmlns:models="using:CKAN.App.Models"
        xmlns:media="using:Avalonia.Media"
        xmlns:shapes="using:Avalonia.Controls.Shapes"
        mc:Ignorable="d"
        x:Class="CKAN.LinuxGUI.MainWindow"
        x:Name="MainWindowRoot"
        KeyDown="Window_OnKeyDown"
        x:DataType="vm:MainWindowViewModel"
        Width="1200"
        Height="760"
        MinWidth="1040"
        MinHeight="700"
        Title="CKAN Linux"
        FontFamily="Inter, Noto Sans, Segoe UI, Arial"
        Background="#171C22">
  <Window.Styles>
    <Style Selector="ToggleButton.toolbar-chip">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="86" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Margin" Value="0,0,8,8" />
    </Style>
    <Style Selector="Button.toolbar-chip">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="Margin" Value="0,0,8,8" />
    </Style>
    <Style Selector="Button.preview-action">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="MinWidth" Value="132" />
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="StackPanel.preview-summary-metric">
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.preview-summary-metric-card">
      <Setter Property="Height" Value="52" />
    </Style>
    <Style Selector="ToggleButton.browser-chip">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="#161B21" />
      <Setter Property="BorderBrush" Value="#34404C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Button.browser-chip">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="#161B21" />
      <Setter Property="BorderBrush" Value="#34404C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Border.browser-chip">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#34404C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Button.column-sort-header">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Foreground" Value="#D7E0EA" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="ToggleButton.filter-menu-item">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Background" Value="#5B6068" />
      <Setter Property="BorderBrush" Value="#6A7079" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="ToggleButton.filter-menu-item:pointerover">
      <Setter Property="Background" Value="#666C75" />
      <Setter Property="BorderBrush" Value="#7A828D" />
    </Style>
    <Style Selector="ToggleButton.filter-menu-item:checked">
      <Setter Property="Background" Value="#8A1BB6" />
      <Setter Property="BorderBrush" Value="#B61BD1" />
    </Style>
    <Style Selector="Button.filter-menu-item">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Background" Value="#5B6068" />
      <Setter Property="BorderBrush" Value="#6A7079" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Button.filter-menu-item:pointerover">
      <Setter Property="Background" Value="#666C75" />
      <Setter Property="BorderBrush" Value="#7A828D" />
    </Style>
    <Style Selector="Border.filter-drawer-section">
      <Setter Property="Background" Value="#1A2027" />
      <Setter Property="BorderBrush" Value="#333D49" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="14" />
    </Style>
    <Style Selector="TextBlock.filter-drawer-title">
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#E5EDF6" />
    </Style>
    <Style Selector="TextBlock.filter-drawer-note">
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="Opacity" Value="0.72" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.filter-drawer-label">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Opacity" Value="0.72" />
      <Setter Property="Foreground" Value="#CDD7E2" />
    </Style>
    <Style Selector="TextBox.filter-drawer-input">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Background" Value="#14191F" />
      <Setter Property="BorderBrush" Value="#394654" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Foreground" Value="#F4F6F8" />
    </Style>
    <Style Selector="TextBox.filter-drawer-input:pointerover">
      <Setter Property="Background" Value="#171D24" />
      <Setter Property="BorderBrush" Value="#4B5A6B" />
    </Style>
    <Style Selector="TextBox.filter-drawer-input:focus">
      <Setter Property="Background" Value="#171D24" />
      <Setter Property="BorderBrush" Value="#637489" />
    </Style>
    <Style Selector="ComboBox.filter-state-picker">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="146" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Background" Value="#14191F" />
      <Setter Property="BorderBrush" Value="#394654" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Foreground" Value="#F4F6F8" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>
    <Style Selector="ComboBox.filter-state-picker:pointerover">
      <Setter Property="Background" Value="#171D24" />
      <Setter Property="BorderBrush" Value="#4B5A6B" />
    </Style>
    <Style Selector="ComboBox.filter-state-picker:focus">
      <Setter Property="Background" Value="#171D24" />
      <Setter Property="BorderBrush" Value="#637489" />
    </Style>
    <Style Selector="Border.filter-token-chip">
      <Setter Property="Background" Value="#27303A" />
      <Setter Property="BorderBrush" Value="#435465" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="Margin" Value="0,0,6,6" />
    </Style>
    <Style Selector="Border.filter-tag-picker-popup">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#39424E" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Width" Value="272" />
      <Setter Property="BoxShadow" Value="0 16 32 0 #66000000" />
    </Style>
    <Style Selector="Button.filter-tag-option-button">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="#161B21" />
      <Setter Property="BorderBrush" Value="#34404C" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ToggleButton.sort-menu-item">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="Background" Value="#161B21" />
      <Setter Property="BorderBrush" Value="#2B323C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="ToggleButton.sort-menu-item:checked">
      <Setter Property="Background" Value="#26303A" />
      <Setter Property="BorderBrush" Value="#4A5563" />
    </Style>
    <Style Selector="ToggleButton.details-section-chip">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Background" Value="#161B21" />
      <Setter Property="BorderBrush" Value="#2B323C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ToggleButton.details-section-chip:checked">
      <Setter Property="Background" Value="#B61BD1" />
      <Setter Property="BorderBrush" Value="#B61BD1" />
    </Style>
    <Style Selector="ContextMenu.mod-row-menu /template/ Border">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#39424E" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>
    <Style Selector="MenuItem.mod-row-menu-item">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="Foreground" Value="#F4F6F8" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,8" />
    </Style>
    <Style Selector="MenuItem.mod-row-menu-item:pointerover">
      <Setter Property="Background" Value="#2A323C" />
      <Setter Property="BorderBrush" Value="#475C73" />
    </Style>
    <Style Selector="Menu.app-menu-bar">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#F4F6F8" />
    </Style>
    <Style Selector="Menu.app-menu-bar > MenuItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#F4F6F8" />
      <Setter Property="Padding" Value="10,6" />
    </Style>
    <Style Selector="Menu.app-menu-bar > MenuItem:selected">
      <Setter Property="Background" Value="#2A323C" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="ClipToBounds" Value="False" />
      <Setter Property="Foreground" Value="#F4F6F8" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:focus">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Grid.ready-menu-key">
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="IsHitTestVisible" Value="False" />
      <Setter Property="MinHeight" Value="36" />
    </Style>
    <Style Selector="Border.ready-menu-key-shell">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#36404B" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.ready-menu-key-top-edge">
      <Setter Property="Height" Value="1" />
      <Setter Property="Margin" Value="7,0,7,0" />
      <Setter Property="Background" Value="#4A5561" />
      <Setter Property="Opacity" Value="0.28" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Top" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="Border.ready-menu-key-bottom-edge">
      <Setter Property="Height" Value="1" />
      <Setter Property="Margin" Value="7,0,7,0" />
      <Setter Property="Background" Value="#121820" />
      <Setter Property="Opacity" Value="0.45" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Bottom" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="Border.ready-menu-key-left-edge">
      <Setter Property="Width" Value="1" />
      <Setter Property="Margin" Value="0,7,0,7" />
      <Setter Property="Background" Value="#3A4450" />
      <Setter Property="Opacity" Value="0.18" />
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="Border.ready-menu-key-right-edge">
      <Setter Property="Width" Value="1" />
      <Setter Property="Margin" Value="0,7,0,7" />
      <Setter Property="Background" Value="#141A21" />
      <Setter Property="Opacity" Value="0.2" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="StackPanel.ready-menu-key-content">
      <Setter Property="Orientation" Value="Horizontal" />
      <Setter Property="Spacing" Value="8" />
      <Setter Property="Margin" Value="12,7,14,6" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="TextBlock.ready-menu-key-label">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#B6C0CB" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Viewbox.ready-menu-globe">
      <Setter Property="Width" Value="16" />
      <Setter Property="Height" Value="16" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="Ellipse.ready-menu-icon-planet">
      <Setter Property="Fill" Value="Transparent" />
      <Setter Property="Stroke" Value="#516072" />
      <Setter Property="StrokeThickness" Value="1.2" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="Ellipse.ready-menu-icon-inner">
      <Setter Property="Stroke" Value="#516072" />
      <Setter Property="StrokeThickness" Value="0.9" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="Line.ready-menu-icon-inner">
      <Setter Property="Stroke" Value="#516072" />
      <Setter Property="StrokeThickness" Value="0.9" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="Ellipse.ready-menu-icon-ring">
      <Setter Property="Stroke" Value="#324050" />
      <Setter Property="StrokeThickness" Value="1" />
      <Setter Property="Fill" Value="Transparent" />
      <Setter Property="StrokeDashArray" Value="2,1.5" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:pointerover Border.ready-menu-key-shell">
      <Setter Property="Background" Value="#252D37" />
      <Setter Property="BorderBrush" Value="#45515F" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:pointerover TextBlock.ready-menu-key-label">
      <Setter Property="Foreground" Value="#D8E1EA" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:pointerover Ellipse.ready-menu-icon-planet">
      <Setter Property="Fill" Value="#0D1F3A" />
      <Setter Property="Stroke" Value="#5A9FF5" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:pointerover Ellipse.ready-menu-icon-inner">
      <Setter Property="Stroke" Value="#3A7ACC" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:pointerover Line.ready-menu-icon-inner">
      <Setter Property="Stroke" Value="#3A7ACC" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:pointerover Ellipse.ready-menu-icon-ring">
      <Setter Property="Stroke" Value="#4CAF7D" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:selected Border.ready-menu-key-shell">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#36404B" />
      <Setter Property="Margin" Value="0" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:selected Border.ready-menu-key-top-edge">
      <Setter Property="Background" Value="#4A5561" />
      <Setter Property="Opacity" Value="0.28" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:selected Border.ready-menu-key-bottom-edge">
      <Setter Property="Background" Value="#121820" />
      <Setter Property="Opacity" Value="0.45" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:selected Border.ready-menu-key-left-edge">
      <Setter Property="Background" Value="#3A4450" />
      <Setter Property="Opacity" Value="0.18" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:selected Border.ready-menu-key-right-edge">
      <Setter Property="Background" Value="#141A21" />
      <Setter Property="Opacity" Value="0.2" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:selected TextBlock.ready-menu-key-label">
      <Setter Property="Foreground" Value="#B6C0CB" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:selected Ellipse.ready-menu-icon-planet">
      <Setter Property="Fill" Value="Transparent" />
      <Setter Property="Stroke" Value="#516072" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:selected Ellipse.ready-menu-icon-inner">
      <Setter Property="Stroke" Value="#516072" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:selected Line.ready-menu-icon-inner">
      <Setter Property="Stroke" Value="#516072" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:selected Ellipse.ready-menu-icon-ring">
      <Setter Property="Stroke" Value="#324050" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:focus Border.ready-menu-key-shell">
      <Setter Property="Background" Value="#252D37" />
      <Setter Property="BorderBrush" Value="#45515F" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:focus TextBlock.ready-menu-key-label">
      <Setter Property="Foreground" Value="#D8E1EA" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:focus Ellipse.ready-menu-icon-planet">
      <Setter Property="Fill" Value="#0D1F3A" />
      <Setter Property="Stroke" Value="#5A9FF5" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:focus Ellipse.ready-menu-icon-inner">
      <Setter Property="Stroke" Value="#3A7ACC" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:focus Line.ready-menu-icon-inner">
      <Setter Property="Stroke" Value="#3A7ACC" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem:focus Ellipse.ready-menu-icon-ring">
      <Setter Property="Stroke" Value="#4CAF7D" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem[IsSubMenuOpen=true] Border.ready-menu-key-shell">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="BorderBrush" Value="#36404B" />
      <Setter Property="Margin" Value="0" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem[IsSubMenuOpen=true] Border.ready-menu-key-top-edge">
      <Setter Property="Background" Value="#4A5561" />
      <Setter Property="Opacity" Value="0.28" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem[IsSubMenuOpen=true] Border.ready-menu-key-bottom-edge">
      <Setter Property="Background" Value="#121820" />
      <Setter Property="Opacity" Value="0.45" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem[IsSubMenuOpen=true] Border.ready-menu-key-left-edge">
      <Setter Property="Background" Value="#3A4450" />
      <Setter Property="Opacity" Value="0.18" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem[IsSubMenuOpen=true] Border.ready-menu-key-right-edge">
      <Setter Property="Background" Value="#141A21" />
      <Setter Property="Opacity" Value="0.2" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem[IsSubMenuOpen=true] TextBlock.ready-menu-key-label">
      <Setter Property="Foreground" Value="#B6C0CB" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem[IsSubMenuOpen=true] Ellipse.ready-menu-icon-planet">
      <Setter Property="Fill" Value="Transparent" />
      <Setter Property="Stroke" Value="#516072" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem[IsSubMenuOpen=true] Ellipse.ready-menu-icon-inner">
      <Setter Property="Stroke" Value="#516072" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem[IsSubMenuOpen=true] Line.ready-menu-icon-inner">
      <Setter Property="Stroke" Value="#516072" />
    </Style>
    <Style Selector="Menu.ready-title-menu > MenuItem[IsSubMenuOpen=true] Ellipse.ready-menu-icon-ring">
      <Setter Property="Stroke" Value="#324050" />
    </Style>
    <Style Selector="MenuItem.app-menu-item">
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="Foreground" Value="#F4F6F8" />
      <Setter Property="Padding" Value="12,8" />
    </Style>
    <Style Selector="MenuItem.app-menu-item:pointerover">
      <Setter Property="Background" Value="#2A323C" />
    </Style>
    <Style Selector="Border.surface-view-toggle">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="Width" Value="256" />
    </Style>
    <Style Selector="Border.surface-view-toggle-rim">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#36404B" />
      <Setter Property="BorderThickness" Value="1,0,1,0" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="Border.surface-view-toggle-left-edge">
      <Setter Property="Width" Value="1" />
      <Setter Property="Margin" Value="1,7,0,7" />
      <Setter Property="Background" Value="#3A4450" />
      <Setter Property="Opacity" Value="0.18" />
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="Border.surface-view-toggle-right-edge">
      <Setter Property="Width" Value="1" />
