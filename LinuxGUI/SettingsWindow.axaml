<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="CKAN.LinuxGUI.SettingsWindow"
        x:CompileBindings="False"
        mc:Ignorable="d"
        Width="900"
        Height="640"
        MinWidth="860"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Title="Settings"
        Background="#20262D">
  <Window.Styles>
    <Style Selector="Border.settings-group">
      <Setter Property="BorderBrush" Value="#55606B" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,12,10,10" />
    </Style>
    <Style Selector="TextBlock.settings-group-title">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="#F2F4F7" />
      <Setter Property="Background" Value="#20262D" />
      <Setter Property="Padding" Value="4,0" />
      <Setter Property="Margin" Value="0,-18,0,8" />
    </Style>
    <Style Selector="TextBlock.settings-label">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="#F2F4F7" />
    </Style>
    <Style Selector="TextBlock.settings-muted">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="#D8DEE5" />
      <Setter Property="Opacity" Value="0.86" />
    </Style>
    <Style Selector="Button.settings-button">
      <Setter Property="Background" Value="#1C2229" />
      <Setter Property="BorderBrush" Value="#3E4955" />
      <Setter Property="Foreground" Value="#F2F4F7" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="MinWidth" Value="84" />
      <Setter Property="Padding" Value="12,5" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="TextBox.settings-textbox">
      <Setter Property="Background" Value="#0F1419" />
      <Setter Property="BorderBrush" Value="#0B0F14" />
      <Setter Property="Foreground" Value="#E8EDF2" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="MinHeight" Value="28" />
    </Style>
    <Style Selector="ComboBox.settings-combo">
      <Setter Property="Background" Value="#F4F6F8" />
      <Setter Property="Foreground" Value="#11161C" />
      <Setter Property="BorderBrush" Value="#0B0F14" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="4,2" />
      <Setter Property="MinHeight" Value="28" />
    </Style>
    <Style Selector="ListBox.settings-list">
      <Setter Property="Background" Value="#F5F5F5" />
      <Setter Property="BorderBrush" Value="#0B0F14" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinHeight" Value="0" />
    </Style>
    <Style Selector="ListBox.settings-list ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="CheckBox.settings-check">
      <Setter Property="Foreground" Value="#F2F4F7" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>
    <Style Selector="TextBlock.card-error">
      <Setter Property="Foreground" Value="#FF6B6B" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </Window.Styles>

  <Grid Margin="18">
    <Grid ColumnDefinitions="*,*,*"
          RowDefinitions="164,198,*">
      <Border Classes="settings-group"
              Grid.ColumnSpan="2"
              Margin="0,0,14,14">
        <Grid RowDefinitions="Auto,*,Auto">
          <TextBlock Classes="settings-group-title"
                     Text="Metadata Repositories" />
          <Grid Grid.Row="1"
                RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="140,*"
                  Margin="0,0,0,4">
              <TextBlock Classes="settings-label"
                         Text="Name" />
              <TextBlock Grid.Column="1"
                         Classes="settings-label"
                         Text="URL" />
            </Grid>
            <ListBox Grid.Row="1"
                     Classes="settings-list"
                     ItemsSource="{Binding RepositoryRows}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="140,*"
                        Margin="8,4">
                    <TextBlock Foreground="#11161C"
                               Text="{Binding Name}" />
                    <TextBlock Grid.Column="1"
                               Foreground="#11161C"
                               Text="{Binding Url}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
          <DockPanel Grid.Row="2"
                     Margin="0,8,0,0">
            <Button Classes="settings-button"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right"
                    IsEnabled="False"
                    Content="Delete" />
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <Button Classes="settings-button"
                      IsEnabled="False"
                      Content="New" />
              <Button Classes="settings-button"
                      IsEnabled="False"
                      Content="Up" />
              <Button Classes="settings-button"
                      IsEnabled="False"
                      Content="Down" />
            </StackPanel>
          </DockPanel>
        </Grid>
      </Border>

      <Border Grid.Column="2"
              Classes="settings-group"
              Margin="0,0,0,14">
        <Grid RowDefinitions="Auto,*,Auto">
          <TextBlock Classes="settings-group-title"
                     Text="Authentication Tokens" />
          <Grid Grid.Row="1"
                RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="110,*"
                  Margin="0,0,0,4">
              <TextBlock Classes="settings-label"
                         Text="Host" />
              <TextBlock Grid.Column="1"
                         Classes="settings-label"
                         Text="Token" />
            </Grid>
            <ListBox Grid.Row="1"
                     Classes="settings-list"
                     ItemsSource="{Binding AuthTokenRows}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="110,*"
                        Margin="8,4">
                    <TextBlock Foreground="#11161C"
                               Text="{Binding Host}" />
                    <TextBlock Grid.Column="1"
                               Foreground="#11161C"
                               Text="{Binding Token}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
          <DockPanel Grid.Row="2"
                     Margin="0,8,0,0">
            <Button Classes="settings-button"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right"
                    IsEnabled="False"
                    Content="Delete" />
            <Button Classes="settings-button"
                    IsEnabled="False"
                    Content="New" />
          </DockPanel>
        </Grid>
      </Border>

      <Border Grid.Row="1"
              Classes="settings-group"
              Margin="0,0,14,14">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Classes="settings-group-title"
                     Text="Auto-Updates" />
          <Grid Grid.Row="0"
                ColumnDefinitions="105,*"
                RowDefinitions="Auto,Auto"
                Margin="0,2,0,10">
            <TextBlock Classes="settings-label"
                       Text="Local version:" />
            <TextBlock Grid.Column="1"
                       Classes="settings-muted"
                       Text="{Binding LocalVersion}" />
            <TextBlock Grid.Row="1"
                       Classes="settings-label"
                       Text="Latest version:" />
            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Classes="settings-muted"
                       Text="{Binding LatestVersion}" />
          </Grid>
          <CheckBox Grid.Row="1"
                    Classes="settings-check"
                    IsEnabled="False"
                    Content="Check for CKAN updates on launch" />
          <CheckBox Grid.Row="2"
                    Classes="settings-check"
                    IsChecked="{Binding UseDevBuilds}"
                    Content="Use dev builds" />
          <StackPanel Grid.Row="3"
                      Orientation="Horizontal"
                      Spacing="10"
                      Margin="0,8,0,0">
            <Button Classes="settings-button"
                    Click="CheckForUpdatesButton_OnClick"
                    Content="Check for updates" />
            <Button Classes="settings-button"
                    IsEnabled="False"
                    Content="Install update" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Row="1"
              Grid.Column="1"
              Grid.ColumnSpan="2"
              Classes="settings-group"
              Margin="0,0,0,14">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <TextBlock Classes="settings-group-title"
                     Text="Download Cache" />
          <Grid ColumnDefinitions="*,Auto"
                Margin="0,2,0,8">
            <TextBox Classes="settings-textbox"
                     IsReadOnly="True"
                     Text="{Binding DownloadCachePath}" />
            <Button Grid.Column="1"
                    Classes="settings-button"
                    Margin="8,0,0,0"
                    Click="ChangeCachePathButton_OnClick"
                    Content="Edit" />
          </Grid>
          <TextBlock Grid.Row="1"
                     Classes="settings-muted"
                     Margin="0,0,0,8"
                     Text="{Binding DownloadCacheSummary}" />
          <Grid Grid.Row="2"
                ColumnDefinitions="140,64,*"
                Margin="0,0,0,10">
            <TextBlock Classes="settings-label"
                       VerticalAlignment="Center"
                       Text="Maximum cache size:" />
            <TextBox Grid.Column="1"
                     Classes="settings-textbox"
                     HorizontalAlignment="Stretch"
                     Text="{Binding CacheSizeLimitMiBText}" />
            <TextBlock Grid.Column="2"
                       Classes="settings-muted"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Text="MiB (empty for unlimited)" />
          </Grid>
          <StackPanel Grid.Row="3"
                      Orientation="Horizontal"
                      Spacing="10">
            <Button Classes="settings-button"
                    Click="ChangeCachePathButton_OnClick"
                    Content="Change..." />
            <Button Classes="settings-button"
                    Click="PurgeCacheButton_OnClick"
                    Content="Purge" />
            <Button Classes="settings-button"
                    Click="OpenCacheButton_OnClick"
                    Content="Open" />
          </StackPanel>
          <TextBlock Grid.Row="4"
                     Classes="card-error"
                     Margin="0,10,0,0"
                     IsVisible="{Binding ShowCacheError}"
                     Text="{Binding CacheErrorMessage}" />
        </Grid>
      </Border>

      <Border Grid.Row="2"
              Classes="settings-group"
              Margin="0,0,14,0">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Classes="settings-group-title"
                     Text="Behavior" />
          <CheckBox Classes="settings-check"
                    IsEnabled="False"
                    Content="Enable tray icon" />
          <CheckBox Grid.Row="1"
                    Classes="settings-check"
                    IsEnabled="False"
                    Content="Minimize to tray" />
          <Grid Grid.Row="2"
                ColumnDefinitions="140,52,*"
                Margin="0,8,0,8">
            <TextBlock Classes="settings-label"
                       VerticalAlignment="Center"
                       Text="Refresh modlist every" />
            <TextBox Grid.Column="1"
                     Classes="settings-textbox"
                     Text="{Binding RefreshRateText}" />
            <TextBlock Grid.Column="2"
                       Classes="settings-muted"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Text="minute(s)" />
          </Grid>
          <CheckBox Grid.Row="3"
                    Classes="settings-check"
                    IsEnabled="False"
                    Content="Pause refreshing" />
        </Grid>
      </Border>

      <Border Grid.Row="2"
              Grid.Column="1"
              Grid.ColumnSpan="2"
              Classes="settings-group">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Classes="settings-group-title"
                     Text="More Settings" />
          <Grid Margin="0,4,0,10"
                ColumnDefinitions="270,*">
            <TextBlock Classes="settings-label"
                       VerticalAlignment="Center"
                       Text="Language (requires restart):" />
            <ComboBox Grid.Column="1"
                      Classes="settings-combo"
                      ItemsSource="{Binding LanguageOptions}"
                      SelectedItem="{Binding SelectedLanguage}" />
          </Grid>
          <CheckBox Grid.Row="1"
                    Classes="settings-check"
                    IsEnabled="False"
                    IsChecked="True"
                    Content="Update repositories on launch" />
          <CheckBox Grid.Row="2"
                    Classes="settings-check"
                    IsEnabled="False"
                    IsChecked="True"
                    Content="Hide epoch numbers in mod list (requires restart)" />
          <CheckBox Grid.Row="3"
                    Classes="settings-check"
                    IsEnabled="False"
                    Content="Hide &quot;v&quot; in mod list (requires restart)" />
          <CheckBox Grid.Row="4"
                    Classes="settings-check"
                    IsEnabled="False"
                    IsChecked="True"
                    Content="Automatically sort by &quot;Update&quot; column when clicking &quot;Add available updates&quot;" />
          <Grid Grid.Row="5"
                Margin="0,4,0,0"
                ColumnDefinitions="270,*">
            <TextBlock Classes="settings-label"
                       VerticalAlignment="Center"
                       Text="Stability tolerance:" />
            <ComboBox Grid.Column="1"
                      Classes="settings-combo"
                      IsEnabled="{Binding CanEditStabilityTolerance}"
                      ItemsSource="{Binding StabilityToleranceOptions}"
                      SelectedItem="{Binding SelectedStabilityTolerance}" />
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
