<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CKAN.LinuxGUI.InstallationHistoryWindow"
        x:CompileBindings="False"
        Width="920"
        Height="580"
        MinWidth="820"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Title="Installation History"
        Background="#171C22">
  <Window.Styles>
    <Style Selector="Button.dialog-action">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto"
        Margin="20">
    <StackPanel Spacing="6">
      <TextBlock FontSize="22"
                 FontWeight="SemiBold"
                 Text="Installation History" />
      <TextBlock FontSize="13"
                 Opacity="0.74"
                 TextWrapping="Wrap"
                 Text="{Binding SummaryText}" />
    </StackPanel>

    <Grid Grid.Row="1"
          ColumnDefinitions="0.95*,1.45*"
          Margin="0,18,0,0">
      <Border Background="#161B21"
              BorderBrush="#2B323C"
              BorderThickness="1"
              CornerRadius="10"
              Padding="12"
              Margin="0,0,8,0">
        <Grid RowDefinitions="Auto,*">
          <TextBlock FontWeight="SemiBold"
                     Text="Snapshots" />
          <ListBox Grid.Row="1"
                   Margin="0,12,0,0"
                   ItemsSource="{Binding Snapshots}"
                   SelectedItem="{Binding SelectedSnapshot, Mode=TwoWay}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border BorderBrush="#242B33"
                        BorderThickness="0,0,0,1"
                        Padding="0,10">
                  <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding TimestampText}" />
                    <TextBlock FontSize="12"
                               Opacity="0.68"
                               Text="{Binding FileName}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Background="#161B21"
              BorderBrush="#2B323C"
              BorderThickness="1"
              CornerRadius="10"
              Padding="12"
              Margin="8,0,0,0">
        <Grid RowDefinitions="Auto,*">
          <StackPanel Spacing="4">
            <TextBlock FontWeight="SemiBold"
                       Text="{Binding SelectedSnapshotTitle}" />
            <TextBlock FontSize="12"
                       Opacity="0.68"
                       TextWrapping="Wrap"
                       Text="{Binding SelectedSnapshotSubtitle}" />
          </StackPanel>

          <ScrollViewer Grid.Row="1"
                        Margin="0,12,0,0">
            <ItemsControl ItemsSource="{Binding Modules}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="#242B33"
                          BorderThickness="0,0,0,1"
                          Padding="0,10">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Spacing="3">
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding Name}" />
                        <TextBlock FontSize="12"
                                   Opacity="0.66"
                                   Text="{Binding Identifier}" />
                      </StackPanel>
                      <TextBlock Grid.Column="1"
                                 VerticalAlignment="Center"
                                 Opacity="0.76"
                                 Text="{Binding Version}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <StackPanel Grid.Row="2"
                Margin="0,18,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="12">
      <Button Classes="dialog-action"
              Background="#1F3D58"
              BorderBrush="#31597B"
              Foreground="#F4F6F8"
              Click="OpenSnapshotFolderButton_OnClick"
              IsEnabled="{Binding HasSelectedSnapshot}"
              Content="Open Snapshot Folder" />
      <Button Classes="dialog-action"
              Background="#20262D"
              BorderBrush="#39424E"
              Foreground="#F4F6F8"
              Click="CloseButton_OnClick"
              Content="Close" />
    </StackPanel>
  </Grid>
</Window>
