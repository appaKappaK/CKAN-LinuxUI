<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CKAN.LinuxGUI.PluginsWindow"
        x:CompileBindings="False"
        Width="920"
        Height="560"
        MinWidth="820"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Title="Plugins"
        Background="#171C22">
  <Window.Styles>
    <Style Selector="Button.dialog-action">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="ListBox.plugin-list > ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto"
        Margin="20">
    <StackPanel Spacing="6">
      <TextBlock FontSize="22"
                 FontWeight="SemiBold"
                 Text="Plugins" />
      <TextBlock FontSize="13"
                 Opacity="0.74"
                 TextWrapping="Wrap"
                 Text="{Binding SummaryText}" />
      <TextBlock FontSize="12"
                 Opacity="0.6"
                 TextTrimming="CharacterEllipsis"
                 Text="{Binding PluginsPathLabel}" />
      <TextBlock FontSize="12"
                 Foreground="#F06C6C"
                 IsVisible="{Binding ShowMessage}"
                 TextWrapping="Wrap"
                 Text="{Binding Message}" />
      <Border Background="#4A3920"
              BorderBrush="#9A7B37"
              BorderThickness="1"
              CornerRadius="8"
              Padding="10,8"
              IsVisible="{Binding HasLoadFailures}">
        <StackPanel Spacing="4">
          <TextBlock FontSize="12"
                     FontWeight="SemiBold"
                     Text="{Binding LoadFailureHeading}" />
          <ItemsControl ItemsSource="{Binding LoadFailures}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock FontSize="12"
                           TextWrapping="Wrap"
                           Text="{Binding}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </StackPanel>

    <Grid Grid.Row="1"
          ColumnDefinitions="*,*"
          Margin="0,18,0,0">
      <Border Background="#161B21"
              BorderBrush="#2B323C"
              BorderThickness="1"
              CornerRadius="10"
              Padding="14"
              Margin="0,0,8,0">
        <Grid RowDefinitions="Auto,*,Auto">
          <TextBlock FontSize="15"
                     FontWeight="SemiBold"
                     Text="{Binding ActiveHeading}" />
          <ListBox Classes="plugin-list"
                   Grid.Row="1"
                   Margin="0,12,0,0"
                   ItemsSource="{Binding ActivePlugins}"
                   SelectedItem="{Binding SelectedActivePlugin, Mode=TwoWay}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Background="#1D232A"
                        BorderBrush="#2F3741"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                  <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding DisplayName}" />
                    <TextBlock FontSize="12"
                               Opacity="0.7"
                               Text="{Binding FileName}" />
                    <TextBlock FontSize="11"
                               Opacity="0.55"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding FilePath}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <StackPanel Grid.Row="2"
                      Margin="0,12,0,0"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="10">
            <Button Classes="dialog-action"
                    Background="#5B4020"
                    BorderBrush="#8A6837"
                    Foreground="#F4F6F8"
                    Click="DeactivateButton_OnClick"
                    IsEnabled="{Binding HasSelectedActivePlugin}"
                    Content="Deactivate" />
            <Button Classes="dialog-action"
                    Background="#1F3D58"
                    BorderBrush="#31597B"
                    Foreground="#F4F6F8"
                    Click="ReloadButton_OnClick"
                    IsEnabled="{Binding HasSelectedActivePlugin}"
                    Content="Reload" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Background="#161B21"
              BorderBrush="#2B323C"
              BorderThickness="1"
              CornerRadius="10"
              Padding="14"
              Margin="8,0,0,0">
        <Grid RowDefinitions="Auto,*,Auto">
          <TextBlock FontSize="15"
                     FontWeight="SemiBold"
                     Text="{Binding DormantHeading}" />
          <ListBox Classes="plugin-list"
                   Grid.Row="1"
                   Margin="0,12,0,0"
                   ItemsSource="{Binding DormantPlugins}"
                   SelectedItem="{Binding SelectedDormantPlugin, Mode=TwoWay}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Background="#1D232A"
                        BorderBrush="#2F3741"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                  <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding DisplayName}" />
                    <TextBlock FontSize="12"
                               Opacity="0.7"
                               Text="{Binding FileName}" />
                    <TextBlock FontSize="11"
                               Opacity="0.55"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding FilePath}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <StackPanel Grid.Row="2"
                      Margin="0,12,0,0"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="10">
            <Button Classes="dialog-action"
                    Background="#2E6D48"
                    BorderBrush="#3A8A5A"
                    Foreground="#F4F6F8"
                    Click="ActivateButton_OnClick"
                    IsEnabled="{Binding HasSelectedDormantPlugin}"
                    Content="Activate" />
            <Button Classes="dialog-action"
                    Background="#5B4020"
                    BorderBrush="#8A6837"
                    Foreground="#F4F6F8"
                    Click="UnloadButton_OnClick"
                    IsEnabled="{Binding HasSelectedDormantPlugin}"
                    Content="Unload" />
            <Button Classes="dialog-action"
                    Background="#355779"
                    BorderBrush="#5A86B4"
                    Foreground="#F4F6F8"
                    Click="AddPluginButton_OnClick"
                    Content="Add Plugin" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <StackPanel Grid.Row="2"
                Margin="0,18,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="12">
      <Button Classes="dialog-action"
              Background="#20262D"
              BorderBrush="#39424E"
              Foreground="#F4F6F8"
              Click="CloseButton_OnClick"
              Content="Close" />
    </StackPanel>
  </Grid>
</Window>
